            </div>
            <div class="col-md-4 text-center">
                <div class="dxs-step-badge">3</div>
                <div class="mb-6">
                    <img src="~/metronic/assets/media/illustrations/sketchy-1/12.png" class="mh-125px" alt="Xem kết quả"/>
