@using LotteryDetection.Web.Public.Startup
@{
    ViewBag.CurrentPageName = FrontEndPageNames.Home;
}

<!--begin::Features Section-->
<section id="features" class="py-20" style="background-color:#FAFBF6;">
    <div class="container">
        <div class="text-center mb-16">
            <span class="badge fw-bold fs-7 mb-5 px-4 py-2" style="background:rgba(0,187,119,0.12);color:#00bb77;border-radius:20px;">Tính Năng</span>
            <h2 class="fw-bold fs-2hx mb-4" style="color:#031649;">Mọi thứ bạn cần để dò xổ số</h2>
            <p class="fs-5 text-muted mw-550px mx-auto">Chỉ cần chiếc điện thoại, DòXổSố AI làm hết phần còn lại.</p>
        </div>
        <div class="row g-6">
            <div class="col-sm-6 col-lg-3">
                <div class="dxs-feature-card">
                    <div class="dxs-icon-circle"><i class="fa fa-camera fa-lg"></i></div>
                    <h5 class="fw-bold mb-3" style="color:#031649;">AI Nhận Diện Tức Thì</h5>
                    <p class="text-muted fs-6 mb-0 lh-lg">Chụp ảnh vé số, AI phân tích và trả kết quả trong vòng 2 giây.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="dxs-feature-card">
                    <div class="dxs-icon-circle"><i class="fa fa-check-circle fa-lg"></i></div>
                    <h5 class="fw-bold mb-3" style="color:#031649;">Kết Quả Chính Xác</h5>
                    <p class="text-muted fs-6 mb-0 lh-lg">Dữ liệu xổ số cập nhật trực tiếp từ đài phát hành chính thức trên toàn quốc.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="dxs-feature-card">
                    <div class="dxs-icon-circle"><i class="fa fa-history fa-lg"></i></div>
                    <h5 class="fw-bold mb-3" style="color:#031649;">Lịch Sử Đầy Đủ</h5>
                    <p class="text-muted fs-6 mb-0 lh-lg">Lưu toàn bộ lịch sử dò vé, tra cứu bất kỳ lúc nào, kể cả khi offline.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="dxs-feature-card">
                    <div class="dxs-icon-circle"><i class="fa fa-lock fa-lg"></i></div>
                    <h5 class="fw-bold mb-3" style="color:#031649;">Bảo Mật Tuyệt Đối</h5>
                    <p class="text-muted fs-6 mb-0 lh-lg">Không lưu ảnh vé số lên server. Dữ liệu cá nhân được mã hoá và bảo vệ an toàn.</p>
                </div>
            </div>
        </div>
    </div>
</section>
<!--end::Features Section-->

<!--begin::How It Works Section-->
