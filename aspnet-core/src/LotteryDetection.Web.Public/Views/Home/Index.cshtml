@using LotteryDetection.Web.Public.Startup
@{
    ViewBag.CurrentPageName = FrontEndPageNames.Home;
}

<!-- Hero Start -->
<div id="hero" class="container-fluid pt-5 hero-header mb-5">
    <div class="container pt-5">
        <div class="row g-5 pt-5 align-items-center">
            <div class="col-lg-6 align-self-center text-center text-lg-start mb-lg-5">
                <div class="btn btn-sm border rounded-pill px-3 mb-3 animated slideInRight"
                     style="color:#00bb77;border-color:rgba(0,187,119,.4);">
                    🎯 &nbsp;@L("Public_Hero_Badge")
                </div>
                <h1 class="display-4 text-white mb-4 animated slideInRight" style="line-height:1.15;">
                    @L("Public_Hero_Title1")<br>
                    <span style="background:linear-gradient(to right,#00bb77,#00e89a);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                        @L("Public_Hero_Title2")
                    </span>
                </h1>
                <p class="text-white mb-5 animated slideInRight" style="opacity:.8;font-size:1.1rem;line-height:1.7;">
                    @L("Public_Hero_Desc")
                </p>
                <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-lg-start animated slideInRight">
                    <a href="#download" class="btn btn-primary py-sm-3 px-sm-5 rounded-pill">
                        <i class="fa fa-download me-2"></i>@L("Public_Hero_DownloadBtn")
                    </a>
                    <a href="#about" class="btn btn-outline-light py-sm-3 px-sm-5 rounded-pill">
                        @L("Public_Hero_LearnMore")
                    </a>
                </div>
            </div>
            <div class="col-lg-6 align-self-end text-center text-lg-end pb-4">
                <img class="hero-phone-img animated slideInRight"
                     src="~/Common/Images/ai_hero.png"
                     alt="@L("Public_AppName")"
                     style="max-height:520px;border-radius:32px;box-shadow:0 0 30px rgba(0,232,154,0.5);"
                     onerror="this.src='~/Common/Images/42c751f5ffc17e9f27d0.jpg'">
            </div>
        </div>
    </div>
</div>
<!-- Hero End -->


<!-- Stats Start -->
<div class="container-fluid py-5" style="background:var(--light);">
    <div class="container py-3">
        <div class="row g-4 justify-content-center">
            <div class="col-md-4 col-sm-6 wow fadeIn" data-wow-delay="0.1s">
                <div class="stat-card text-center">
                    <div class="stat-number mb-2">100K+</div>
                    <h5 class="mb-1" style="color:var(--dark);">@L("Public_Stats_Tickets")</h5>
                    <p class="text-muted mb-0 small">@L("Public_Stats_TicketsDesc")</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6 wow fadeIn" data-wow-delay="0.3s">
                <div class="stat-card text-center">
                    <div class="stat-number mb-2">50K+</div>
                    <h5 class="mb-1" style="color:var(--dark);">@L("Public_Stats_Users")</h5>
                    <p class="text-muted mb-0 small">@L("Public_Stats_UsersDesc")</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6 wow fadeIn" data-wow-delay="0.5s">
                <div class="stat-card text-center">
                    <div class="stat-number mb-2">99%</div>
                    <h5 class="mb-1" style="color:var(--dark);">@L("Public_Stats_Accuracy")</h5>
                    <p class="text-muted mb-0 small">@L("Public_Stats_AccuracyDesc")</p>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Stats End -->


<!-- About Start -->
<div id="about" class="container-fluid py-5">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                <div class="about-img">
                    <img class="img-fluid"
                         src="~/Common/Images/ai_about.png"
                         alt="@L("Public_About_Badge")"
                         style="border-radius:32px;box-shadow:0 0 30px rgba(0,187,119,0.5);"
                         onerror="this.src='~/Common/Images/08ad499ee7aa66f43fbb.jpg'">
                </div>
            </div>
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.5s">
                <div class="btn btn-sm border rounded-pill px-3 mb-3"
                     style="color:var(--primary);border-color:rgba(0,187,119,.4);">
                    @L("Public_About_Badge")
                </div>
                <h1 class="mb-4">@L("Public_About_Title")</h1>
                <p class="mb-4">@L("Public_About_P1")</p>
                <p class="mb-4">@L("Public_About_P2")</p>
                <div class="row g-3 mb-4">
                    <div class="col-sm-6">
                        <h6 class="mb-3"><i class="fa fa-check text-primary me-2"></i>@L("Public_About_Feature1")</h6>
                        <h6 class="mb-0"><i class="fa fa-check text-primary me-2"></i>@L("Public_About_Feature2")</h6>
                    </div>
                    <div class="col-sm-6">
                        <h6 class="mb-3"><i class="fa fa-check text-primary me-2"></i>@L("Public_About_Feature3")</h6>
                        <h6 class="mb-0"><i class="fa fa-check text-primary me-2"></i>@L("Public_About_Feature4")</h6>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <a class="btn btn-primary rounded-pill px-4" href="#features">@L("Public_About_FeaturesBtn")</a>
                    <a class="btn btn-outline-primary btn-square" href="#download">
                        <i class="fa fa-download"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- About End -->


<!-- Features Start -->
<div id="features" class="container-fluid py-5" style="background:var(--light);">
    <div class="container py-5">
        <div class="mx-auto text-center wow fadeIn" data-wow-delay="0.1s" style="max-width:720px;margin-bottom:3rem;">
            <div class="btn btn-sm border rounded-pill px-3 mb-3"
                 style="color:var(--primary);border-color:rgba(0,187,119,.4);">
                @L("Public_Features_Badge")
            </div>
            <h1 class="mb-4">@L("Public_Features_Title")</h1>
            <p class="mb-0">@L("Public_Features_Desc")</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.1s">
                <div class="service-item d-flex flex-column text-center rounded h-100">
                    <div class="service-icon btn-square"><i class="fa fa-camera fa-2x"></i></div>
                    <h5 class="mb-3">@L("Public_Feature1_Title")</h5>
                    <p class="mb-0">@L("Public_Feature1_Desc")</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.3s">
                <div class="service-item d-flex flex-column text-center rounded h-100">
                    <div class="service-icon btn-square"><i class="fa fa-check-circle fa-2x"></i></div>
                    <h5 class="mb-3">@L("Public_Feature2_Title")</h5>
                    <p class="mb-0">@L("Public_Feature2_Desc")</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.5s">
                <div class="service-item d-flex flex-column text-center rounded h-100">
                    <div class="service-icon btn-square"><i class="fa fa-history fa-2x"></i></div>
                    <h5 class="mb-3">@L("Public_Feature3_Title")</h5>
                    <p class="mb-0">@L("Public_Feature3_Desc")</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.7s">
                <div class="service-item d-flex flex-column text-center rounded h-100">
                    <div class="service-icon btn-square"><i class="fa fa-lock fa-2x"></i></div>
                    <h5 class="mb-3">@L("Public_Feature4_Title")</h5>
                    <p class="mb-0">@L("Public_Feature4_Desc")</p>
                </div>
            </div>
        </div>
        <div class="text-center mt-5 wow fadeIn" data-wow-delay="0.2s">
            <a class="btn btn-primary rounded-pill px-4" href="#download">
                <i class="fa fa-download me-2"></i>@L("Public_Features_DownloadBtn")
            </a>
        </div>
    </div>
</div>
<!-- Features End -->


<!-- Screenshots Start -->
<div id="screenshots" class="container-fluid py-5">
    <div class="container py-5">
        <div class="mx-auto text-center wow fadeIn" data-wow-delay="0.1s" style="max-width:600px;margin-bottom:3rem;">
            <div class="btn btn-sm border rounded-pill px-3 mb-3"
                 style="color:var(--primary);border-color:rgba(0,187,119,.4);">
                @L("Public_Screenshots_Badge")
            </div>
            <h1 class="mb-4">@L("Public_Screenshots_Title")</h1>
            <p>@L("Public_Screenshots_Desc")</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.1s">
                <div class="screen-frame">
                    <img src="~/Common/Images/aeb64a80e4b465ea3ca5.jpg" alt="@L("Public_Screenshot1_Caption")">
                </div>
                <p class="screen-caption text-center">@L("Public_Screenshot1_Caption")</p>
            </div>
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.2s">
                <div class="screen-frame">
                    <img src="~/Common/Images/42c751f5ffc17e9f27d0.jpg" alt="@L("Public_Screenshot2_Caption")">
                </div>
                <p class="screen-caption text-center">@L("Public_Screenshot2_Caption")</p>
            </div>
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.3s">
                <div class="screen-frame">
                    <img src="~/Common/Images/08ad499ee7aa66f43fbb.jpg" alt="@L("Public_Screenshot3_Caption")">
                </div>
                <p class="screen-caption text-center">@L("Public_Screenshot3_Caption")</p>
            </div>
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.4s">
                <div class="screen-frame">
                    <img src="~/Common/Images/b112822e2c1aad44f40b.jpg" alt="@L("Public_Screenshot4_Caption")">
                </div>
                <p class="screen-caption text-center">@L("Public_Screenshot4_Caption")</p>
            </div>
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.5s">
                <div class="screen-frame">
                    <img src="~/Common/Images/857ac1476f73ee2db762.jpg" alt="@L("Public_Screenshot5_Caption")">
                </div>
                <p class="screen-caption text-center">@L("Public_Screenshot5_Caption")</p>
            </div>
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.6s">
                <div class="screen-frame">
                    <img src="~/Common/Images/0af84dc5e3f162af3be0.jpg" alt="@L("Public_Screenshot6_Caption")">
                </div>
                <p class="screen-caption text-center">@L("Public_Screenshot6_Caption")</p>
            </div>
        </div>
    </div>
</div>
<!-- Screenshots End -->


<!-- Team Start -->
<div id="team" class="container-fluid py-5" style="background:var(--light);">
    <div class="container py-5">
        <div class="mx-auto text-center wow fadeIn" data-wow-delay="0.1s" style="max-width:600px;margin-bottom:3rem;">
            <div class="btn btn-sm border rounded-pill px-3 mb-3"
                 style="color:var(--primary);border-color:rgba(0,187,119,.4);">
                @L("Public_Team_Badge")
            </div>
            <h1 class="mb-4">@L("Public_Team_Title")</h1>
            <p>@L("Public_Team_Desc")</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-md-6 col-lg-4 wow fadeIn" data-wow-delay="0.1s">
                <div class="text-center">
                    <div class="mb-3">
                        <img class="team-img" src="~/img/team-van-nguyen.png" alt="Van Nguyen"
                             onerror="this.src='https://ui-avatars.com/api/?name=Van+Nguyen&size=180&background=031649&color=00bb77&bold=true&rounded=true'">
                    </div>
                    <h5 class="mb-1">Van Nguyen</h5>
                    <p class="mb-2" style="color:var(--primary);">@L("Public_Team_Van_Role")</p>
                    <p class="text-muted mb-3 small">@L("Public_Team_Van_Bio")</p>
                    <div class="d-flex justify-content-center">
                        <a class="btn btn-outline-primary btn-square" href="https://www.linkedin.com/in/van-nguyen-ai26/" target="_blank">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 wow fadeIn" data-wow-delay="0.2s">
                <div class="text-center">
                    <div class="mb-3">
                        <img class="team-img" src="~/img/team-tommy-nguyen.png" alt="Tommy Nguyen"
                             onerror="this.src='https://ui-avatars.com/api/?name=Tommy+Nguyen&size=180&background=031649&color=00bb77&bold=true&rounded=true'">
                    </div>
                    <h5 class="mb-1">Tommy Nguyen</h5>
                    <p class="mb-2" style="color:var(--primary);">@L("Public_Team_Tommy_Role")</p>
                    <p class="text-muted mb-3 small">@L("Public_Team_Tommy_Bio")</p>
                    <div class="d-flex justify-content-center">
                        <a class="btn btn-outline-primary btn-square" href="https://www.linkedin.com/in/tommynguyen89898/" target="_blank">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 wow fadeIn" data-wow-delay="0.3s">
                <div class="text-center">
                    <div class="mb-3">
                        <img class="team-img" src="~/img/team-chien-nguyen.png" alt="Chien Nguyen"
                             onerror="this.src='https://ui-avatars.com/api/?name=Chien+Nguyen&size=180&background=031649&color=00bb77&bold=true&rounded=true'">
                    </div>
                    <h5 class="mb-1">Chien Nguyen</h5>
                    <p class="mb-2" style="color:var(--primary);">@L("Public_Team_Chien_Role")</p>
                    <p class="text-muted mb-3 small">@L("Public_Team_Chien_Bio")</p>
                    <div class="d-flex justify-content-center">
                        <a class="btn btn-outline-primary btn-square" href="https://www.linkedin.com/in/chien-nguyen-484a82149/" target="_blank">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Team End -->
