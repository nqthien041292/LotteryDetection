                <div class="text-center">
                    <div class="mb-3">
                        <img class="team-img" src="~/img/team-chien-nguyen.png" alt="Chien Nguyen"
                             onerror="this.src='https://ui-avatars.com/api/?name=Chien+Nguyen&size=180&background=031649&color=00bb77&bold=true&rounded=true'">
                    </div>
                    <h5 class="mb-1">Chien Nguyen</h5>
                    <p class="mb-2" style="color:var(--primary);">Co-founder &amp; Backend Lead</p>
