@using LotteryDetection.Web.Public.Startup
@{
    ViewBag.CurrentPageName = FrontEndPageNames.Home;
}

<!-- Hero Start -->
<div id="hero" class="container-fluid pt-5 hero-header mb-5">
    <div class="container pt-5">
        <div class="row g-5 pt-5 align-items-center">
            <!-- Text -->
            <div class="col-lg-6 align-self-center text-center text-lg-start mb-lg-5">
                <div class="btn btn-sm border rounded-pill px-3 mb-3 animated slideInRight"
                     style="color:#00bb77;border-color:rgba(0,187,119,.4);">
                    🎯 &nbsp;Miễn phí · iOS & Android
                </div>
                <h1 class="display-4 text-white mb-4 animated slideInRight" style="line-height:1.15;">
                    Dò Xổ Số<br>
                    <span style="background:linear-gradient(to right,#00bb77,#00e89a);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                        Thần Tốc Cùng AI
                    </span>
                </h1>
                <p class="text-white mb-5 animated slideInRight" style="opacity:.8;font-size:1.1rem;line-height:1.7;">
                    Chụp ảnh vé số — AI nhận diện và trả kết quả trong 2 giây.<br>
                    Chính xác, nhanh chóng, hoàn toàn miễn phí.
                </p>
                <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-lg-start animated slideInRight">
                    <a href="#download" class="btn btn-primary py-sm-3 px-sm-5 rounded-pill">
                        <i class="fa fa-download me-2"></i>Tải App Ngay
                    </a>
                    <a href="#about" class="btn btn-outline-light py-sm-3 px-sm-5 rounded-pill">
                        Xem thêm →
                    </a>
                </div>
            </div>
            <!-- Phone mockup -->
            <div class="col-lg-6 align-self-end text-center text-lg-end pb-4">
                <img class="hero-phone-img animated slideInRight"
                     src="~/Common/Images/42c751f5ffc17e9f27d0.jpg"
                     alt="DòXổSố AI – Trang chủ app"
                     style="max-height:520px;border-radius:32px;">
            </div>
        </div>
    </div>
</div>
<!-- Hero End -->


<!-- Stats Start -->
<div class="container-fluid py-5" style="background:var(--light);">
    <div class="container py-3">
        <div class="row g-4 justify-content-center">
            <div class="col-md-4 col-sm-6 wow fadeIn" data-wow-delay="0.1s">
                <div class="stat-card text-center">
                    <div class="stat-number mb-2">100K+</div>
                    <h5 class="mb-1" style="color:var(--dark);">Vé đã dò</h5>
                    <p class="text-muted mb-0 small">Tính từ khi ra mắt</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6 wow fadeIn" data-wow-delay="0.3s">
                <div class="stat-card text-center">
                    <div class="stat-number mb-2">50K+</div>
                    <h5 class="mb-1" style="color:var(--dark);">Người dùng</h5>
                    <p class="text-muted mb-0 small">Trên iOS & Android</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6 wow fadeIn" data-wow-delay="0.5s">
                <div class="stat-card text-center">
                    <div class="stat-number mb-2">99%</div>
                    <h5 class="mb-1" style="color:var(--dark);">Độ chính xác</h5>
                    <p class="text-muted mb-0 small">Được kiểm chứng thực tế</p>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Stats End -->


<!-- About Start -->
<div id="about" class="container-fluid py-5">
    <div class="container">
        <div class="row g-5 align-items-center">
            <!-- Screenshot image -->
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                <div class="about-img">
                    <img class="img-fluid"
                         src="~/Common/Images/08ad499ee7aa66f43fbb.jpg"
                         alt="Chụp ảnh vé số với DòXổSố AI">
                </div>
            </div>
            <!-- Text -->
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.5s">
                <div class="btn btn-sm border rounded-pill px-3 mb-3"
                     style="color:var(--primary);border-color:rgba(0,187,119,.4);">
                    Về ứng dụng
                </div>
                <h1 class="mb-4">Dò vé số chưa bao giờ đơn giản đến thế</h1>
                <p class="mb-4">
                    DòXổSố AI là ứng dụng dò xổ số thông minh sử dụng trí tuệ nhân tạo để nhận diện
                    vé số và tra cứu kết quả tự động. Không cần nhập tay từng con số — chỉ cần chụp ảnh
                    và để AI làm việc.
                </p>
                <p class="mb-4">
                    Kết quả xổ số được cập nhật trực tiếp từ các đài phát hành chính thức trên toàn quốc,
                    đảm bảo độ chính xác tuyệt đối.
                </p>
                <div class="row g-3 mb-4">
                    <div class="col-sm-6">
                        <h6 class="mb-3"><i class="fa fa-check text-primary me-2"></i>AI nhận diện tức thì</h6>
                        <h6 class="mb-0"><i class="fa fa-check text-primary me-2"></i>Kết quả chính xác</h6>
                    </div>
                    <div class="col-sm-6">
                        <h6 class="mb-3"><i class="fa fa-check text-primary me-2"></i>Lịch sử đầy đủ</h6>
                        <h6 class="mb-0"><i class="fa fa-check text-primary me-2"></i>Bảo mật dữ liệu</h6>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <a class="btn btn-primary rounded-pill px-4" href="#features">Xem tính năng</a>
                    <a class="btn btn-outline-primary btn-square" href="#download" title="Tải app">
                        <i class="fa fa-download"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- About End -->


<!-- Features Start -->
<div id="features" class="container-fluid py-5" style="background:var(--light);">
    <div class="container py-5">
        <div class="mx-auto text-center wow fadeIn" data-wow-delay="0.1s" style="max-width:720px;margin-bottom:3rem;">
            <div class="btn btn-sm border rounded-pill px-3 mb-3"
                 style="color:var(--primary);border-color:rgba(0,187,119,.4);">
                Tính năng nổi bật
            </div>
            <h1 class="mb-4">Mọi thứ bạn cần để dò xổ số</h1>
            <p class="mb-0">Chỉ cần chiếc điện thoại. DòXổSố AI làm hết phần còn lại.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.1s">
                <div class="service-item d-flex flex-column text-center rounded h-100">
                    <div class="service-icon btn-square">
                        <i class="fa fa-camera fa-2x"></i>
                    </div>
                    <h5 class="mb-3">AI Nhận Diện Tức Thì</h5>
                    <p class="mb-0">Chụp ảnh vé số, AI phân tích và trả kết quả trong vòng 2 giây.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.3s">
                <div class="service-item d-flex flex-column text-center rounded h-100">
                    <div class="service-icon btn-square">
                        <i class="fa fa-check-circle fa-2x"></i>
                    </div>
                    <h5 class="mb-3">Kết Quả Chính Xác</h5>
                    <p class="mb-0">Dữ liệu xổ số cập nhật trực tiếp từ đài phát hành chính thức trên toàn quốc.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.5s">
                <div class="service-item d-flex flex-column text-center rounded h-100">
                    <div class="service-icon btn-square">
                        <i class="fa fa-history fa-2x"></i>
                    </div>
                    <h5 class="mb-3">Lịch Sử Đầy Đủ</h5>
                    <p class="mb-0">Lưu toàn bộ lịch sử dò vé, tra cứu bất kỳ lúc nào, kể cả khi offline.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.7s">
                <div class="service-item d-flex flex-column text-center rounded h-100">
                    <div class="service-icon btn-square">
                        <i class="fa fa-lock fa-2x"></i>
                    </div>
                    <h5 class="mb-3">Bảo Mật Tuyệt Đối</h5>
                    <p class="mb-0">Không lưu ảnh vé số lên server. Dữ liệu được mã hoá và bảo vệ an toàn.</p>
                </div>
            </div>
        </div>
        <div class="text-center mt-5 wow fadeIn" data-wow-delay="0.2s">
            <a class="btn btn-primary rounded-pill px-4" href="#download">
                <i class="fa fa-download me-2"></i>Tải App Miễn Phí
            </a>
        </div>
    </div>
</div>
<!-- Features End -->


<!-- Screenshots Start -->
<div id="screenshots" class="container-fluid py-5">
    <div class="container py-5">
        <div class="mx-auto text-center wow fadeIn" data-wow-delay="0.1s" style="max-width:600px;margin-bottom:3rem;">
            <div class="btn btn-sm border rounded-pill px-3 mb-3"
                 style="color:var(--primary);border-color:rgba(0,187,119,.4);">
                App Screenshots
            </div>
            <h1 class="mb-4">Giao diện đẹp, dễ dùng</h1>
            <p>Thiết kế tối giản — từ đăng nhập đến kết quả, chỉ vài thao tác.</p>
        </div>
        <div class="row g-4 justify-content-center">
            <!-- Screenshot 1 — Login -->
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.1s">
                <div class="screen-frame">
                    <img src="~/Common/Images/aeb64a80e4b465ea3ca5.jpg" alt="Đăng nhập">
                </div>
                <p class="screen-caption text-center">Đăng nhập nhanh</p>
            </div>
            <!-- Screenshot 2 — Dashboard -->
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.2s">
                <div class="screen-frame">
                    <img src="~/Common/Images/42c751f5ffc17e9f27d0.jpg" alt="Trang chủ">
                </div>
                <p class="screen-caption text-center">Trang chủ</p>
            </div>
            <!-- Screenshot 3 — Capture -->
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.3s">
                <div class="screen-frame">
                    <img src="~/Common/Images/08ad499ee7aa66f43fbb.jpg" alt="Chụp ảnh vé">
                </div>
                <p class="screen-caption text-center">Chụp ảnh vé</p>
            </div>
            <!-- Screenshot 4 — AI analyzing -->
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.4s">
                <div class="screen-frame">
                    <img src="~/Common/Images/b112822e2c1aad44f40b.jpg" alt="AI phân tích">
                </div>
                <p class="screen-caption text-center">AI phân tích</p>
            </div>
            <!-- Screenshot 5 — Result -->
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.5s">
                <div class="screen-frame">
                    <img src="~/Common/Images/857ac1476f73ee2db762.jpg" alt="Kết quả dò vé">
                </div>
                <p class="screen-caption text-center">Kết quả tức thì</p>
            </div>
            <!-- Screenshot 6 — History -->
            <div class="col-6 col-md-4 col-lg-2 wow fadeIn" data-wow-delay="0.6s">
                <div class="screen-frame">
                    <img src="~/Common/Images/0af84dc5e3f162af3be0.jpg" alt="Lịch sử dò vé">
                </div>
                <p class="screen-caption text-center">Lịch sử dò vé</p>
            </div>
        </div>
    </div>
</div>
<!-- Screenshots End -->


<!-- Team Start -->
