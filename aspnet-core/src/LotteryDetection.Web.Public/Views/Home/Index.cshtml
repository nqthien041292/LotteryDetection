<!--begin::FAQ Section-->
<section id="faq" class="py-20" style="background:#FAFBF6;">
    <div class="container">
        <div class="text-center mb-14">
            <span class="badge fw-bold fs-7 mb-5 px-4 py-2" style="background:rgba(0,187,119,0.12);color:#00bb77;border-radius:20px;">FAQ</span>
            <h2 class="fw-bold fs-2hx mb-4" style="color:#031649;">Câu hỏi thường gặp</h2>
        </div>
        <div class="mw-800px mx-auto">
            <!--begin::FAQ 1-->
            <div class="dxs-faq-item">
                <button class="dxs-faq-question" type="button" data-bs-toggle="collapse" data-bs-target="#faq1" aria-expanded="true" aria-controls="faq1">
                    App hỗ trợ những đài xổ số nào?
                    <i class="fa fa-chevron-down text-muted fs-8"></i>
                </button>
                <div id="faq1" class="collapse show">
                    <div class="dxs-faq-answer">
                        DòXổSố AI hỗ trợ tất cả các đài xổ số kiến thiết miền Nam, miền Trung, miền Bắc và Vietlott. Kết quả được cập nhật ngay sau khi đài công bố chính thức.
                    </div>
                </div>
            </div>
            <!--end::FAQ 1-->
            <!--begin::FAQ 2-->
            <div class="dxs-faq-item">
                <button class="dxs-faq-question collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2" aria-expanded="false" aria-controls="faq2">
                    Kết quả dò có chính xác không?
                    <i class="fa fa-chevron-down text-muted fs-8"></i>
                </button>
                <div id="faq2" class="collapse">
                    <div class="dxs-faq-answer">
                        Có. AI nhận diện số vé với độ chính xác 99%+ và kết quả xổ số được lấy trực tiếp từ nguồn chính thức. Nếu ảnh chụp không rõ, app sẽ thông báo để bạn chụp lại.
                    </div>
                </div>
            </div>
            <!--end::FAQ 2-->
            <!--begin::FAQ 3-->
            <div class="dxs-faq-item">
                <button class="dxs-faq-question collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3" aria-expanded="false" aria-controls="faq3">
                    App có miễn phí không?
                    <i class="fa fa-chevron-down text-muted fs-8"></i>
                </button>
                <div id="faq3" class="collapse">
                    <div class="dxs-faq-answer">
                        Hoàn toàn miễn phí. Tải về, đăng ký và dò vé không mất bất kỳ chi phí nào. Không có phí ẩn hay gói nâng cấp bắt buộc.
                    </div>
                </div>
            </div>
            <!--end::FAQ 3-->
            <!--begin::FAQ 4-->
            <div class="dxs-faq-item">
                <button class="dxs-faq-question collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4" aria-expanded="false" aria-controls="faq4">
                    Dữ liệu và ảnh vé của tôi có bị lưu lại không?
                    <i class="fa fa-chevron-down text-muted fs-8"></i>
                </button>
                <div id="faq4" class="collapse">
                    <div class="dxs-faq-answer">
                        Ảnh vé số không được lưu trên server của chúng tôi. Chỉ có dãy số vé và kết quả dò được lưu vào lịch sử cá nhân, được mã hoá và bảo vệ nghiêm ngặt.
                    </div>
                </div>
            </div>
            <!--end::FAQ 4-->
            <!--begin::FAQ 5-->
            <div class="dxs-faq-item">
                <button class="dxs-faq-question collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq5" aria-expanded="false" aria-controls="faq5">
                    App có hoạt động khi không có mạng không?
                    <i class="fa fa-chevron-down text-muted fs-8"></i>
                </button>
                <div id="faq5" class="collapse">
                    <div class="dxs-faq-answer">
                        Cần kết nối mạng để AI phân tích và tra cứu kết quả xổ số mới nhất. Tuy nhiên, lịch sử dò đã lưu trước đó vẫn xem được khi offline.
                    </div>
                </div>
            </div>
            <!--end::FAQ 5-->
        </div>
    </div>
</section>
<!--end::FAQ Section-->

