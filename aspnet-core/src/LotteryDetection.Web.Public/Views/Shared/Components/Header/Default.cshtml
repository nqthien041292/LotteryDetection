@model LotteryDetection.Web.Public.Views.Shared.Components.Header.HeaderViewModel

<!-- Navbar Start -->
<div class="container-fluid sticky-top">
    <div class="container">
        <nav class="navbar navbar-expand-lg navbar-dark p-0">
            <!-- Logo -->
            <a href="/" class="navbar-brand d-flex align-items-center gap-2">
                <img src="~/Common/Images/logo.png" alt="@L("Public_AppName")"
                     style="height:38px;width:38px;object-fit:contain;border-radius:10px;background:#fff;padding:2px;">
                <span style="font-family:'Ubuntu',sans-serif;font-weight:700;font-size:1.25rem;color:#fff;">
                    DòXổSố <span style="color:#00bb77;">AI</span>
                </span>
            </a>

            <!-- Mobile toggle -->
            <button type="button" class="navbar-toggler ms-auto me-0"
                    data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarCollapse">
                <div class="navbar-nav ms-auto">
                    <a href="#hero"        class="nav-item nav-link">@L("Public_Nav_Home")</a>
                    <a href="#about"       class="nav-item nav-link">@L("Public_Nav_About")</a>
                    <a href="#features"    class="nav-item nav-link">@L("Public_Nav_Features")</a>
                    <a href="#screenshots" class="nav-item nav-link">@L("Public_Nav_Screenshots")</a>
                    <a href="#team"        class="nav-item nav-link">@L("Public_Nav_Team")</a>
                </div>

                @if (Model.Languages.Count > 1)
                {
                    <div class="dropdown me-2">
                        <button type="button"
                                class="btn btn-outline-light rounded-pill px-3 dropdown-toggle"
                                data-bs-toggle="dropdown">
                            <i class="@Model.CurrentLanguage.Icon"></i> @Model.CurrentLanguage.DisplayName
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @foreach (var languageInfo in Model.Languages)
                            {
                                if (Model.CurrentLanguage.Name == languageInfo.Name) continue;
                                <li>
                                    <a class="dropdown-item"
                                       href="@Url.Action("ChangeCulture", "AbpLocalization", new {
                                           area = "",
                                           cultureName = languageInfo.Name,
                                           returnUrl = Context.Request.Path + Context.Request.QueryString
                                       })">
                                        <i class="@languageInfo.Icon"></i> <span>@languageInfo.DisplayName</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }

                @if (Model.LoginInformations?.User != null)
                {
                    <div class="dropdown d-none d-lg-block">
                        <button type="button"
                                class="btn btn-light rounded-pill px-3 dropdown-toggle"
                                data-bs-toggle="dropdown">
                            @Model.GetShownLoginName()
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Logout", "Account")">
                                    <i class="fa fa-sign-out-alt me-2"></i>@L("Logout")
                                </a>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a href="#download"
                       class="btn btn-primary rounded-pill px-4 d-none d-lg-block"
                       style="font-weight:600;">
                        <i class="fa fa-download me-2"></i>@L("Public_Nav_Download")
                    </a>
                }
            </div>
        </nav>
    </div>
</div>
<!-- Navbar End -->
