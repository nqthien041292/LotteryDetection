@using Abp.Timing
<!--begin::Footer Section-->
<div class="mb-0">
    <!--begin::Curve top-->
    <div class="landing-curve landing-dark-color">
        <svg viewBox="15 -1 1470 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 48C4.93573 47.6644 8.85984 47.3311 12.7725 47H1489.16C1493.1 47.3311 1497.04 47.6644 1501 48V47H1489.16C914.668 -1.34764 587.282 -1.61174 12.7725 47H1V48Z" fill="currentColor"></path>
        </svg>
    </div>
    <!--end::Curve top-->
    <!--begin::Wrapper-->
    <div class="landing-dark-bg pt-20">
        <!--begin::Container-->
        <div class="container">
            <!--begin::Row-->
            <div class="row py-10 py-lg-20">
                <!--begin::Col left — App info-->
                <div class="col-lg-5 pe-lg-16 mb-10 mb-lg-0">
                    <div class="mb-6">
                        <span class="fw-bold fs-2" style="color:#00bb77;">DòXổSố</span>
                        <span class="text-white fw-bold fs-2"> AI</span>
                    </div>
                    <p class="text-gray-600 fs-5 lh-lg mb-8">
                        Ứng dụng dò xổ số thông minh bằng trí tuệ nhân tạo. Chụp ảnh vé số, AI phân tích và trả kết quả tức thì. Miễn phí cho iOS và Android.
                    </p>
                    <!--begin::Social links-->
                    <div class="d-flex gap-4">
                        <a href="#" class="d-flex align-items-center justify-content-center" style="width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,0.08);" title="Facebook">
                            <img src="~/metronic/assets/media/svg/brand-logos/facebook-4.svg" class="h-18px" alt="Facebook"/>
                        </a>
                        <a href="#" class="d-flex align-items-center justify-content-center" style="width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,0.08);" title="Instagram">
                            <img src="~/metronic/assets/media/svg/brand-logos/instagram-2-1.svg" class="h-18px" alt="Instagram"/>
                        </a>
                        <a href="#" class="d-flex align-items-center justify-content-center" style="width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,0.08);" title="Github">
                            <img src="~/metronic/assets/media/svg/brand-logos/github.svg" class="h-18px" alt="Github"/>
                        </a>
                    </div>
