                        &copy; @Clock.Now.Year DòXổSố AI &nbsp;·&nbsp; FamilyAI Tech. All rights reserved.
                    </span>
                </div>
                <!--end::Copyright-->
                <!--begin::Links-->
                <ul class="menu menu-gray-600 menu-hover-primary fw-semibold fs-6 fs-md-5 order-1 mb-5 mb-md-0">
                    <li class="menu-item">
                        <a href="#" class="menu-link px-2">Về chúng tôi</a>
                    </li>
                    <li class="menu-item mx-5">
                        <a href="mailto:support@doxoso.ai" class="menu-link px-2">Liên hệ</a>
                    </li>
                    <li class="menu-item">
                        <a href="#" class="menu-link px-2">Chính sách bảo mật</a>
                    </li>
                </ul>
                <!--end::Links-->
            </div>
        </div>
        <!--end::Container bottom-->
    </div>
    <!--end::Wrapper-->
</div>
<!--end::Footer Section-->
