@using Abp.Timing
<!-- Footer Start -->
<div id="download" class="container-fluid text-white-50 footer pt-5">
    <div class="container py-5">
        <div class="row g-5">
            <!-- Col 1: Brand + Download -->
            <div class="col-md-6 col-lg-4 wow fadeIn" data-wow-delay="0.1s">
                <a href="/" class="d-inline-flex align-items-center gap-2 mb-4 text-decoration-none">
                    <img src="~/Common/Images/logo.png" alt="@L("Public_AppName")"
                         style="height:44px;width:44px;object-fit:contain;border-radius:12px;background:#fff;padding:3px;">
                    <h4 class="text-white mb-0" style="font-family:'Ubuntu',sans-serif;">
                        DòXổSố <span style="color:#00bb77;">AI</span>
                    </h4>
                </a>
                <p class="mb-4">@L("Public_Footer_Tagline")</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#" class="store-btn">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="white"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                        <div class="text-start">
                            <div style="font-size:10px;line-height:1;opacity:.75;">@L("Public_Download_DownloadOnThe")</div>
                            <div style="font-weight:700;font-size:14px;">@L("Public_Download_AppStore")</div>
                        </div>
                    </a>
                    <a href="#" class="store-btn">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="white"><path d="m12.954 11.616 2.957-2.957L6.36 3.291c-.633-.342-1.226-.39-1.746-.016l8.34 8.341zm3.461 3.462 3.074-1.729c.6-.336.929-.812.929-1.349 0-.537-.329-1.013-.929-1.349l-3.074-1.729-3.093 3.093 3.093 3.063zM4.609 3.277A1.55 1.55 0 0 0 4 4.795V19.205c0 .548.186 1.015.609 1.518l.058.055 8.34-8.34v-.174L4.609 3.277zm7.977 8.332-8.34 8.34c.52.374 1.113.325 1.746-.016l9.551-5.368-2.957-2.956z"/></svg>
                        <div class="text-start">
                            <div style="font-size:10px;line-height:1;opacity:.75;">@L("Public_Download_GetItOn")</div>
                            <div style="font-weight:700;font-size:14px;">@L("Public_Download_GooglePlay")</div>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Col 2: Contact -->
            <div class="col-md-6 col-lg-4 wow fadeIn" data-wow-delay="0.3s">
                <h5 class="text-white mb-4">@L("Public_Footer_Contact")</h5>
                <p><i class="fa fa-map-marker-alt me-3"></i>@L("Public_Footer_Address")</p>
                <p><i class="fa fa-envelope me-3"></i>@L("Public_Footer_Email")</p>
                <div class="d-flex pt-2">
                    <a class="btn btn-outline-light btn-social" href="#" title="Facebook">
                        <i class="fab fa-facebook-f"></i>
                    </a>
                    <a class="btn btn-outline-light btn-social" href="#" title="LinkedIn">
                        <i class="fab fa-linkedin-in"></i>
                    </a>
                    <a class="btn btn-outline-light btn-social" href="#" title="GitHub">
                        <i class="fab fa-github"></i>
                    </a>
                </div>
            </div>

            <!-- Col 3: Quick Links -->
            <div class="col-md-6 col-lg-4 wow fadeIn" data-wow-delay="0.5s">
                <h5 class="text-white mb-4">@L("Public_Footer_Explore")</h5>
                <a class="btn btn-link" href="#about">@L("Public_Footer_AboutLink")</a>
                <a class="btn btn-link" href="#features">@L("Public_Footer_FeaturesLink")</a>
                <a class="btn btn-link" href="#screenshots">@L("Public_Footer_ScreenshotsLink")</a>
                <a class="btn btn-link" href="#team">@L("Public_Footer_TeamLink")</a>
                <a class="btn btn-link" href="mailto:@L("Public_Footer_Email")">@L("Public_Footer_ContactLink")</a>
            </div>
        </div>
    </div>

    <!-- Copyright -->
    <div class="container wow fadeIn" data-wow-delay="0.1s">
        <div class="copyright">
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    &copy; @Clock.Now.Year <a class="border-bottom" href="/">@L("Public_AppName")</a>
                    &nbsp;&middot;&nbsp; DoXoSo AI. @L("Public_Footer_AllRights")
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <div class="footer-menu">
                        <a href="/">@L("Public_Nav_Home")</a>
                        <a href="/Home/Privacy">@L("Public_Footer_Privacy")</a>
                        <a href="#">@L("Public_Footer_Terms")</a>
                        <a href="mailto:@L("Public_Footer_Email")">@L("Public_Footer_Support")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Footer End -->
