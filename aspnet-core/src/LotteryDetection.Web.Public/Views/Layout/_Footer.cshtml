                        <div class="d-flex fw-semibold flex-column">
                            <h4 class="fw-bold mb-6" style="color:#00bb77;">Khám phá</h4>
                            <a href="#features" data-kt-scroll-toggle="true" class="text-white opacity-50 text-hover-primary fs-5 mb-4">Tính năng</a>
                            <a href="#how-it-works" data-kt-scroll-toggle="true" class="text-white opacity-50 text-hover-primary fs-5 mb-4">Cách dùng</a>
                            <a href="#reviews" data-kt-scroll-toggle="true" class="text-white opacity-50 text-hover-primary fs-5 mb-4">Đánh giá</a>
                            <a href="#faq" data-kt-scroll-toggle="true" class="text-white opacity-50 text-hover-primary fs-5 mb-4">FAQ</a>
                            <a href="#download" data-kt-scroll-toggle="true" class="text-white opacity-50 text-hover-primary fs-5">Tải app</a>
                        </div>
                        <!--end::Links group-->
                        <!--begin::Links group-->
                        <div class="d-flex fw-semibold flex-column">
                            <h4 class="fw-bold mb-6" style="color:#00bb77;">Hỗ trợ</h4>
                            <a href="#faq" data-kt-scroll-toggle="true" class="text-white opacity-50 text-hover-primary fs-5 mb-4">Câu hỏi thường gặp</a>
                            <a href="mailto:support@doxoso.ai" class="text-white opacity-50 text-hover-primary fs-5 mb-4">Liên hệ</a>
                            <a href="#" class="text-white opacity-50 text-hover-primary fs-5 mb-4">Chính sách bảo mật</a>
                            <a href="#" class="text-white opacity-50 text-hover-primary fs-5">Điều khoản sử dụng</a>
                        </div>
                        <!--end::Links group-->
                    </div>
                </div>
                <!--end::Col right-->
            </div>
            <!--end::Row-->
        </div>
