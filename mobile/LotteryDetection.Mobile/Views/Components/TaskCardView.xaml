<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LotteryDetection.Mobile.Views.Components.TaskCardView"
             x:Name="CardRoot">
    <Border x:Name="CardBorder"
            Padding="14"
            Margin="0,0,0,10"
            StrokeShape="RoundRectangle 14"
            StrokeThickness="1"
            Stroke="{AppThemeBinding Light={DynamicResource FamilyBorderLight}, Dark={DynamicResource FamilyBorderDark}}"
            BackgroundColor="{AppThemeBinding Light={StaticResource FamilySurfaceLight}, Dark={StaticResource FamilySurfaceDark}}">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnCardTapped" />
        </Border.GestureRecognizers>
        <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
            <!-- Priority accent strip -->
            <BoxView Grid.Column="0"
                     WidthRequest="4"
                     CornerRadius="2"
                     BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                     VerticalOptions="Fill" />

            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto" RowSpacing="0">
                <!-- Title -->
                <Label Grid.Row="0"
                       Text="{Binding Title, Source={x:Reference CardRoot}}"
                       FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                       LineHeight="1.3" CharacterSpacing="-0.005"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />

                <!-- Description -->
                <Label Grid.Row="1"
                       Margin="0,4,0,0"
                       Text="{Binding Description, Source={x:Reference CardRoot}}"
                       FontFamily="Geist" FontSize="12"
                       MaxLines="2"
                       LineBreakMode="TailTruncation"
                       IsVisible="{Binding HasDescription, Source={x:Reference CardRoot}}"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />

                <!-- Bottom row -->
                <Grid Grid.Row="2"
                      Margin="0,8,0,0"
                      ColumnDefinitions="Auto,Auto,*,Auto"
                      VerticalOptions="Center">
                    <Label Grid.Column="0"
                           Text="{Binding Owner, Source={x:Reference CardRoot}}"
                           FontFamily="Geist" FontSize="11.5" FontAttributes="Bold"
                           IsVisible="{Binding HasOwner, Source={x:Reference CardRoot}}"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                    <BoxView Grid.Column="1"
                             WidthRequest="3" HeightRequest="3" CornerRadius="1.5"
                             Margin="5,0"
                             IsVisible="{Binding HasOwner, Source={x:Reference CardRoot}}"
                             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}"
                             VerticalOptions="Center" />
                    <Label Grid.Column="2"
                           Text="{Binding DueDate, Source={x:Reference CardRoot}}"
                           FontFamily="Geist" FontSize="11.5"
                           IsVisible="{Binding HasDueDate, Source={x:Reference CardRoot}}"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                    <Border Grid.Column="3"
                            Padding="8,3"
                            StrokeShape="RoundRectangle 999"
                            StrokeThickness="0"
                            IsVisible="{Binding HasPriority, Source={x:Reference CardRoot}}"
                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}">
                        <Label Text="{Binding Priority, Source={x:Reference CardRoot}}"
                               FontFamily="Geist" FontSize="10.5" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</ContentView>