<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="LotteryDetection.Mobile.Views.Components.BottomBarView">
    <Grid VerticalOptions="End">
        <!-- Floating bar with rounded top corners + soft shadow -->
        <Border StrokeThickness="0"
                Padding="0"
                BackgroundColor="{AppThemeBinding Light={DynamicResource FamilySurfaceLight}, Dark={DynamicResource FamilySurfaceDark}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22,22,0,0" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,-4"
                        Radius="18"
                        Opacity="0.10" />
            </Border.Shadow>

            <Grid Padding="12,8,12,14"
                  HeightRequest="84"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="6">
                <!-- Home -->
                <Grid Grid.Column="0"
                      RowDefinitions="3,*,Auto"
                      RowSpacing="2"
                      AutomationId="TabHome"
                      SemanticProperties.Description="Home tab">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabTapped"
                                               CommandParameter="Home" />
                    </Grid.GestureRecognizers>
                    <BoxView x:Name="HomeIndicator"
                             Grid.Row="0"
                             WidthRequest="20"
                             HeightRequest="3"
                             CornerRadius="2"
                             Color="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                             HorizontalOptions="Center"
                             VerticalOptions="Start"
                             IsVisible="True" />
                    <shapes:Path x:Name="HomeIcon"
                             Grid.Row="1"
                             Data="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM9 22V12h6v10"
                             Stroke="{AppThemeBinding Light={DynamicResource FamilyTextPrimaryLight}, Dark={DynamicResource FamilyTextPrimaryDark}}"
                             StrokeThickness="1.8"
                             StrokeLineCap="Round"
                             StrokeLineJoin="Round"
                             Fill="Transparent"
                             HeightRequest="24" WidthRequest="24"
                             HorizontalOptions="Center" VerticalOptions="Center"
                             Aspect="Uniform" />
                    <Label x:Name="HomeLabel"
                           Grid.Row="2"
                           Text="Home"
                           FontSize="{StaticResource FontSizeCaption}"
                           HorizontalOptions="Center" />
                </Grid>

                <!-- Mic FAB (center) -->
                <Grid Grid.Column="1"
                      AutomationId="TabMic"
                      SemanticProperties.Description="Voice capture button">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabTapped"
                                               CommandParameter="Mic" />
                    </Grid.GestureRecognizers>
                    <!-- Concentric halo + FAB wrapper -->
                    <Grid WidthRequest="78"
                          HeightRequest="78"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          Margin="0,6,0,0">
                        <!-- Outer halo ring -->
                        <Ellipse x:Name="MicHalo"
                                 WidthRequest="78"
                                 HeightRequest="78"
                                 Fill="{AppThemeBinding Light={DynamicResource PrimaryLighter}, Dark={DynamicResource PrimaryLighterDark}}"
                                 Opacity="0.35"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />
                        <!-- Main FAB -->
                        <Border x:Name="MicContainer"
                                WidthRequest="62"
                                HeightRequest="62"
                                StrokeThickness="0"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="31" />
                        </Border.StrokeShape>
                        <Border.Background>
                            <RadialGradientBrush Radius="0.95" Center="0.5,0.35">
                                <GradientStop
                                    Color="{AppThemeBinding Light={StaticResource FamilyMicGradientCenterLight}, Dark={StaticResource FamilyMicGradientCenterDark}}"
                                    Offset="0" />
                                <GradientStop
                                    Color="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                                    Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="#3B82F6"
                                    Offset="0,6"
                                    Radius="14"
                                    Opacity="0.45" />
                        </Border.Shadow>
                            <shapes:Path x:Name="MicPath"
                                         Data="M12 2a3 3 0 0 1 3 3v5a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3Zm6 8h-1a5 5 0 0 1-10 0H6a6 6 0 0 0 12 0Zm-6 9a1 1 0 0 1-1-1v-1h2v1a1 1 0 0 1-1 1Zm-3-3h6v-1H9v1Z"
                                         Fill="White"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         HeightRequest="26"
                                         WidthRequest="26"
                                         Aspect="Uniform" />
                        </Border>
                    </Grid>
                </Grid>

                <!-- Settings -->
                <Grid Grid.Column="2"
                      RowDefinitions="3,*,Auto"
                      RowSpacing="2"
                      AutomationId="TabSettings"
                      SemanticProperties.Description="Settings tab">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabTapped"
                                               CommandParameter="Settings" />
                    </Grid.GestureRecognizers>
                    <BoxView x:Name="SettingsIndicator"
                             Grid.Row="0"
                             WidthRequest="20"
                             HeightRequest="3"
                             CornerRadius="2"
                             Color="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                             HorizontalOptions="Center"
                             VerticalOptions="Start"
                             IsVisible="False" />
                    <shapes:Path x:Name="ProfileIcon"
                                 Grid.Row="1"
                                 Data="M21 4H14M10 4H3M21 12H12M8 12H3M21 20H16M12 20H3M14 2v4M8 10v4M16 18v4"
                                 Stroke="{AppThemeBinding Light={DynamicResource FamilyTextPrimaryLight}, Dark={DynamicResource FamilyTextPrimaryDark}}"
                                 StrokeThickness="1.8"
                                 StrokeLineCap="Round"
                                 StrokeLineJoin="Round"
                                 Fill="Transparent"
                                 HeightRequest="24" WidthRequest="24"
                                 HorizontalOptions="Center" VerticalOptions="Center"
                                 Aspect="Uniform" />
                    <Label x:Name="ProfileLabel"
                           Grid.Row="2"
                           Text="Settings"
                           FontSize="{StaticResource FontSizeCaption}"
                           HorizontalOptions="Center" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentView>
