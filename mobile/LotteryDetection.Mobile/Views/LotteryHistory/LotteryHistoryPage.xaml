<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:viewModel="clr-namespace:LotteryDetection.Mobile.ViewModel"
             xmlns:lotteryModels="clr-namespace:LotteryDetection.Mobile.Models.Lottery"
             xmlns:cv="clr-namespace:LotteryDetection.Mobile.Converters"
             x:Class="LotteryDetection.Mobile.Views.LotteryHistory.LotteryHistoryPage"
             x:DataType="viewModel:LotteryHistoryViewModel"
             x:Name="thisPage"
             Title="Lịch sử dò vé"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFBF6">

    <ContentPage.Resources>
        <ResourceDictionary>
            <cv:InvertBoolConverter x:Key="InvertBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top bar (Header với nút quay lại tinh tế và Rương Kho Báu 3D lắc lư) -->
        <Grid Grid.Row="0"
              Padding="20,42,20,12"
              ColumnDefinitions="Auto,*,Auto">
            <Border Grid.Column="0" WidthRequest="42" HeightRequest="42" StrokeThickness="0" BackgroundColor="#E9EFE4" HorizontalOptions="Start" VerticalOptions="Center">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Radius="6" Offset="0,2" Opacity="0.05" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Border.GestureRecognizers>
                <Label Text="‹" FontSize="26" FontAttributes="Bold" TextColor="#173D2A" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-2,0,0" />
            </Border>
            
            <Label Grid.Column="1"
                   Text="LỊCH SỬ DÒ VÉ"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                   CharacterSpacing="1.2"
                   TextColor="#031649" />
                   
            <Border x:Name="HeaderChest" Grid.Column="2" WidthRequest="42" HeightRequest="42" StrokeThickness="1.5" Stroke="#F5C842" BackgroundColor="White" HorizontalOptions="End" VerticalOptions="Center">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="21" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#031649" Radius="8" Offset="0,3" Opacity="0.1" />
                </Border.Shadow>
                <Image Source="treasure_chest.png" Aspect="AspectFill" Margin="1.5" />
            </Border>
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,8,20,24" Spacing="18">

                <!-- Hero stats card (Dải màu Gradient Tài Lộc cực kỳ sang trọng) -->
                <Border StrokeThickness="0" Padding="20">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#031649" Offset="0.0" />
                            <GradientStop Color="#00bb77" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#031649" Radius="20" Offset="0,10" Opacity="0.22" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">

                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding HeroSubline}"
                                       FontFamily="Geist" FontSize="12.5"
                                       TextColor="#CFE6D5" />
                                <Label Text="{Binding HeroHeadline}"
                                       FontFamily="Geist" FontSize="22" FontAttributes="Bold"
                                       LineHeight="1.15"
                                       TextColor="White" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    WidthRequest="56" HeightRequest="56"
                                    StrokeThickness="1.5"
                                    Stroke="#F5C842"
                                    BackgroundColor="White">
                                <Border.StrokeShape>
                                    <shapes:RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#F5C842" Radius="10" Offset="0,3" Opacity="0.2" />
                                </Border.Shadow>
                                <Image Source="treasure_chest.png" Aspect="AspectFill" Margin="2" />
                            </Border>
                        </Grid>

                        <BoxView Grid.Row="1" HeightRequest="1" Color="#20FFFFFF" />

                        <Grid Grid.Row="2" ColumnDefinitions="*,1,*" ColumnSpacing="14">
                            <VerticalStackLayout Grid.Column="0" Spacing="3">
                                <Label Text="Tổng tiền thưởng"
                                       FontFamily="Geist" FontSize="11"
                                       TextColor="#CFE6D5" />
                                <Label Text="{Binding TotalWinningsDisplay}"
                                       FontFamily="GeistMono" FontSize="18" FontAttributes="Bold"
                                       TextColor="#F5C842" />
                            </VerticalStackLayout>
                            <BoxView Grid.Column="1" WidthRequest="1" Color="#20FFFFFF" />
                            <VerticalStackLayout Grid.Column="2" Spacing="3">
                                <Label Text="Giải lớn nhất"
                                       FontFamily="Geist" FontSize="11"
                                       TextColor="#CFE6D5" />
                                <Label Text="{Binding BiggestWinDisplay}"
                                       FontFamily="GeistMono" FontSize="18" FontAttributes="Bold"
                                       TextColor="White" />
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Skeleton Loader -->
                <Border IsVisible="{Binding ShowSkeleton}"
                        Padding="22"
                        StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Radius="10" Offset="0,4" Opacity="0.04" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">
                        <ActivityIndicator IsRunning="True" Color="#00bb77" HeightRequest="36" WidthRequest="36" />
                        <Label Text="AI đang tải lịch sử dò vé…"
                               FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="#031649" />
                    </VerticalStackLayout>
                </Border>

                <!-- Empty state với Thần Tài lấp lánh cát tường -->
                <Border IsVisible="{Binding ShowEmptyState}"
                        Padding="24"
                        StrokeThickness="1"
                        Stroke="#DAE5D6"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#031649" Radius="14" Offset="0,6" Opacity="0.05" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                        <Border WidthRequest="84" HeightRequest="84"
                                Stroke="#F5C842"
                                StrokeThickness="2"
                                BackgroundColor="White"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="42" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#F5C842" Offset="0,4" Radius="14" Opacity="0.25" />
                            </Border.Shadow>
                            <Image Source="lucky_mascot.png" Aspect="AspectFill" Margin="2" />
                        </Border>
                        
                        <Label Text="Bạn đang không có lịch sử dò vé"
                               FontFamily="Geist" FontSize="17" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="#031649" />
                        <Label Text="Hãy bắt đầu dò vé ngay"
                               FontFamily="Geist" FontSize="13"
                               LineHeight="1.45"
                               HorizontalTextAlignment="Center"
                               TextColor="#66736A" />
                        <Button Text="🔮 Chụp Vé Số Ngay"
                                Command="{Binding StartCaptureCommand}"
                                HeightRequest="52"
                                CornerRadius="18"
                                FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                BackgroundColor="#F5C842"
                                TextColor="#031649"
                                Margin="0,6,0,0">
                            <Button.Shadow>
                                <Shadow Brush="#F5C842" Radius="8" Offset="0,3" Opacity="0.2" />
                            </Button.Shadow>
                        </Button>
                    </VerticalStackLayout>
                </Border>

                <!-- Winners section (Danh sách vé trúng thưởng cực kỳ nổi bật) -->
                <VerticalStackLayout Spacing="12" IsVisible="{Binding HasWinners}">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Trúng giải gần đây"
                                   FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                                   TextColor="#031649" />
                            <Label Text="Mang vé thật đối chiếu lĩnh thưởng trong 30 ngày nhé!"
                                   FontFamily="Geist" FontSize="11"
                                   TextColor="#66736A" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                StrokeThickness="0"
                                Padding="10,4"
                                BackgroundColor="#F5C842"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="{Binding WinCount, StringFormat='{0} vé'}"
                                   FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                   TextColor="#031649" />
                        </Border>
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Winners}"
                                         Spacing="12"
                                         HorizontalOptions="Fill">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="lotteryModels:LotteryHistoryEntry">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItem Text="Xóa"
                                                       BackgroundColor="#DC2626"
                                                       BindingContext="{Binding .}"
                                                       Invoked="OnDeleteSwipeItemInvoked" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <!-- Card trúng giải mạ vàng kép tinh xảo -->
                                    <Border StrokeThickness="1.5"
                                            Stroke="#F5C842"
                                            BackgroundColor="#0B2316"
                                            Padding="16"
                                            HorizontalOptions="Fill">
                                        <Border.StrokeShape>
                                            <shapes:RoundRectangle CornerRadius="20" />
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="#F5C842" Offset="0,6" Radius="14" Opacity="0.12" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTicketCardTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">

                                            <!-- Header row: trophy + status chip -->
                                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <Border Grid.Column="0"
                                                        WidthRequest="44" HeightRequest="44"
                                                        StrokeThickness="0"
                                                        BackgroundColor="Transparent"
                                                        VerticalOptions="Center">
                                                    <Border.StrokeShape>
                                                        <shapes:RoundRectangle CornerRadius="14" />
                                                    </Border.StrokeShape>
                                                    <Image Source="{Binding ProvinceLogoImage}" Aspect="AspectFill" />
                                                </Border>
                                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                    <Label Text="TRÚNG GIẢI"
                                                           FontFamily="Geist" FontSize="10.5" FontAttributes="Bold"
                                                           TextColor="#F5C842" />
                                                    <Label Text="{Binding StatusLabel}"
                                                           FontFamily="Geist" FontSize="14.5" FontAttributes="Bold"
                                                           TextColor="White" />
                                                </VerticalStackLayout>
                                                <Border Grid.Column="2"
                                                        StrokeThickness="0"
                                                        Padding="9,4"
                                                        BackgroundColor="#163A1D"
                                                        VerticalOptions="Center">
                                                    <Border.StrokeShape>
                                                        <shapes:RoundRectangle CornerRadius="9" />
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding CapturedDisplay}"
                                                           FontFamily="Geist" FontSize="10" FontAttributes="Bold"
                                                           TextColor="#A9D7B6" />
                                                </Border>
                                            </Grid>

                                            <!-- Prize amount highlight -->
                                            <Border Grid.Row="1"
                                                    StrokeThickness="0"
                                                    Padding="14,12"
                                                    BackgroundColor="#163A1D">
                                                <Border.StrokeShape>
                                                    <shapes:RoundRectangle CornerRadius="14" />
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <Label Text="Tiền thưởng"
                                                           FontFamily="Geist" FontSize="11.5"
                                                           VerticalOptions="Center"
                                                           TextColor="#CFE6D5" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding PrizeAmountDisplay}"
                                                           FontFamily="GeistMono" FontSize="20" FontAttributes="Bold"
                                                           VerticalOptions="Center"
                                                           TextColor="#F5C842" />
                                                </Grid>
                                            </Border>

                                            <!-- Ticket info row -->
                                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="Số vé"
                                                           FontFamily="Geist" FontSize="10"
                                                           TextColor="#CFE6D5" />
                                                    <Label Text="{Binding TicketNumber}"
                                                           FontFamily="GeistMono" FontSize="16" FontAttributes="Bold"
                                                           TextColor="White" />
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="End">
                                                    <Label Text="Đài quay"
                                                           FontFamily="Geist" FontSize="10"
                                                           HorizontalTextAlignment="End"
                                                           TextColor="#CFE6D5" />
                                                    <Label Text="{Binding Province}"
                                                           FontFamily="Geist" FontSize="13.5" FontAttributes="Bold"
                                                           HorizontalTextAlignment="End"
                                                           TextColor="White" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- All entries section (Danh sách tất cả vé đã dò) -->
                <VerticalStackLayout Spacing="12" IsVisible="{Binding HasEntries}">
                    <Label Text="Tất cả vé đã dò"
                           FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                           TextColor="#031649" />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Entries}"
                                         Spacing="10"
                                         HorizontalOptions="Fill">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="lotteryModels:LotteryHistoryEntry">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItem Text="Xóa"
                                                       BackgroundColor="#DC2626"
                                                       BindingContext="{Binding .}"
                                                       Invoked="OnDeleteSwipeItemInvoked" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <!-- Thẻ vé bo góc sâu, đổ bóng mịn hiện đại -->
                                    <Border StrokeThickness="1"
                                            Stroke="{Binding CardStrokeColor}"
                                            BackgroundColor="White"
                                            Padding="14"
                                            HorizontalOptions="Fill">
                                        <Border.StrokeShape>
                                            <shapes:RoundRectangle CornerRadius="18" />
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="#031649" Radius="8" Offset="0,3" Opacity="0.03" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTicketCardTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">

                                            <Border Grid.Column="0"
                                                    WidthRequest="48" HeightRequest="48"
                                                    StrokeThickness="0"
                                                    BackgroundColor="Transparent"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <shapes:RoundRectangle CornerRadius="14" />
                                                </Border.StrokeShape>
                                                <Image Source="{Binding ProvinceLogoImage}" Aspect="AspectFill" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                                <Label Text="{Binding TicketNumber}"
                                                       FontFamily="GeistMono" FontSize="16.5" FontAttributes="Bold"
                                                       TextColor="#031649" />
                                                <Label Text="{Binding Province}"
                                                       FontFamily="Geist" FontSize="12.5"
                                                       TextColor="#38443B" />
                                                <Label Text="{Binding CapturedDisplay}"
                                                       FontFamily="Geist" FontSize="11"
                                                       TextColor="#8A958D" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="2" Spacing="6"
                                                                  VerticalOptions="Center"
                                                                  HorizontalOptions="End">
                                                <Border StrokeThickness="0"
                                                        Padding="10,4"
                                                        BackgroundColor="{Binding StatusBackground}">
                                                    <Border.StrokeShape>
                                                        <shapes:RoundRectangle CornerRadius="10" />
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding StatusLabel}"
                                                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                                           TextColor="{Binding StatusTextColor}" />
                                                </Border>
                                                <Label Text="{Binding PrizeAmountDisplay}"
                                                       FontFamily="GeistMono"
                                                       FontSize="{Binding PrizeAmountFontSize}"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="End"
                                                       TextColor="{Binding PrizeAmountColor}" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- Paging controls -->
                    <Button Text="Xem thêm vé cũ"
                            Command="{Binding LoadMoreCommand}"
                            IsVisible="{Binding CanLoadMore}"
                            HeightRequest="46"
                            CornerRadius="14"
                            FontFamily="Geist" FontSize="13.5" FontAttributes="Bold"
                            BackgroundColor="#E9EFE4"
                            TextColor="#173D2A"
                            Margin="0,12,0,0">
                        <Button.Shadow>
                            <Shadow Brush="#000000" Radius="6" Offset="0,2" Opacity="0.05" />
                        </Button.Shadow>
                    </Button>
                    <ActivityIndicator IsRunning="{Binding IsLoadingMore}"
                                       IsVisible="{Binding IsLoadingMore}"
                                       Color="#00bb77"
                                       HeightRequest="30" WidthRequest="30"
                                       HorizontalOptions="Center"
                                       Margin="0,12,0,0" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom CTA Button (Luôn bám dính dưới cùng và chạy hoạt ảnh co giãn nhịp thở mời gọi) -->
        <Grid Grid.Row="2"
              Padding="20,12,20,30"
              IsVisible="{Binding ShowEmptyState, Converter={StaticResource InvertBool}}">
            <Button x:Name="ContinueButton"
                    Text="📸 TIẾP TỤC DÒ VÉ MỚI"
                    Command="{Binding StartCaptureCommand}"
                    HeightRequest="58"
                    CornerRadius="19"
                    FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                    BackgroundColor="#F5C842"
                    TextColor="#031649">
                <Button.Shadow>
                    <Shadow Brush="#F5C842" Radius="12" Offset="0,6" Opacity="0.25" />
                </Button.Shadow>
            </Button>
        </Grid>

        <!-- HIGH-FIDELITY PREMIUM DETAIL POPUP MODAL OVERLAY -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              IsVisible="{Binding IsTicketDetailsOpen}"
              BackgroundColor="#CC031649"
              Padding="24,40">
            <Grid.GestureRecognizers>
                <!-- Tap outside the card to close modal -->
                <TapGestureRecognizer Command="{Binding CloseTicketDetailsCommand}" />
            </Grid.GestureRecognizers>

            <Border VerticalOptions="Center" HorizontalOptions="Fill"
                    StrokeThickness="1.5"
                    Stroke="#F5C842"
                    BackgroundColor="White"
                    Padding="24"
                    MaximumWidthRequest="380">
                <Border.StrokeShape>
                    <shapes:RoundRectangle CornerRadius="28" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Radius="30" Offset="0,15" Opacity="0.4" />
                </Border.Shadow>
                <!-- Catch taps inside the card so it doesn't close the modal -->
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>

                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="18">

                    <!-- Title / Close Row -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="CHI TIẾT VÉ SỐ"
                                   FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                                   TextColor="#F5C842" CharacterSpacing="1.5" />
                            <Label Text="Thông tin chi tiết"
                                   FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                                   TextColor="#031649" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" WidthRequest="36" HeightRequest="36" StrokeThickness="0" BackgroundColor="#F2F4F0" HorizontalOptions="End" VerticalOptions="Start">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CloseTicketDetailsCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="✕" FontSize="14" FontAttributes="Bold" TextColor="#173D2A" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <!-- Ticket Large Display -->
                    <Border Grid.Row="1"
                            StrokeThickness="1"
                            Stroke="#E9EFE4"
                            Padding="20,16"
                            BackgroundColor="#FAFBF6">
                        <Border.StrokeShape>
                            <shapes:RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="SỐ TRÊN VÉ"
                                   FontFamily="Geist" FontSize="11.5" FontAttributes="Bold"
                                   TextColor="#66736A" HorizontalTextAlignment="Center" CharacterSpacing="1" />
                            <Label Text="{Binding SelectedTicket.TicketNumber}"
                                   FontFamily="GeistMono" FontSize="36" FontAttributes="Bold"
                                   TextColor="#142116" HorizontalTextAlignment="Center" CharacterSpacing="2" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Details Fields -->
                    <VerticalStackLayout Grid.Row="2" Spacing="12">
                        <!-- Đài quay -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Đài quay thưởng" FontFamily="Geist" FontSize="13.5" TextColor="#66736A" />
                            <Label Grid.Column="1" Text="{Binding SelectedTicket.Province}" FontFamily="Geist" FontSize="14.5" FontAttributes="Bold" TextColor="#031649" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E9EFE4" />

                        <!-- Ngày mở thưởng -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Ngày mở thưởng" FontFamily="Geist" FontSize="13.5" TextColor="#66736A" />
                            <Label Grid.Column="1" Text="{Binding SelectedTicket.DrawDateDisplay}" FontFamily="Geist" FontSize="14.5" FontAttributes="Bold" TextColor="#031649" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E9EFE4" />

                        <!-- Quét lúc -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Thời điểm chụp" FontFamily="Geist" FontSize="13.5" TextColor="#66736A" />
                            <Label Grid.Column="1" Text="{Binding SelectedTicket.CapturedDisplay}" FontFamily="Geist" FontSize="14.5" FontAttributes="Bold" TextColor="#031649" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E9EFE4" />

                        <!-- Trạng thái -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Kết quả" FontFamily="Geist" FontSize="13.5" TextColor="#66736A" VerticalOptions="Center" />
                            <Border Grid.Column="1" StrokeThickness="0" Padding="10,4" BackgroundColor="{Binding SelectedTicket.StatusBackground}">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                <Label Text="{Binding SelectedTicket.StatusLabel}" FontFamily="Geist" FontSize="11" FontAttributes="Bold" TextColor="{Binding SelectedTicket.StatusTextColor}" />
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Winning Detail Block -->
                    <Border Grid.Row="3"
                            IsVisible="{Binding SelectedTicket.IsWinner}"
                            StrokeThickness="0"
                            Padding="16,14"
                            BackgroundColor="#0B2316">
                        <Border.StrokeShape>
                            <shapes:RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                <Label Text="Mức trúng thưởng" FontFamily="Geist" FontSize="12.5" TextColor="#CFE6D5" />
                                <Label Grid.Column="1" Text="{Binding SelectedTicket.MatchedPrize}" FontFamily="Geist" FontSize="13" FontAttributes="Bold" TextColor="#F5C842" />
                            </Grid>
                            <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                                <Label Text="Tiền giải thưởng" FontFamily="Geist" FontSize="12.5" TextColor="#CFE6D5" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding SelectedTicket.PrizeAmountDisplay}" FontFamily="GeistMono" FontSize="18.5" FontAttributes="Bold" TextColor="#F5C842" VerticalOptions="Center" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Close / Delete Action Buttons -->
                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Button Grid.Column="0"
                                Text="Đóng"
                                Command="{Binding CloseTicketDetailsCommand}"
                                HeightRequest="50"
                                CornerRadius="16"
                                FontFamily="Geist" FontSize="14.5" FontAttributes="Bold"
                                BackgroundColor="#031649"
                                TextColor="White">
                            <Button.Shadow>
                                <Shadow Brush="#031649" Radius="8" Offset="0,3" Opacity="0.15" />
                            </Button.Shadow>
                        </Button>
                        <Button Grid.Column="1"
                                Text="Xóa"
                                Command="{Binding DeleteEntryCommand}"
                                CommandParameter="{Binding SelectedTicket}"
                                Clicked="OnDeleteButtonClickedFromModal"
                                HeightRequest="50"
                                WidthRequest="80"
                                CornerRadius="16"
                                FontFamily="Geist" FontSize="14.5" FontAttributes="Bold"
                                BackgroundColor="#FEE2E2"
                                TextColor="#DC2626">
                        </Button>
                    </Grid>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
