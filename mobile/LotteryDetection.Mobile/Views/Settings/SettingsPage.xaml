<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:viewModel="clr-namespace:LotteryDetection.Mobile.ViewModel"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             ios:Page.UseSafeArea="True"
             x:Class="LotteryDetection.Mobile.Views.Settings.SettingsPage"
             x:DataType="viewModel:SettingsViewModel"
             Title="Cài đặt"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFBF6">

    <Grid RowDefinitions="Auto,*">

        <!-- Top bar -->
        <Grid Grid.Row="0"
              Padding="20,8,20,12"
              ColumnDefinitions="Auto,*,Auto">
            <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" StrokeThickness="0" BackgroundColor="#E9EFE4" HorizontalOptions="Start" VerticalOptions="Center">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Radius="6" Offset="0,2" Opacity="0.05" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Border.GestureRecognizers>
                <Label Text="‹" FontSize="26" FontAttributes="Bold" TextColor="#031649" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-2,0,0" />
            </Border>
            <Label Grid.Column="1"
                   Text="CÀI ĐẶT"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                   CharacterSpacing="1.2"
                   TextColor="#031649" />
            <BoxView Grid.Column="2" WidthRequest="44" HeightRequest="44" BackgroundColor="Transparent" />
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,8,20,32" Spacing="16">

                <!-- Hero profile card -->
                <Border StrokeThickness="0" Padding="22">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#031649" Offset="0.0" />
                            <GradientStop Color="#00bb77" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#031649" Radius="20" Offset="0,10" Opacity="0.22" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <!-- Tappable avatar — opens photo picker -->
                        <Grid Grid.Column="0" WidthRequest="72" HeightRequest="72" VerticalOptions="Center">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding UpdateAvatarCommand}" />
                            </Grid.GestureRecognizers>
                            <Border WidthRequest="72" HeightRequest="72"
                                    StrokeThickness="1.5" Stroke="#F5C842" BackgroundColor="White">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="36" /></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#F5C842" Radius="10" Offset="0,3" Opacity="0.2" />
                                </Border.Shadow>
                                <Grid>
                                    <!-- Default person icon -->
                                    <shapes:Path IsVisible="{Binding HasNoCustomAvatar}"
                                                 Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                                                 Fill="#031649"
                                                 WidthRequest="38" HeightRequest="38"
                                                 HorizontalOptions="Center" VerticalOptions="Center"
                                                 Aspect="Uniform" />
                                    <!-- Custom uploaded photo -->
                                    <Image IsVisible="{Binding HasCustomAvatar}"
                                           Source="{Binding AvatarSource}"
                                           Aspect="AspectFill"
                                           WidthRequest="68" HeightRequest="68"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Grid>
                            </Border>
                            <!-- Camera badge — affordance to indicate tappability -->
                            <Border WidthRequest="22" HeightRequest="22"
                                    StrokeThickness="2" Stroke="#031649" BackgroundColor="#F5C842"
                                    HorizontalOptions="End" VerticalOptions="End">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="11" /></Border.StrokeShape>
                                <Label Text="📷" FontSize="11" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                        </Grid>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding UserDisplayName}"
                                   FontFamily="Geist" FontSize="20" FontAttributes="Bold"
                                   LineHeight="1.1"
                                   TextColor="White"
                                   MaxLines="1" LineBreakMode="TailTruncation" />
                            <Label Text="Chạm avatar để đổi ảnh"
                                   FontFamily="Geist" FontSize="10.5"
                                   FontAttributes="Italic"
                                   TextColor="#F5C842"
                                   Margin="0,4,0,0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- About app card -->
                <Border StrokeThickness="1" Stroke="#E2EDE0" BackgroundColor="White" Padding="18">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#031649" Radius="12" Offset="0,6" Opacity="0.06" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeThickness="0" BackgroundColor="#E7F5DE" VerticalOptions="Center">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                <Label Text="ℹ" FontSize="20" FontAttributes="Bold" TextColor="#031649" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Về ứng dụng"
                                       FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                       CharacterSpacing="0.6"
                                       TextColor="#66736A" />
                                <Label Text="DòVéSố AI"
                                       FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                                       TextColor="#031649" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="{Binding AppDescription}"
                               FontFamily="Geist" FontSize="13" LineHeight="1.45"
                               TextColor="#52705A" />

                        <BoxView HeightRequest="1" Color="#EAEFE6" />

                        <!-- Info rows -->
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12">
                            <Label Grid.Row="0" Grid.Column="0" Text="Phiên bản" FontFamily="Geist" FontSize="12.5" TextColor="#66736A" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding AppVersion}" FontFamily="GeistMono" FontSize="12.5" FontAttributes="Bold" TextColor="#031649" />

                            <Label Grid.Row="1" Grid.Column="0" Text="Thiết bị" FontFamily="Geist" FontSize="12.5" TextColor="#66736A" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding DeviceDescription}" FontFamily="Geist" FontSize="12.5" TextColor="#031649" MaxLines="1" LineBreakMode="TailTruncation" MaximumWidthRequest="220" />

                            <Label Grid.Row="2" Grid.Column="0" Text="Nhà phát triển" FontFamily="Geist" FontSize="12.5" TextColor="#66736A" />
                            <Label Grid.Row="2" Grid.Column="1" Text="FamilyAI Tech" FontFamily="Geist" FontSize="12.5" FontAttributes="Bold" TextColor="#031649" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Sign out button -->
                <Border StrokeThickness="0"
                        Padding="6"
                        BackgroundColor="White"
                        Margin="0,8,0,0">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#DC2626" Offset="0,10" Radius="20" Opacity="0.10" />
                    </Border.Shadow>
                    <Button Text="Đăng xuất"
                            Command="{Binding SignOutCommand}"
                            HeightRequest="52"
                            CornerRadius="18"
                            FontFamily="Geist"
                            FontSize="15"
                            FontAttributes="Bold"
                            BackgroundColor="#DC2626"
                            TextColor="White" />
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
