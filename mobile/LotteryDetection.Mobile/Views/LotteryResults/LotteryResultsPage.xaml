<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:viewModel="clr-namespace:LotteryDetection.Mobile.ViewModel"
             xmlns:lotteryModels="clr-namespace:LotteryDetection.Mobile.Models.Lottery"
             x:Class="LotteryDetection.Mobile.Views.LotteryResults.LotteryResultsPage"
             x:DataType="viewModel:LotteryResultsViewModel"
             Title="Kết quả hôm nay"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F8F2">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top bar -->
        <Grid Grid.Row="0"
              Padding="20,42,20,12"
              ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="28"
                    WidthRequest="42" HeightRequest="42"
                    Padding="0" CornerRadius="14"
                    BackgroundColor="#E9EFE4"
                    TextColor="#173D2A"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1"
                   Text="Kết quả hôm nay"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                   TextColor="#142116" />
            <BoxView Grid.Column="2" WidthRequest="42" HeightRequest="42" BackgroundColor="Transparent" />
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,4,20,28" Spacing="16">

                <!-- Hero -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Xổ số ba miền"
                               FontFamily="Geist" FontSize="13"
                               TextColor="#52705A" />
                        <Label Text="{Binding HeroDateLabel}"
                               FontFamily="Geist" FontSize="26" FontAttributes="Bold"
                               LineHeight="1.1"
                               TextColor="#142116" />
                        <Label Text="{Binding UpdatedAtLabel}"
                               FontFamily="Geist" FontSize="12"
                               TextColor="#66736A" />
                    </VerticalStackLayout>
                    <Border x:Name="LiveButtonBorder"
                            Grid.Column="1"
                            StrokeThickness="1.5"
                            Stroke="{Binding LiveButtonStrokeColor}"
                            Padding="14,10"
                            VerticalOptions="Center"
                            HorizontalOptions="End">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{Binding LiveButtonStartColor}" Offset="0.0" />
                                <GradientStop Color="{Binding LiveButtonEndColor}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.StrokeShape>
                            <shapes:RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="{Binding LiveButtonShadowColor}" Radius="8" Offset="0,4" Opacity="0.3" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLiveResultsCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="6" VerticalOptions="Center">
                            <!-- Pulse Dot -->
                            <Ellipse Grid.Column="0"
                                     WidthRequest="8" HeightRequest="8"
                                     Fill="{Binding LiveButtonPulseColor}"
                                     VerticalOptions="Center">
                                <Ellipse.Shadow>
                                    <Shadow Brush="{Binding LiveButtonPulseColor}" Radius="6" Offset="0,0" Opacity="0.8" />
                                </Ellipse.Shadow>
                            </Ellipse>
                            
                            <!-- Label -->
                            <Label Grid.Column="1"
                                   Text="{Binding LiveButtonLabel}"
                                   FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center"
                                   CharacterSpacing="0.5" />
                                   
                            <!-- Chevron -->
                            <Label Grid.Column="2"
                                   Text="›"
                                   FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center"
                                   Margin="0,-2,0,0" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Date Filter Selector -->
                <VerticalStackLayout Spacing="8" Margin="0,4,0,4">
                    <Label Text="Chọn ngày xem kết quả:"
                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                           TextColor="#66736A"
                           Margin="2,0" />
                    <Grid HeightRequest="48" Margin="0,2,0,0">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDatePickerTapped" />
                        </Grid.GestureRecognizers>
                        
                        <!-- Custom Styled Clickable Card -->
                        <Border StrokeThickness="1"
                                Stroke="#D1DCD2"
                                BackgroundColor="White"
                                Padding="14,0"
                                InputTransparent="True">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                                <Label Text="📅" FontSize="18" VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding SelectedDate, StringFormat='{0:dd \'tháng\' MM, yyyy}'}"
                                       FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                       TextColor="#142116"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="▼" FontFamily="Geist" FontSize="11" TextColor="#52705A" VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!-- Invisible Native DatePicker overlay -->
                        <DatePicker x:Name="ActualDatePicker"
                                    Date="{Binding SelectedDate, Mode=TwoWay}"
                                    Format="dd/MM/yyyy"
                                    Opacity="0"
                                    InputTransparent="True"
                                    VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" />
                    </Grid>
                </VerticalStackLayout>

                <!-- Region Selector Filters -->
                <VerticalStackLayout Spacing="8" Margin="0,4,0,4">
                    <Label Text="Bộ lọc miền:"
                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                           TextColor="#66736A"
                           Margin="2,0" />
                    <HorizontalStackLayout Spacing="8">
                        <!-- Miền Bắc Chip -->
                        <Border StrokeThickness="1"
                                Stroke="{Binding BacChipStroke}"
                                BackgroundColor="{Binding BacChipBg}"
                                Padding="12,5"
                                HeightRequest="32">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleBacCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Miền Bắc"
                                   FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                   TextColor="{Binding BacChipText}"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Miền Trung Chip -->
                        <Border StrokeThickness="1"
                                Stroke="{Binding TrungChipStroke}"
                                BackgroundColor="{Binding TrungChipBg}"
                                Padding="12,5"
                                HeightRequest="32">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleTrungCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Miền Trung"
                                   FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                   TextColor="{Binding TrungChipText}"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Miền Nam Chip -->
                        <Border StrokeThickness="1"
                                Stroke="{Binding NamChipStroke}"
                                BackgroundColor="{Binding NamChipBg}"
                                Padding="12,5"
                                HeightRequest="32">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleNamCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Miền Nam"
                                   FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                   TextColor="{Binding NamChipText}"
                                   VerticalOptions="Center" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Skeleton -->
                <Border IsVisible="{Binding ShowSkeleton}"
                        Padding="20"
                        StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <ActivityIndicator IsRunning="True" Color="#173D2A" />
                        <Label Text="Đang tải kết quả mới nhất…"
                               FontFamily="Geist" FontSize="13"
                               HorizontalTextAlignment="Center"
                               TextColor="#66736A" />
                    </VerticalStackLayout>
                </Border>

                <!-- Empty State -->
                <Border IsVisible="{Binding ShowEmptyState}"
                        StrokeThickness="1"
                        Stroke="#E2E8F0"
                        Padding="24,36"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label Text="✨"
                               FontSize="36"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Không có miền nào được chọn"
                               FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="#1E293B" />
                        <Label Text="Vui lòng bật các miền ở bộ lọc trên để xem kết quả xổ số tương ứng."
                               FontFamily="Geist" FontSize="12.5"
                               LineHeight="1.3"
                               HorizontalTextAlignment="Center"
                               TextColor="#64748B" />
                    </VerticalStackLayout>
                </Border>

                <!-- Region cards -->
                <CollectionView ItemsSource="{Binding Regions}"
                                SelectionMode="None"
                                ItemSizingStrategy="MeasureAllItems">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="lotteryModels:LotteryRegionDraw">
                            <Border StrokeThickness="1"
                                    Stroke="{Binding CardStrokeColor}"
                                    BackgroundColor="{Binding CardTintColor}"
                                    Padding="0">
                                <Border.StrokeShape>
                                    <shapes:RoundRectangle CornerRadius="22" />
                                </Border.StrokeShape>

                                <Grid RowDefinitions="6,Auto">

                                    <!-- Top color stripe -->
                                    <BoxView Grid.Row="0"
                                             Color="{Binding AccentColor}" />

                                    <VerticalStackLayout Grid.Row="1" Padding="18" Spacing="14">

                                        <!-- Header row -->
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Border Grid.Column="0"
                                                    WidthRequest="36" HeightRequest="36"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{Binding AccentColor}"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <shapes:RoundRectangle CornerRadius="12" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding RegionIcon}"
                                                       FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       TextColor="{Binding AccentTextColor}" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding ProvinceLabel}"
                                                       FontFamily="Geist" FontSize="17" FontAttributes="Bold"
                                                       TextColor="#142116" />
                                                <Label Text="{Binding RegionLabel}"
                                                       FontFamily="Geist" FontSize="11"
                                                       TextColor="#66736A" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="2"
                                                    StrokeThickness="0"
                                                    Padding="9,5"
                                                    BackgroundColor="White"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <shapes:RoundRectangle CornerRadius="9" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding DrawDateDisplay}"
                                                       FontFamily="GeistMono" FontSize="11" FontAttributes="Bold"
                                                       TextColor="#142116" />
                                            </Border>
                                        </Grid>

                                        <!-- Đặc biệt highlight -->
                                        <Border StrokeThickness="0"
                                                Padding="16"
                                                BackgroundColor="{Binding AccentColor}">
                                            <Border.StrokeShape>
                                                <shapes:RoundRectangle CornerRadius="16" />
                                            </Border.StrokeShape>
                                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                                <Label Text="GIẢI ĐẶC BIỆT"
                                                       FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center"
                                                       TextColor="{Binding AccentTextColor}"
                                                       Opacity="0.7" />
                                                <Label Text="{Binding SpecialPrize.Numbers}"
                                                       FontFamily="GeistMono" FontSize="34" FontAttributes="Bold"
                                                       LineHeight="1.0"
                                                       HorizontalTextAlignment="Center"
                                                       TextColor="{Binding AccentTextColor}" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <!-- Secondary prizes -->
                                        <Border StrokeThickness="0"
                                                Padding="14"
                                                BackgroundColor="White">
                                            <Border.StrokeShape>
                                                <shapes:RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <VerticalStackLayout Spacing="10"
                                                                 BindableLayout.ItemsSource="{Binding OtherPrizes}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="lotteryModels:LotteryPrizeTier">
                                                        <Grid ColumnDefinitions="78,*" ColumnSpacing="12">
                                                            <Label Grid.Column="0"
                                                                   Text="{Binding TierLabel}"
                                                                   FontFamily="Geist" FontSize="12"
                                                                   VerticalOptions="Center"
                                                                   TextColor="#66736A" />
                                                            <Label Grid.Column="1"
                                                                   Text="{Binding Numbers}"
                                                                   FontFamily="GeistMono" FontSize="13.5"
                                                                   FontAttributes="Bold"
                                                                   VerticalOptions="Center"
                                                                   TextColor="#142116" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </Border>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="* Kết quả mang tính tham khảo. Vui lòng đối chiếu với đài phát hành chính thức."
                       FontFamily="Geist" FontSize="11"
                       LineHeight="1.4"
                       TextColor="#8A958D"
                       Margin="4,2,4,80" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Sticky CTA -->
        <Border Grid.Row="2"
                Margin="20,0,20,28"
                Padding="6"
                StrokeThickness="0"
                BackgroundColor="White">
            <Border.StrokeShape>
                <shapes:RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#142116" Offset="0,10" Radius="20" Opacity="0.10" />
            </Border.Shadow>
            <Button Text="Kiểm tra vé của bạn"
                    Command="{Binding OpenCaptureCommand}"
                    HeightRequest="52"
                    CornerRadius="18"
                    FontFamily="Geist"
                    FontSize="15"
                    FontAttributes="Bold"
                    BackgroundColor="#173D2A"
                    TextColor="#F5C842" />
        </Border>
    </Grid>
</ContentPage>
