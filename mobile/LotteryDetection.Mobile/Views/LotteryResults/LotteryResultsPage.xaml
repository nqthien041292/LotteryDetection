<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:viewModel="clr-namespace:LotteryDetection.Mobile.ViewModel"
             xmlns:lotteryModels="clr-namespace:LotteryDetection.Mobile.Models.Lottery"
             xmlns:components="clr-namespace:LotteryDetection.Mobile.Views.Components"
             xmlns:col="clr-namespace:System.Collections;assembly=netstandard"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             ios:Page.UseSafeArea="True"
             x:Class="LotteryDetection.Mobile.Views.LotteryResults.LotteryResultsPage"
             x:DataType="viewModel:LotteryResultsViewModel"
             Title="Kết quả hôm nay"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFBF6">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BooleanToColorConverter x:Key="BooleanToColorConverter" xmlns:converters="clr-namespace:LotteryDetection.Mobile.Converters" />
            <converters:EqualityToColorConverter x:Key="EqualityToColorConverter" xmlns:converters="clr-namespace:LotteryDetection.Mobile.Converters" />
            <converters:BooleanToTextConverter x:Key="BooleanToTextConverter" xmlns:converters="clr-namespace:LotteryDetection.Mobile.Converters" />
            <converters:InvertBooleanConverter x:Key="InvertBooleanConverter" xmlns:converters="clr-namespace:LotteryDetection.Mobile.Converters" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top bar -->
        <Grid Grid.Row="0"
              Padding="20,8,20,12"
              ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="28"
                    WidthRequest="44" HeightRequest="44"
                    Padding="0" CornerRadius="14"
                    BackgroundColor="#E9EFE4"
                    TextColor="#031649"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1"
                   Text="Kết quả hôm nay"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                   TextColor="#031649" />
            <BoxView Grid.Column="2" WidthRequest="44" HeightRequest="44" BackgroundColor="Transparent" />
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1" ios:ScrollView.ShouldDelayContentTouches="False">
            <VerticalStackLayout Padding="20,4,20,28" Spacing="12">

                <!-- Removed Segmented Control and Sub-Tabs -->

                <!-- Hero -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Xổ số ba miền"
                               FontFamily="Geist" FontSize="13"
                               TextColor="#52705A" />
                        <Label Text="{Binding HeroDateLabel}"
                               FontFamily="Geist" FontSize="26" FontAttributes="Bold"
                               LineHeight="1.1"
                               TextColor="#142116" />
                        <Label Text="{Binding UpdatedAtLabel}"
                               FontFamily="Geist" FontSize="12"
                               TextColor="#66736A" />
                    </VerticalStackLayout>
                    <Border x:Name="LiveButtonBorder"
                            Grid.Column="1"
                            StrokeThickness="1.5"
                            Stroke="{Binding LiveButtonStrokeColor}"
                            Padding="14,10"
                            VerticalOptions="Center"
                            HorizontalOptions="End">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{Binding LiveButtonStartColor}" Offset="0.0" />
                                <GradientStop Color="{Binding LiveButtonEndColor}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.StrokeShape>
                            <shapes:RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="{Binding LiveButtonShadowColor}" Radius="8" Offset="0,4" Opacity="0.3" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLiveResultsCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="6" VerticalOptions="Center">
                            <!-- Pulse Dot -->
                            <Ellipse Grid.Column="0"
                                     WidthRequest="8" HeightRequest="8"
                                     Fill="{Binding LiveButtonPulseColor}"
                                     VerticalOptions="Center">
                                <Ellipse.Shadow>
                                    <Shadow Brush="{Binding LiveButtonPulseColor}" Radius="6" Offset="0,0" Opacity="0.8" />
                                </Ellipse.Shadow>
                            </Ellipse>
                            
                            <!-- Label -->
                            <Label Grid.Column="1"
                                   Text="{Binding LiveButtonLabel}"
                                   FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center"
                                   CharacterSpacing="0.5" />
                                   
                            <!-- Chevron -->
                            <Label Grid.Column="2"
                                   Text="›"
                                   FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center"
                                   Margin="0,-2,0,0" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Date Selection Area (Isolated Trigger Strategy) -->
                <Grid>
                    <VerticalStackLayout Spacing="6" InputTransparent="True">
                        <Label Text="Chọn ngày xem kết quả"
                               FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                               TextColor="#66736A"
                               Margin="2,0" />
                        <Border StrokeThickness="1"
                                Stroke="#D1DCD2"
                                BackgroundColor="White"
                                Padding="14,0"
                                HeightRequest="50">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                                <Label Text="📅" FontSize="18" VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding SelectedDate, StringFormat='{0:dd \'tháng\' MM, yyyy}'}"
                                       FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                       TextColor="#142116"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="▼" FontFamily="Geist" FontSize="11" TextColor="#52705A" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- The Actual Hit Target (Standard Button for max reliability) -->
                    <Button BackgroundColor="Transparent"
                            BorderWidth="0"
                            CornerRadius="0"
                            Clicked="OnDatePickerClicked"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill" />

                    <!-- Hidden DatePicker for programmatic access -->
                    <DatePicker x:Name="ActualDatePicker"
                                Date="{Binding SelectedDate}"
                                IsVisible="False"
                                Opacity="0"
                                InputTransparent="True" />
                </Grid>

                <!-- Region Selector Filters -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Bộ lọc miền:"
                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                           TextColor="#66736A"
                           Margin="2,0" />
                    <HorizontalStackLayout Spacing="8">
                        <!-- Miền Bắc Chip -->
                        <Border StrokeThickness="1"
                                Stroke="{Binding BacChipStroke}"
                                BackgroundColor="{Binding BacChipBg}"
                                Padding="12,5"
                                HeightRequest="32">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleBacCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Miền Bắc"
                                   FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                   TextColor="{Binding BacChipText}"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Miền Trung Chip -->
                        <Border StrokeThickness="1"
                                Stroke="{Binding TrungChipStroke}"
                                BackgroundColor="{Binding TrungChipBg}"
                                Padding="12,5"
                                HeightRequest="32">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleTrungCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Miền Trung"
                                   FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                   TextColor="{Binding TrungChipText}"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Miền Nam Chip -->
                        <Border StrokeThickness="1"
                                Stroke="{Binding NamChipStroke}"
                                BackgroundColor="{Binding NamChipBg}"
                                Padding="12,5"
                                HeightRequest="32">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleNamCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Miền Nam"
                                   FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                   TextColor="{Binding NamChipText}"
                                   VerticalOptions="Center" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Skeleton -->
                <Border IsVisible="{Binding ShowSkeleton}"
                        Padding="20"
                        StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <ActivityIndicator IsRunning="True" Color="#173D2A" />
                        <Label Text="Đang tải kết quả mới nhất…"
                               FontFamily="Geist" FontSize="13"
                               HorizontalTextAlignment="Center"
                               TextColor="#66736A" />
                    </VerticalStackLayout>
                </Border>

                <!-- Empty State -->
                <Border IsVisible="{Binding ShowEmptyState}"
                        StrokeThickness="1"
                        Stroke="#E2E8F0"
                        Padding="24,36"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label Text="✨"
                               FontSize="36"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Không có miền nào được chọn"
                               FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="#1E293B" />
                        <Label Text="Vui lòng bật các miền ở bộ lọc trên để xem kết quả xổ số tương ứng."
                               FontFamily="Geist" FontSize="12.5"
                               LineHeight="1.3"
                               HorizontalTextAlignment="Center"
                               TextColor="#64748B" />
                    </VerticalStackLayout>
                </Border>

                <!-- Region cards -->
                <CollectionView ItemsSource="{Binding Regions}"
                                SelectionMode="None"
                                ItemSizingStrategy="MeasureAllItems">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="lotteryModels:LotteryRegionDraw">
                            <Border StrokeThickness="1"
                                    Stroke="#E2E8F0"
                                    BackgroundColor="White"
                                    Padding="0">
                                <Border.StrokeShape>
                                    <shapes:RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F172A" Offset="0,8" Radius="18" Opacity="0.08" />
                                </Border.Shadow>

                                <Grid RowDefinitions="4,Auto">

                                    <!-- Top color stripe -->
                                    <BoxView Grid.Row="0"
                                             Color="{Binding AccentColor}" />

                                    <VerticalStackLayout Grid.Row="1" Padding="16" Spacing="14">

                                        <!-- Header row -->
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Border Grid.Column="0"
                                                    WidthRequest="40" HeightRequest="40"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{Binding AccentColor}"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <shapes:RoundRectangle CornerRadius="12" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding RegionIcon}"
                                                       FontFamily="Geist" FontSize="20" FontAttributes="Bold"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       TextColor="{Binding AccentTextColor}" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding ProvinceLabel}"
                                                       FontFamily="Geist" FontSize="19" FontAttributes="Bold"
                                                       TextColor="#142116" />
                                                <Label Text="{Binding RegionLabel}"
                                                       FontFamily="Geist" FontSize="12"
                                                       TextColor="#66736A" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="2"
                                                    StrokeThickness="1"
                                                    Stroke="#E2E8F0"
                                                    Padding="10,6"
                                                    BackgroundColor="#F8FAFC"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <shapes:RoundRectangle CornerRadius="10" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding DrawDateDisplay}"
                                                       FontFamily="GeistMono" FontSize="11" FontAttributes="Bold"
                                                       TextColor="#334155" />
                                            </Border>
                                        </Grid>

                                        <!-- Unified Prizes -->
                                        <VerticalStackLayout Spacing="12">
                                            <!-- Special Prize -->
                                            <Border StrokeThickness="1"
                                                    Stroke="#F8D77A"
                                                    BackgroundColor="#FFF8DB"
                                                    Padding="16,14">
                                                <Border.StrokeShape>
                                                    <shapes:RoundRectangle CornerRadius="16" />
                                                </Border.StrokeShape>
                                                <VerticalStackLayout Spacing="5">
                                                    <Label Text="GIẢI ĐẶC BIỆT"
                                                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                                           CharacterSpacing="0.8"
                                                           HorizontalTextAlignment="Center"
                                                           TextColor="#92400E" />
                                                    <FlexLayout IsVisible="{Binding HasSpecialPrize}"
                                                                BindableLayout.ItemsSource="{Binding SpecialNumberSegments}"
                                                                Wrap="Wrap"
                                                                JustifyContent="Center"
                                                                AlignItems="Center">
                                                        <BindableLayout.ItemTemplate>
                                                            <DataTemplate x:DataType="lotteryModels:LotteryNumberDisplayPart">
                                                                <HorizontalStackLayout Spacing="0" Margin="0,0,10,0">
                                                                    <Label Text="{Binding Prefix}"
                                                                           FontFamily="GeistMono"
                                                                           FontSize="40"
                                                                           FontAttributes="Bold"
                                                                           CharacterSpacing="1.2"
                                                                           TextColor="#334155" />
                                                                    <Label Text="{Binding Suffix}"
                                                                           FontFamily="GeistMono"
                                                                           FontSize="40"
                                                                           FontAttributes="Bold"
                                                                           CharacterSpacing="1.2"
                                                                           TextColor="#DC2626" />
                                                                    <Label Text="{Binding Separator}"
                                                                           FontFamily="GeistMono"
                                                                           FontSize="28"
                                                                           FontAttributes="Bold"
                                                                           Margin="8,5,0,0"
                                                                           TextColor="#CBD5E1" />
                                                                </HorizontalStackLayout>
                                                            </DataTemplate>
                                                        </BindableLayout.ItemTemplate>
                                                    </FlexLayout>
                                                </VerticalStackLayout>
                                            </Border>

                                            <!-- Other Prizes -->
                                            <VerticalStackLayout Spacing="8"
                                                                 BindableLayout.ItemsSource="{Binding OtherPrizes}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="lotteryModels:LotteryPrizeTier">
                                                        <Border StrokeThickness="1"
                                                                Stroke="#EEF2F7"
                                                                BackgroundColor="#FBFCFE"
                                                                Padding="12,10">
                                                            <Border.StrokeShape>
                                                                <shapes:RoundRectangle CornerRadius="12" />
                                                            </Border.StrokeShape>
                                                            <Grid ColumnDefinitions="76,*" ColumnSpacing="12">
                                                                <Label Text="{Binding TierLabel}"
                                                                       FontFamily="Geist"
                                                                       FontSize="13"
                                                                       FontAttributes="Bold"
                                                                       TextColor="#64748B"
                                                                       VerticalOptions="Start" />
                                                                <FlexLayout Grid.Column="1"
                                                                            BindableLayout.ItemsSource="{Binding NumberSegments}"
                                                                            Wrap="Wrap"
                                                                            AlignItems="Center">
                                                                    <BindableLayout.ItemTemplate>
                                                                        <DataTemplate x:DataType="lotteryModels:LotteryNumberDisplayPart">
                                                                            <HorizontalStackLayout Spacing="0" Margin="0,0,9,3">
                                                                                <Label Text="{Binding Prefix}"
                                                                                       FontFamily="GeistMono"
                                                                                       FontSize="15"
                                                                                       FontAttributes="Bold"
                                                                                       TextColor="#334155" />
                                                                                <Label Text="{Binding Suffix}"
                                                                                       FontFamily="GeistMono"
                                                                                       FontSize="15"
                                                                                       FontAttributes="Bold"
                                                                                       TextColor="#DC2626" />
                                                                                <Label Text="{Binding Separator}"
                                                                                       FontFamily="GeistMono"
                                                                                       FontSize="14"
                                                                                       FontAttributes="Bold"
                                                                                       Margin="6,0,0,0"
                                                                                       TextColor="#CBD5E1" />
                                                                            </HorizontalStackLayout>
                                                                        </DataTemplate>
                                                                    </BindableLayout.ItemTemplate>
                                                                </FlexLayout>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                        
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="* Kết quả mang tính tham khảo. Vui lòng đối chiếu với đài phát hành chính thức."
                       FontFamily="Geist" FontSize="11"
                       LineHeight="1.4"
                       TextColor="#8A958D"
                       Margin="4,2,4,80" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Sticky CTA -->
        <Border Grid.Row="2"
                Margin="20,0,20,28"
                Padding="6"
                StrokeThickness="0"
                BackgroundColor="White">
            <Border.StrokeShape>
                <shapes:RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#142116" Offset="0,10" Radius="20" Opacity="0.10" />
            </Border.Shadow>
            <Button Text="Kiểm tra vé của bạn"
                    Command="{Binding OpenCaptureCommand}"
                    HeightRequest="52"
                    CornerRadius="18"
                    FontFamily="Geist"
                    FontSize="15"
                    FontAttributes="Bold"
                    BackgroundColor="#173D2A"
                    TextColor="#F5C842" />
        </Border>
    </Grid>
</ContentPage>
