<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:viewModel="clr-namespace:LotteryDetection.Mobile.ViewModel"
             xmlns:lotteryModels="clr-namespace:LotteryDetection.Mobile.Models.Lottery"
             xmlns:components="clr-namespace:LotteryDetection.Mobile.Views.Components"
             xmlns:col="clr-namespace:System.Collections;assembly=netstandard"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             ios:Page.UseSafeArea="True"
             x:Class="LotteryDetection.Mobile.Views.LotteryResults.LotteryLiveResultsPage"
             x:DataType="viewModel:LotteryLiveResultsViewModel"
             Title="Kết quả trực tiếp"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFBF6">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top bar -->
        <Grid Grid.Row="0"
              Padding="20,8,20,12"
              ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="28"
                    WidthRequest="44" HeightRequest="44"
                    Padding="0" CornerRadius="14"
                    BackgroundColor="#E9EFE4"
                    TextColor="#031649"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1"
                   Text="Kết quả trực tiếp"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                   TextColor="#031649" />
            <BoxView Grid.Column="2" WidthRequest="44" HeightRequest="44" BackgroundColor="Transparent" />
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,4,20,28" Spacing="16">

                <!-- Hero -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Xổ số trực tiếp hôm nay"
                               FontFamily="Geist" FontSize="13"
                               TextColor="#16A34A" FontAttributes="Bold" />
                        <Label Text="{Binding HeroDateLabel}"
                               FontFamily="Geist" FontSize="26" FontAttributes="Bold"
                               LineHeight="1.1"
                               TextColor="#142116" />
                        <Label Text="{Binding UpdatedAtLabel}"
                               FontFamily="Geist" FontSize="12"
                               TextColor="#66736A" />
                    </VerticalStackLayout>
                    <Border x:Name="LiveBadgeBorder"
                            Grid.Column="1"
                            StrokeThickness="0"
                            Padding="10,5"
                            BackgroundColor="#DCFCE7"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <shapes:RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                            <Ellipse WidthRequest="7" HeightRequest="7"
                                     Fill="#16A34A"
                                     VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="TRỰC TIẾP"
                                   FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                   TextColor="#15803D" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Region Selector Filters -->
                <VerticalStackLayout Spacing="8" Margin="0,4,0,4">
                    <Label Text="Bộ lọc miền:"
                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                           TextColor="#66736A"
                           Margin="2,0" />
                    <HorizontalStackLayout Spacing="8">
                        <!-- Miền Bắc Chip -->
                        <Border StrokeThickness="1"
                                Stroke="{Binding BacChipStroke}"
                                BackgroundColor="{Binding BacChipBg}"
                                Padding="12,5"
                                HeightRequest="32">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleBacCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Miền Bắc"
                                   FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                   TextColor="{Binding BacChipText}"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Miền Trung Chip -->
                        <Border StrokeThickness="1"
                                Stroke="{Binding TrungChipStroke}"
                                BackgroundColor="{Binding TrungChipBg}"
                                Padding="12,5"
                                HeightRequest="32">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleTrungCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Miền Trung"
                                   FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                   TextColor="{Binding TrungChipText}"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Miền Nam Chip -->
                        <Border StrokeThickness="1"
                                Stroke="{Binding NamChipStroke}"
                                BackgroundColor="{Binding NamChipBg}"
                                Padding="12,5"
                                HeightRequest="32">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleNamCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Miền Nam"
                                   FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                   TextColor="{Binding NamChipText}"
                                   VerticalOptions="Center" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Status Warning Notice -->
                <Border IsVisible="{Binding ShowDrawingTimeStatusMessage}"
                        StrokeThickness="1"
                        Stroke="#FDBA74"
                        Padding="16"
                        BackgroundColor="#FFF7ED">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Text="⏰" FontSize="22" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Chưa tới giờ xổ số"
                                   FontFamily="Geist" FontSize="14.5" FontAttributes="Bold"
                                   TextColor="#C2410C" />
                            <Label Text="{Binding DrawingTimeStatusMessage}"
                                   FontFamily="Geist" FontSize="12.5"
                                   LineHeight="1.3"
                                   TextColor="#EA580C" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Skeleton -->
                <Border IsVisible="{Binding ShowSkeleton}"
                        Padding="20"
                        StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <ActivityIndicator IsRunning="True" Color="#173D2A" />
                        <Label Text="Đang kết nối đến máy chủ trực tiếp…"
                               FontFamily="Geist" FontSize="13"
                               HorizontalTextAlignment="Center"
                               TextColor="#66736A" />
                    </VerticalStackLayout>
                </Border>

                <!-- Empty State -->
                <Border IsVisible="{Binding ShowEmptyState}"
                        StrokeThickness="1"
                        Stroke="#E2E8F0"
                        Padding="24,36"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label Text="✨"
                               FontSize="36"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Không có miền nào được chọn"
                               FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="#1E293B" />
                        <Label Text="Vui lòng bật các miền ở bộ lọc trên để xem kết quả xổ số tương ứng."
                               FontFamily="Geist" FontSize="12.5"
                               LineHeight="1.3"
                               HorizontalTextAlignment="Center"
                               TextColor="#64748B" />
                    </VerticalStackLayout>
                </Border>

                <!-- Region cards -->
                <CollectionView ItemsSource="{Binding Regions}"
                                SelectionMode="None"
                                ItemSizingStrategy="MeasureAllItems">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="lotteryModels:LotteryRegionDraw">
                            <Border StrokeThickness="1"
                                    Stroke="#E2E8F0"
                                    BackgroundColor="White"
                                    Padding="0">
                                <Border.StrokeShape>
                                    <shapes:RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F172A" Offset="0,8" Radius="18" Opacity="0.08" />
                                </Border.Shadow>

                                <Grid RowDefinitions="4,Auto">

                                    <!-- Top color stripe -->
                                    <BoxView Grid.Row="0"
                                             Color="{Binding AccentColor}" />

                                    <VerticalStackLayout Grid.Row="1" Padding="16" Spacing="14">

                                        <!-- Header row -->
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Border Grid.Column="0"
                                                    WidthRequest="40" HeightRequest="40"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{Binding AccentColor}"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <shapes:RoundRectangle CornerRadius="12" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding RegionIcon}"
                                                       FontFamily="Geist" FontSize="20" FontAttributes="Bold"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       TextColor="{Binding AccentTextColor}" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding ProvinceLabel}"
                                                       FontFamily="Geist" FontSize="19" FontAttributes="Bold"
                                                       TextColor="#142116" />
                                                <Label Text="{Binding RegionLabel}"
                                                       FontFamily="Geist" FontSize="12"
                                                       TextColor="#66736A" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="2"
                                                    StrokeThickness="1"
                                                    Stroke="#E2E8F0"
                                                    Padding="10,6"
                                                    BackgroundColor="#F8FAFC"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <shapes:RoundRectangle CornerRadius="10" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding DrawDateDisplay}"
                                                       FontFamily="GeistMono" FontSize="11" FontAttributes="Bold"
                                                       TextColor="#334155" />
                                            </Border>
                                        </Grid>

                                        <!-- Unified Prizes -->
                                        <VerticalStackLayout Spacing="12">
                                            <!-- Special Prize -->
                                            <Border StrokeThickness="1"
                                                    Stroke="#F8D77A"
                                                    BackgroundColor="#FFF8DB"
                                                    Padding="16,14">
                                                <Border.StrokeShape>
                                                    <shapes:RoundRectangle CornerRadius="16" />
                                                </Border.StrokeShape>
                                                <VerticalStackLayout Spacing="5">
                                                    <Label Text="GIẢI ĐẶC BIỆT"
                                                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                                           CharacterSpacing="0.8"
                                                           HorizontalTextAlignment="Center"
                                                           TextColor="#92400E" />
                                                    
                                                    <!-- If Drawn -->
                                                    <FlexLayout IsVisible="{Binding HasSpecialPrize}"
                                                                BindableLayout.ItemsSource="{Binding SpecialNumberSegments}"
                                                                Wrap="Wrap"
                                                                JustifyContent="Center"
                                                                AlignItems="Center">
                                                        <BindableLayout.ItemTemplate>
                                                            <DataTemplate x:DataType="lotteryModels:LotteryNumberDisplayPart">
                                                                <HorizontalStackLayout Spacing="0" Margin="0,0,10,0">
                                                                    <Label Text="{Binding Prefix}"
                                                                           FontFamily="GeistMono"
                                                                           FontSize="40"
                                                                           FontAttributes="Bold"
                                                                           CharacterSpacing="1.2"
                                                                           TextColor="#334155" />
                                                                    <Label Text="{Binding Suffix}"
                                                                           FontFamily="GeistMono"
                                                                           FontSize="40"
                                                                           FontAttributes="Bold"
                                                                           CharacterSpacing="1.2"
                                                                           TextColor="#DC2626" />
                                                                    <Label Text="{Binding Separator}"
                                                                           FontFamily="GeistMono"
                                                                           FontSize="28"
                                                                           FontAttributes="Bold"
                                                                           Margin="8,5,0,0"
                                                                           TextColor="#CBD5E1" />
                                                                </HorizontalStackLayout>
                                                            </DataTemplate>
                                                        </BindableLayout.ItemTemplate>
                                                    </FlexLayout>

                                                    <!-- If Not Drawn (Loading) -->
                                                    <HorizontalStackLayout IsVisible="{Binding IsSpecialPrizeNotDrawn}"
                                                                           Spacing="8" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,4,0,0">
                                                        <ActivityIndicator IsRunning="True" Color="#B45309" WidthRequest="20" HeightRequest="20" />
                                                        <Label Text="Đang quay..." FontFamily="Geist" FontSize="15" FontAttributes="Italic" TextColor="#92400E" VerticalOptions="Center" />
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>
                                            </Border>

                                            <!-- Other Prizes -->
                                            <VerticalStackLayout Spacing="8"
                                                                 BindableLayout.ItemsSource="{Binding OtherPrizes}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="lotteryModels:LotteryPrizeTier">
                                                        <Border StrokeThickness="1"
                                                                Stroke="#EEF2F7"
                                                                BackgroundColor="#FBFCFE"
                                                                Padding="12,10">
                                                            <Border.StrokeShape>
                                                                <shapes:RoundRectangle CornerRadius="12" />
                                                            </Border.StrokeShape>
                                                            <Grid ColumnDefinitions="76,*" ColumnSpacing="12">
                                                                <Label Text="{Binding TierLabel}"
                                                                       FontFamily="Geist"
                                                                       FontSize="13"
                                                                       FontAttributes="Bold"
                                                                       TextColor="#64748B"
                                                                       VerticalOptions="Start" />
                                                                
                                                                <!-- If Drawn -->
                                                                <FlexLayout Grid.Column="1"
                                                                            IsVisible="{Binding IsDrawn}"
                                                                            BindableLayout.ItemsSource="{Binding NumberSegments}"
                                                                            Wrap="Wrap"
                                                                            AlignItems="Center">
                                                                    <BindableLayout.ItemTemplate>
                                                                        <DataTemplate x:DataType="lotteryModels:LotteryNumberDisplayPart">
                                                                            <HorizontalStackLayout Spacing="0" Margin="0,0,9,3">
                                                                                <Label Text="{Binding Prefix}"
                                                                                       FontFamily="GeistMono"
                                                                                       FontSize="15"
                                                                                       FontAttributes="Bold"
                                                                                       TextColor="#334155" />
                                                                                <Label Text="{Binding Suffix}"
                                                                                       FontFamily="GeistMono"
                                                                                       FontSize="15"
                                                                                       FontAttributes="Bold"
                                                                                       TextColor="#DC2626" />
                                                                                <Label Text="{Binding Separator}"
                                                                                       FontFamily="GeistMono"
                                                                                       FontSize="14"
                                                                                       FontAttributes="Bold"
                                                                                       Margin="6,0,0,0"
                                                                                       TextColor="#CBD5E1" />
                                                                            </HorizontalStackLayout>
                                                                        </DataTemplate>
                                                                    </BindableLayout.ItemTemplate>
                                                                </FlexLayout>

                                                                <!-- If Not Drawn -->
                                                                <HorizontalStackLayout Grid.Column="1"
                                                                                       IsVisible="{Binding IsNotDrawn}"
                                                                                       Spacing="6"
                                                                                       VerticalOptions="Center">
                                                                    <ActivityIndicator IsRunning="True" Color="#16A34A" WidthRequest="14" HeightRequest="14" />
                                                                    <Label Text="Đang quay..." FontFamily="Geist" FontSize="12" FontAttributes="Italic" TextColor="#16A34A" VerticalOptions="Center" />
                                                                </HorizontalStackLayout>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="* Kết quả trực tiếp đang được cập nhật thời gian thực. Nhấn nút Trực Tiếp ở góc trên để cập nhật tức thì."
                       FontFamily="Geist" FontSize="11"
                       LineHeight="1.4"
                       TextColor="#8A958D"
                       Margin="4,2,4,24" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Sticky CTA -->
        <Border Grid.Row="2"
                Margin="20,0,20,28"
                Padding="6"
                StrokeThickness="0"
                BackgroundColor="White">
            <Border.StrokeShape>
                <shapes:RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#142116" Offset="0,10" Radius="20" Opacity="0.10" />
            </Border.Shadow>
            <Button Text="Kiểm tra vé của bạn"
                    Command="{Binding OpenCaptureCommand}"
                    HeightRequest="52"
                    CornerRadius="18"
                    FontFamily="Geist"
                    FontSize="15"
                    FontAttributes="Bold"
                    BackgroundColor="#173D2A"
                    TextColor="#F5C842" />
        </Border>
    </Grid>
</ContentPage>
