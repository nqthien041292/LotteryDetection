<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="LotteryDetection.Mobile.Views.Dashboard.DashboardPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Padding="0"
                           BackgroundColor="#FAFBF6">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,44,20,24" Spacing="18">
                <!-- Top Header Row with Waving Lucky Cat Avatar -->
                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center" Margin="0,0,0,4">
                    <VerticalStackLayout x:Name="HeaderTitleStack" Spacing="2">
                        <Label Text="DÒ VÉ SỐ TỰ ĐỘNG"
                               FontFamily="Geist"
                               FontSize="12"
                               FontAttributes="Bold"
                               CharacterSpacing="1.2"
                               TextColor="#00bb77" />
                        <Label Text="Gõ Cửa Thần Tài"
                               FontFamily="Geist"
                               FontSize="28"
                               FontAttributes="Bold"
                               LineHeight="1.1"
                               TextColor="#031649" />
                    </VerticalStackLayout>
                    <Border x:Name="HeaderAvatarBorder" Grid.Column="1" WidthRequest="52" HeightRequest="52" StrokeThickness="1.5" Stroke="#00bb77" BackgroundColor="White">
                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="26" /></Border.StrokeShape>
                        <Image Source="lucky_mascot.png" Aspect="AspectFill" Margin="2" />
                    </Border>
                </Grid>

                <!-- Main Scan Ticket Card with Brand Colors and Mascot -->
                <Border x:Name="MainScanCard" StrokeThickness="0" Padding="18">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#031649" Offset="0.0" />
                            <GradientStop Color="#00bb77" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#031649" Radius="24" Offset="0,14" Opacity="0.25" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="18">
                        <Grid ColumnDefinitions="*,110" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Text="Thần Tài Quét Vé 🎯"
                                       FontFamily="Geist"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#FFD700" />
                                <Label Text="Dò Vé Trong Vài Giây"
                                       FontFamily="Geist"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       LineHeight="1.15"
                                       TextColor="White" />
                                <Label Text="Chụp vé nhanh - Thần Tài dò liền, rước cát tường chiêu tài lộc!"
                                       FontFamily="Geist"
                                       FontSize="12"
                                       LineHeight="1.45"
                                       TextColor="#CFE6D5" />
                            </VerticalStackLayout>
                            <Border x:Name="MascotBadge"
                                    Grid.Column="1"
                                    WidthRequest="108"
                                    HeightRequest="108"
                                    Stroke="#F5C842"
                                    StrokeThickness="2.5"
                                    BackgroundColor="White"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End">
                                <Border.StrokeShape>
                                    <shapes:RoundRectangle CornerRadius="54" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#000000" Radius="12" Offset="0,6" Opacity="0.2" />
                                </Border.Shadow>
                                <Image Source="lucky_mascot.png" Aspect="AspectFill" Margin="2" />
                            </Border>
                        </Grid>

                        <Button x:Name="ScanButton"
                                Grid.Row="1"
                                Text="📸 Chụp &amp; Dò Vé Ngay"
                                Command="{Binding OpenLotteryCaptureCommand}"
                                Clicked="OnScanButtonClicked"
                                HeightRequest="56"
                                CornerRadius="18"
                                FontFamily="Geist"
                                FontSize="16"
                                FontAttributes="Bold"
                                BackgroundColor="#F5C842"
                                TextColor="#031649">
                            <Button.Shadow>
                                <Shadow Brush="#000000" Radius="10" Offset="0,4" Opacity="0.15" />
                            </Button.Shadow>
                        </Button>

                        <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                                <Label Text="🪙 3 Bước"
                                       FontFamily="Geist"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Chụp, Đọc, Đối"
                                       FontFamily="Geist"
                                       FontSize="11"
                                       TextColor="#CFE6D5"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                                <Label Text="🔮 AI Siêu Tốc"
                                       FontFamily="Geist"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Độ Chính Xác Cao"
                                       FontFamily="Geist"
                                       FontSize="11"
                                       TextColor="#CFE6D5"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                                <Label Text="✨ Trúng Giải"
                                       FontFamily="Geist"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Báo Kết Quả Liền"
                                       FontFamily="Geist"
                                       FontSize="11"
                                       TextColor="#CFE6D5"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Secondary Actions Card Grid with Lift Shadows -->
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" RowSpacing="12" ColumnSpacing="12">
                    <Border x:Name="ResultsCard" Grid.Row="0" Grid.Column="0" Padding="14" StrokeThickness="1" Stroke="#E2EDE0" BackgroundColor="White">
                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLotteryResultsCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="#031649" Radius="12" Offset="0,6" Opacity="0.08" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Border x:Name="ResultsIconBorder" WidthRequest="36" HeightRequest="36" StrokeThickness="0" BackgroundColor="#E7F5DE" HorizontalOptions="Start">
                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                    <Image x:Name="ResultsIcon" Source="gold_ingot.png" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" VerticalOptions="Center" Aspect="AspectFit" />
                                </Border>
                                <Label Grid.Column="1" Text="›" FontSize="22" FontAttributes="Bold" TextColor="#00bb77" VerticalOptions="Center" />
                            </Grid>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Kết quả hôm nay" FontFamily="Geist" FontSize="13" FontAttributes="Bold" TextColor="#031649" />
                                <Label Text="Xem kết quả miền Bắc, Trung, Nam mới nhất."
                                       FontFamily="Geist" FontSize="12" LineHeight="1.35" TextColor="#66736A" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                    <Border x:Name="HistoryCard" Grid.Row="0" Grid.Column="1" Padding="14" StrokeThickness="1" Stroke="#F7EED3" BackgroundColor="White">
                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLotteryHistoryCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="#031649" Radius="12" Offset="0,6" Opacity="0.08" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Border x:Name="HistoryIconBorder" WidthRequest="36" HeightRequest="36" StrokeThickness="0" BackgroundColor="#FFF5CC" HorizontalOptions="Start">
                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                    <Image x:Name="HistoryIcon" Source="treasure_chest.png" WidthRequest="26" HeightRequest="26" HorizontalOptions="Center" VerticalOptions="Center" Aspect="AspectFit" />
                                </Border>
                                <Label Grid.Column="1" Text="›" FontSize="22" FontAttributes="Bold" TextColor="#F5C842" VerticalOptions="Center" />
                            </Grid>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Lịch sử dò vé" FontFamily="Geist" FontSize="13" FontAttributes="Bold" TextColor="#031649" />
                                <Label Text="Xem lại ảnh chụp vé và kết quả dò thưởng."
                                       FontFamily="Geist" FontSize="12" LineHeight="1.35" TextColor="#66736A" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Thần Tài Dự Đoán Card -->
                    <Border x:Name="PredictionCard" Grid.Row="1" Grid.Column="0" Padding="14" StrokeThickness="1" Stroke="#E0E7FF" BackgroundColor="White">
                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowFeatureUnderDevelopmentCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="#031649" Radius="12" Offset="0,6" Opacity="0.08" />
                        </Border.Shadow>
                        <Grid>
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Border WidthRequest="36" HeightRequest="36" StrokeThickness="0" BackgroundColor="#EEF2FF" HorizontalOptions="Start">
                                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                        <Label Text="🔮" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Grid.Column="1" Text="›" FontSize="22" FontAttributes="Bold" TextColor="#4F46E5" VerticalOptions="Center" />
                                </Grid>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Thần Tài Dự Đoán" FontFamily="Geist" FontSize="13" FontAttributes="Bold" TextColor="#031649" />
                                    <Label Text="AI gợi ý cặp số may mắn cát tường mỗi ngày."
                                           FontFamily="Geist" FontSize="12" LineHeight="1.35" TextColor="#66736A" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>

                            <!-- BETA Badge -->
                            <Border BackgroundColor="#FF3B30" StrokeThickness="0" Padding="6,2" HorizontalOptions="End" VerticalOptions="Start" Margin="0,-4,-4,0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                <Label Text="BETA" FontSize="8" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Nhiệm Vụ Rước Lộc Card -->
                    <Border x:Name="TasksCard" Grid.Row="1" Grid.Column="1" Padding="14" StrokeThickness="1" Stroke="#FEE2E2" BackgroundColor="White">
                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowFeatureUnderDevelopmentCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="#031649" Radius="12" Offset="0,6" Opacity="0.08" />
                        </Border.Shadow>
                        <Grid>
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Border WidthRequest="36" HeightRequest="36" StrokeThickness="0" BackgroundColor="#FEF2F2" HorizontalOptions="Start">
                                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                        <Label Text="🪙" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Grid.Column="1" Text="›" FontSize="22" FontAttributes="Bold" TextColor="#EF4444" VerticalOptions="Center" />
                                </Grid>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Nhiệm Vụ Rước Lộc" FontFamily="Geist" FontSize="13" FontAttributes="Bold" TextColor="#031649" />
                                    <Label Text="Làm nhiệm vụ nhận xu vàng, tích lũy may mắn."
                                           FontFamily="Geist" FontSize="12" LineHeight="1.35" TextColor="#66736A" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>

                            <!-- BETA Badge -->
                            <Border BackgroundColor="#FF9500" StrokeThickness="0" Padding="6,2" HorizontalOptions="End" VerticalOptions="Start" Margin="0,-4,-4,0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                <Label Text="BETA" FontSize="8" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>


                <!-- Quy trình rước lộc Card -->
                <Border x:Name="ProcessCard" Padding="16" StrokeThickness="1" Stroke="#E2EDE0" BackgroundColor="White">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#031649" Radius="14" Offset="0,8" Opacity="0.06" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Quy Trình Tự Động Rước Lộc 🍀"
                               FontFamily="Geist"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#031649" />
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                            <Border Grid.Row="0" WidthRequest="32" HeightRequest="32" StrokeThickness="0" BackgroundColor="#E7F5DE">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                <Label Text="1" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#00bb77" />
                            </Border>
                            <Label Grid.Row="0" Grid.Column="1" Text="Căn vé trong khung chụp để ảnh rõ số và đài phát hành." FontFamily="Geist" FontSize="13" TextColor="#38443B" VerticalOptions="Center" />
                            <Border Grid.Row="1" WidthRequest="32" HeightRequest="32" StrokeThickness="0" BackgroundColor="#FFF5CC">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                <Label Text="2" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#F5C842" />
                            </Border>
                            <Label Grid.Row="1" Grid.Column="1" Text="AI đọc và phân tích dãy số, ngày quay và tỉnh phát hành." FontFamily="Geist" FontSize="13" TextColor="#38443B" VerticalOptions="Center" />
                            <Border Grid.Row="2" WidthRequest="32" HeightRequest="32" StrokeThickness="0" BackgroundColor="#E8EEFF">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                <Label Text="3" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#031649" />
                            </Border>
                            <Label Grid.Row="2" Grid.Column="1" Text="AI đối chiếu kết quả từ server và báo vé có trúng giải hay không." FontFamily="Geist" FontSize="13" TextColor="#38443B" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
