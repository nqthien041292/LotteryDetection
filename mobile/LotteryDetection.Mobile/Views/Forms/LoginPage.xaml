<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:viewModel="clr-namespace:LotteryDetection.Mobile.ViewModel"
             xmlns:cv="clr-namespace:LotteryDetection.Mobile.Converters"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="LotteryDetection.Mobile.Views.Forms.LoginPage"
             x:DataType="viewModel:LoginPageViewModel"
             Shell.NavBarIsVisible="False"
             ios:Page.UseSafeArea="True"
             BackgroundColor="#FAFBF6">

    <ContentPage.Resources>
        <ResourceDictionary>
            <cv:InvertBoolConverter x:Key="InvertBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="0"
          RowDefinitions="*,Auto">
        <!-- Centered hero + actions -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="0"
                             HorizontalOptions="Fill"
                             VerticalOptions="Center"
                             Padding="32,40,32,0"
                             WidthRequest="{OnPlatform WinUI=420, MacCatalyst=420, Default=-1}">

            <!-- Brand logo — same asset as SplashPage for visual continuity -->
            <Image Source="logo.png"
                   WidthRequest="100"
                   HeightRequest="100"
                   HorizontalOptions="Center"
                   Margin="0,0,0,28" />

            <!-- Title with brand "AI" highlight -->
            <Label HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   FontFamily="Geist" FontSize="36" FontAttributes="Bold"
                   CharacterSpacing="-0.025"
                   LineHeight="1"
                   Margin="0,0,0,14"
                   TextColor="#031649">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="DòVéSố " />
                        <Span Text="AI"
                              TextColor="#00bb77" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Label Text="Đăng nhập để quét vé số tự động, rước tài lộc cát tường cùng Thần Tài AI!"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   FontFamily="Geist" FontSize="15" LineHeight="1.45"
                   MaximumWidthRequest="320"
                   TextColor="#66736A"
                   Margin="0,0,0,28" />

            <!-- Microsoft sign-in button -->
            <Border StrokeThickness="1"
                    Stroke="#E2E8F0"
                    BackgroundColor="White"
                    HeightRequest="56"
                    Padding="0"
                    HorizontalOptions="Fill"
                    Opacity="{Binding MicrosoftButtonOpacity}">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#031649" Offset="0,2" Radius="6" Opacity="0.06" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SignInWithMicrosoftCommand}" />
                </Border.GestureRecognizers>
                <Grid VerticalOptions="Center" HorizontalOptions="Center" ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                    <!-- Idle: 4-square Microsoft logo -->
                    <Grid Grid.Column="0"
                          WidthRequest="18" HeightRequest="18"
                          ColumnDefinitions="*,*"
                          RowDefinitions="*,*"
                          ColumnSpacing="2" RowSpacing="2"
                          IsVisible="{Binding IsMicrosoftIdle}">
                        <BoxView Grid.Row="0" Grid.Column="0" Color="#F25022" />
                        <BoxView Grid.Row="0" Grid.Column="1" Color="#7FBA00" />
                        <BoxView Grid.Row="1" Grid.Column="0" Color="#00A4EF" />
                        <BoxView Grid.Row="1" Grid.Column="1" Color="#FFB900" />
                    </Grid>
                    <!-- Busy: spinner -->
                    <ActivityIndicator Grid.Column="0"
                                       IsRunning="{Binding IsMicrosoftBusy}"
                                       IsVisible="{Binding IsMicrosoftBusy}"
                                       Color="#031649"
                                       HeightRequest="18" WidthRequest="18" />
                    <Label Grid.Column="1"
                           FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="#031649">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsMicrosoftBusy}" Value="True">
                                <Setter Property="Text" Value="Đang đăng nhập…" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsMicrosoftBusy}" Value="False">
                                <Setter Property="Text" Value="Tiếp tục với Microsoft" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Grid>
            </Border>

            <!-- Google sign-in button -->
            <Border StrokeThickness="1"
                    Stroke="#E2E8F0"
                    BackgroundColor="White"
                    HeightRequest="56"
                    Padding="0"
                    HorizontalOptions="Fill"
                    Margin="0,10,0,0"
                    Opacity="{Binding GoogleButtonOpacity}">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#4285F4" Offset="0,2" Radius="6" Opacity="0.08" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SignInWithGoogleCommand}" />
                </Border.GestureRecognizers>
                <Grid VerticalOptions="Center" HorizontalOptions="Center" ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                    <!-- Idle: 4-color Google G -->
                    <Image Grid.Column="0"
                           IsVisible="{Binding IsGoogleIdle}"
                           Source="google_logo.png"
                           WidthRequest="22" HeightRequest="22"
                           Aspect="AspectFit" />
                    <!-- Busy: spinner -->
                    <ActivityIndicator Grid.Column="0"
                                       IsRunning="{Binding IsGoogleBusy}"
                                       IsVisible="{Binding IsGoogleBusy}"
                                       Color="#4285F4"
                                       HeightRequest="18" WidthRequest="18" />
                    <Label Grid.Column="1"
                           FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="#031649">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsGoogleBusy}" Value="True">
                                <Setter Property="Text" Value="Đang đăng nhập…" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsGoogleBusy}" Value="False">
                                <Setter Property="Text" Value="Tiếp tục với Google" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Grid>
            </Border>

            <!-- Facebook sign-in button -->
            <Border StrokeThickness="0"
                    BackgroundColor="#1877F2"
                    HeightRequest="56"
                    Padding="0"
                    HorizontalOptions="Fill"
                    Margin="0,10,0,0"
                    Opacity="{Binding FacebookButtonOpacity}">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1877F2" Offset="0,2" Radius="6" Opacity="0.2" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SignInWithFacebookCommand}" />
                </Border.GestureRecognizers>
                <Grid VerticalOptions="Center" HorizontalOptions="Center" ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                    <!-- Idle: bold "f" -->
                    <Label Grid.Column="0"
                           IsVisible="{Binding IsFacebookIdle}"
                           Text="f"
                           FontFamily="Geist" FontSize="24" FontAttributes="Bold"
                           TextColor="White"
                           WidthRequest="22" HeightRequest="22"
                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                    <!-- Busy: spinner -->
                    <ActivityIndicator Grid.Column="0"
                                       IsRunning="{Binding IsFacebookBusy}"
                                       IsVisible="{Binding IsFacebookBusy}"
                                       Color="White"
                                       HeightRequest="18" WidthRequest="18" />
                    <Label Grid.Column="1"
                           FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="White">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsFacebookBusy}" Value="True">
                                <Setter Property="Text" Value="Đang đăng nhập…" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsFacebookBusy}" Value="False">
                                <Setter Property="Text" Value="Tiếp tục với Facebook" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Grid>
            </Border>

            <!-- Status / error -->
            <Label Text="{Binding StatusMessage}"
                   FontFamily="Geist" FontSize="13"
                   HorizontalOptions="Center"
                   TextColor="#66736A"
                   IsVisible="{Binding HasStatus}" Margin="0,12,0,0" />
            <Label Text="{Binding ErrorMessage}"
                   FontFamily="Geist" FontSize="13"
                   HorizontalOptions="Center"
                   TextColor="#DC2626"
                   IsVisible="{Binding HasError}" Margin="0,8,0,0" />
        </VerticalStackLayout>

        <!-- Footer terms -->
        <Label Grid.Row="1"
               Padding="32,0,32,36"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               FontFamily="Geist" FontSize="11.5" LineHeight="1.4"
               TextColor="#8A958D">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Bằng cách tiếp tục, bạn đồng ý với " />
                    <Span Text="Điều khoản"
                          TextDecorations="Underline"
                          TextColor="#031649" />
                    <Span Text=" và " />
                    <Span Text="Chính sách bảo mật"
                          TextDecorations="Underline"
                          TextColor="#031649" />
                    <Span Text=" của chúng tôi." />
                </FormattedString>
            </Label.FormattedText>
        </Label>
    </Grid>
</ContentPage>
