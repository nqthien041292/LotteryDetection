<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:viewModel="clr-namespace:LotteryDetection.Mobile.ViewModel"
             xmlns:cv="clr-namespace:LotteryDetection.Mobile.Converters"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="LotteryDetection.Mobile.Views.Forms.LoginPage"
             x:DataType="viewModel:LoginPageViewModel"
             Shell.NavBarIsVisible="False"
             ios:Page.UseSafeArea="True"
             BackgroundColor="{AppThemeBinding Light=White, Dark={DynamicResource FamilyCreamDark}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <cv:InvertBoolConverter x:Key="InvertBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="0"
          RowDefinitions="*,Auto">
        <!-- Centered hero + actions -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="0"
                             HorizontalOptions="Fill"
                             VerticalOptions="Center"
                             Padding="32,40,32,0"
                             WidthRequest="{OnPlatform WinUI=420, MacCatalyst=420, Default=-1}">

            <!-- Brand logo — same asset as SplashPage for visual continuity -->
            <Image Source="logo.png"
                   WidthRequest="100"
                   HeightRequest="100"
                   HorizontalOptions="Center"
                   Margin="0,0,0,28" />

            <!-- Title with gradient "AI" -->
            <Label HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   FontFamily="Geist" FontSize="36" FontAttributes="Bold"
                   CharacterSpacing="-0.025"
                   LineHeight="1"
                   Margin="0,0,0,14"
                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="DòVéSố " />
                        <Span Text="AI"
                              TextColor="#00bb77" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Label Text="Đăng nhập để quét vé số tự động, rước tài lộc cát tường cùng Thần Tài AI!"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   FontFamily="Geist" FontSize="15" LineHeight="1.45"
                   MaximumWidthRequest="320"
                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}"
                   Margin="0,0,0,28" />

            <!-- Microsoft sign-in button -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyPaperDark}}"
                    HeightRequest="56"
                    Padding="0"
                    HorizontalOptions="Fill">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1E5BFF" Offset="0,2" Radius="6" Opacity="0.06" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SignInWithMicrosoftCommand}" />
                </Border.GestureRecognizers>
                <Grid VerticalOptions="Center" HorizontalOptions="Center" ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                    <!-- Idle: 4-square Microsoft logo -->
                    <Grid Grid.Column="0"
                          WidthRequest="18" HeightRequest="18"
                          ColumnDefinitions="*,*"
                          RowDefinitions="*,*"
                          ColumnSpacing="2" RowSpacing="2"
                          IsVisible="{Binding IsBusy, Converter={StaticResource InvertBool}}">
                        <BoxView Grid.Row="0" Grid.Column="0" Color="#F25022" />
                        <BoxView Grid.Row="0" Grid.Column="1" Color="#7FBA00" />
                        <BoxView Grid.Row="1" Grid.Column="0" Color="#00A4EF" />
                        <BoxView Grid.Row="1" Grid.Column="1" Color="#FFB900" />
                    </Grid>
                    <!-- Busy: spinner -->
                    <ActivityIndicator Grid.Column="0"
                                       IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}"
                                       HeightRequest="18" WidthRequest="18" />
                    <Label Grid.Column="1"
                           FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Text" Value="Đang đăng nhập…" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsBusy}" Value="False">
                                <Setter Property="Text" Value="Tiếp tục với Microsoft" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Grid>
            </Border>

            <!-- "OR" divider -->
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10" Margin="0,20,0,16">
                <BoxView Grid.Column="0" HeightRequest="1"
                         Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                         VerticalOptions="Center" />
                <Label Grid.Column="1" Text="OR"
                       FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                       CharacterSpacing="0.06"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}"
                       VerticalOptions="Center" />
                <BoxView Grid.Column="2" HeightRequest="1"
                         Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                         VerticalOptions="Center" />
            </Grid>

            <Button Text="Sử dụng email thay thế"
                    HeightRequest="48"
                    CornerRadius="14"
                    BackgroundColor="Transparent"
                    BorderWidth="0"
                    FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}" />

            <!-- Status / error -->
            <Label Text="{Binding StatusMessage}"
                   FontFamily="Geist" FontSize="13"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}"
                   IsVisible="{Binding HasStatus}" Margin="0,12,0,0" />
            <Label Text="{Binding ErrorMessage}"
                   FontFamily="Geist" FontSize="13"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={DynamicResource FamilyDangerLight}, Dark={DynamicResource FamilyDangerDark}}"
                   IsVisible="{Binding HasError}" Margin="0,8,0,0" />
        </VerticalStackLayout>

        <!-- Footer terms -->
        <Label Grid.Row="1"
               Padding="32,0,32,36"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               FontFamily="Geist" FontSize="11.5" LineHeight="1.4"
               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Bằng cách tiếp tục, bạn đồng ý với " />
                    <Span Text="Điều khoản"
                          TextDecorations="Underline"
                          TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}" />
                    <Span Text=" và " />
                    <Span Text="Chính sách bảo mật"
                          TextDecorations="Underline"
                          TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}" />
                    <Span Text=" của chúng tôi." />
                </FormattedString>
            </Label.FormattedText>
        </Label>
    </Grid>
</ContentPage>
