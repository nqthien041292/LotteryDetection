<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:viewModel="clr-namespace:LotteryDetection.Mobile.ViewModel"
             xmlns:cv="clr-namespace:LotteryDetection.Mobile.Converters"
             xmlns:models="clr-namespace:LotteryDetection.Mobile.Models.Lottery"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             ios:Page.UseSafeArea="True"
             x:Class="LotteryDetection.Mobile.Views.LotteryCapture.LotteryCapturePage"
             x:DataType="viewModel:LotteryCaptureViewModel"
             Title="Dò vé số"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFBF6">

    <ContentPage.Resources>
        <ResourceDictionary>
            <cv:InvertBoolConverter x:Key="InvertBool" />
            <cv:IsNotNullConverter x:Key="IsNotNull" />
            <cv:BoolToObjectConverter x:Key="BoolToObject" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top bar with Back Button and Mini Lucky Mascot -->
        <Grid Grid.Row="0"
              Padding="20,8,20,12"
              ColumnDefinitions="Auto,*,Auto">
            <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" StrokeThickness="0" BackgroundColor="#E9EFE4" HorizontalOptions="Start" VerticalOptions="Center">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Radius="6" Offset="0,2" Opacity="0.05" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Border.GestureRecognizers>
                <Label Text="‹" FontSize="26" FontAttributes="Bold" TextColor="#173D2A" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-2,0,0" />
            </Border>
            <Label Grid.Column="1"
                   Text="DÒ VÉ SỐ AI"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                   CharacterSpacing="1.2"
                   TextColor="#031649" />
            <Border Grid.Column="2" WidthRequest="42" HeightRequest="42" StrokeThickness="1.5" Stroke="#F5C842" BackgroundColor="White" HorizontalOptions="End" VerticalOptions="Center">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="21" /></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#031649" Radius="8" Offset="0,3" Opacity="0.1" />
                </Border.Shadow>
                <Image Source="lucky_mascot.png" Aspect="AspectFill" Margin="1.5" />
            </Border>
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1" Padding="0">
            <VerticalStackLayout Padding="20,10,20,8" Spacing="16">

                <!-- Hero copy -->
                <VerticalStackLayout Spacing="6">
                    <Label FontFamily="Geist" FontSize="26" FontAttributes="Bold"
                           LineHeight="1.15" TextColor="#031649">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Chụp Ảnh Vé Số " />
                                <Span Text="&#10;Thần Tài " TextColor="#00bb77" />
                                <Span Text="Dò Giúp Bạn! 🔮" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label Text="Công nghệ AI đọc chuẩn xác dãy số, ngày quay, đài phát hành và rước lộc cát tường về cho bạn liền tay!"
                           FontFamily="Geist" FontSize="13" LineHeight="1.45"
                           TextColor="#66736A" />
                </VerticalStackLayout>

                <!-- Capture zone with High-End Golden Scanner Overlay -->
                <Border x:Name="CaptureFrame"
                        StrokeThickness="0"
                        Padding="8">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="28" />
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#031649" Offset="0.0" />
                            <GradientStop Color="#00bb77" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#031649" Offset="0,12" Radius="24" Opacity="0.25" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CaptureCommand}" />
                    </Border.GestureRecognizers>

                    <Border Stroke="Transparent"
                            StrokeThickness="0"
                            BackgroundColor="#183827"
                            Padding="0"
                            HeightRequest="320">
                        <Border.StrokeShape>
                            <shapes:RoundRectangle CornerRadius="22" />
                        </Border.StrokeShape>
                        <Grid>
                            <!-- Loaded image -->
                            <Image Source="{Binding ImageSource}"
                                   Aspect="AspectFill"
                                   IsVisible="{Binding HasImage}" />

                            <!-- Golden Focused Camera Corners (4 Góc mạ vàng lấy nét cao cấp) -->
                            <Grid IsVisible="{Binding HasImage, Converter={StaticResource InvertBool}}" InputTransparent="True">
                                <!-- Top-Left Corner -->
                                <BoxView WidthRequest="20" HeightRequest="4" BackgroundColor="#F5C842" HorizontalOptions="Start" VerticalOptions="Start" Margin="14,14,0,0" />
                                <BoxView WidthRequest="4" HeightRequest="20" BackgroundColor="#F5C842" HorizontalOptions="Start" VerticalOptions="Start" Margin="14,14,0,0" />

                                <!-- Top-Right Corner -->
                                <BoxView WidthRequest="20" HeightRequest="4" BackgroundColor="#F5C842" HorizontalOptions="End" VerticalOptions="Start" Margin="0,14,14,0" />
                                <BoxView WidthRequest="4" HeightRequest="20" BackgroundColor="#F5C842" HorizontalOptions="End" VerticalOptions="Start" Margin="0,14,14,0" />

                                <!-- Bottom-Left Corner -->
                                <BoxView WidthRequest="20" HeightRequest="4" BackgroundColor="#F5C842" HorizontalOptions="Start" VerticalOptions="End" Margin="14,0,0,14" />
                                <BoxView WidthRequest="4" HeightRequest="20" BackgroundColor="#F5C842" HorizontalOptions="Start" VerticalOptions="End" Margin="14,0,0,14" />

                                <!-- Bottom-Right Corner -->
                                <BoxView WidthRequest="20" HeightRequest="4" BackgroundColor="#F5C842" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,14,14" />
                                <BoxView WidthRequest="4" HeightRequest="20" BackgroundColor="#F5C842" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,14,14" />
                            </Grid>

                            <!-- Laser Scanner Line (Tia laser mạ vàng quét qua quét lại) -->
                            <BoxView x:Name="LaserLine"
                                     HeightRequest="2.5"
                                     BackgroundColor="#F5C842"
                                     HorizontalOptions="Fill"
                                     VerticalOptions="Start"
                                     TranslationY="0"
                                     InputTransparent="True"
                                     IsVisible="{Binding ShowEmptyState, Converter={StaticResource InvertBool}}">
                                <BoxView.Shadow>
                                    <Shadow Brush="#F5C842" Radius="12" Offset="0,0" Opacity="0.9" />
                                </BoxView.Shadow>
                            </BoxView>

                            <!-- Empty state with Glow Lucky Mascot -->
                            <VerticalStackLayout Spacing="14"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 IsVisible="{Binding ShowEmptyState}">
                                <Border WidthRequest="96" HeightRequest="96"
                                        Stroke="#F5C842"
                                        StrokeThickness="2.5"
                                        BackgroundColor="White"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <shapes:RoundRectangle CornerRadius="48" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#F5C842" Offset="0,4" Radius="18" Opacity="0.3" />
                                    </Border.Shadow>
                                    <Image Source="lucky_mascot.png" Aspect="AspectFill" Margin="2" />
                                </Border>
                                <Label Text="Thần Tài Đợi Vé..."
                                       FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="White" />
                                <Label Text="Chạm vào đây hoặc dùng nút bên dưới để chụp/chọn ảnh vé số."
                                       FontFamily="Geist" FontSize="13" LineHeight="1.45"
                                       MaximumWidthRequest="240"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#CFE6D5" />
                            </VerticalStackLayout>

                            <!-- Analyzing overlay -->
                            <Border IsVisible="{Binding IsAnalyzing}"
                                    BackgroundColor="#CC0F2419"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <shapes:RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="12"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">
                                    <ActivityIndicator IsRunning="{Binding IsAnalyzing}"
                                                       Color="#F5C842"
                                                       HeightRequest="44" WidthRequest="44" />
                                    <Label Text="AI đang đọc dãy số…"
                                           FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Retake chip (top-right when image loaded) -->
                            <Button Text="✕"
                                    Command="{Binding RetakeCommand}"
                                    IsVisible="{Binding HasImage}"
                                    HorizontalOptions="End" VerticalOptions="Start"
                                    Margin="0,14,14,0"
                                    WidthRequest="34" HeightRequest="34"
                                    Padding="0" CornerRadius="17"
                                    FontSize="14"
                                    BackgroundColor="#CC10281D"
                                    TextColor="White" />
                        </Grid>
                    </Border>
                </Border>

                <!-- Status badge -->
                <Label Text="{Binding StatusBadge}"
                       FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                       CharacterSpacing="0.04"
                       TextTransform="Uppercase"
                       HorizontalOptions="Center"
                       TextColor="#00bb77" />

                <Label Text="{Binding StatusHint}"
                       FontFamily="Geist" FontSize="13" LineHeight="1.45"
                       HorizontalTextAlignment="Center"
                       Margin="20,-8,20,0"
                       TextColor="#66736A" />

                <!-- Permission notice -->
                <Border IsVisible="{Binding ShowPermissionNotice}"
                        Padding="14"
                        StrokeThickness="1"
                        Stroke="#E7DBA0"
                        BackgroundColor="#FFF4C9">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Cần quyền camera"
                                   FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                   TextColor="#031649" />
                            <Label Text="Bật camera để chụp vé số trực tiếp, hoặc chọn ảnh sẵn có từ thư viện."
                                   FontFamily="Geist" FontSize="12" LineHeight="1.4"
                                   TextColor="#66736A" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Bật camera"
                                Command="{Binding RequestCameraPermissionCommand}"
                                CornerRadius="12"
                                HeightRequest="38"
                                Padding="12,0"
                                FontFamily="Geist" FontAttributes="Bold" FontSize="12"
                                BackgroundColor="#031649"
                                TextColor="White" />
                    </Grid>
                </Border>

                <!-- Capture / Pick buttons with Modern Styles -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,0">
                    <Button Grid.Column="0"
                            Text="🖼️ Chọn Từ Thư Viện"
                            Command="{Binding PickFromGalleryCommand}"
                            IsEnabled="{Binding CanCaptureOrPick}"
                            HeightRequest="54"
                            CornerRadius="18"
                            FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                            BackgroundColor="#E9EFE4"
                            TextColor="#031649">
                        <Button.Shadow>
                            <Shadow Brush="#000000" Radius="6" Offset="0,3" Opacity="0.05" />
                        </Button.Shadow>
                    </Button>
                    <Button Grid.Column="1"
                            Text="📸 Chụp Vé Mới"
                            Command="{Binding CaptureCommand}"
                            IsEnabled="{Binding CanCaptureOrPick}"
                            HeightRequest="54"
                            CornerRadius="18"
                            FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                            BackgroundColor="#00bb77"
                            TextColor="White">
                        <Button.Shadow>
                            <Shadow Brush="#00bb77" Radius="8" Offset="0,4" Opacity="0.15" />
                        </Button.Shadow>
                    </Button>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom CTA with Pulse Loop -->
        <Grid Grid.Row="2"
              Padding="20,12,20,30">
            <Button x:Name="AnalyzeButton"
                    Text="🔮 AI DÒ VÉ SỐ NGAY"
                    Command="{Binding AnalyzeCommand}"
                    IsEnabled="{Binding CanAnalyze}"
                    HeightRequest="58"
                    CornerRadius="19"
                    FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                    BackgroundColor="#F5C842"
                    TextColor="#031649">
                <Button.Shadow>
                    <Shadow Brush="#F5C842" Radius="12" Offset="0,6" Opacity="0.25" />
                </Button.Shadow>
            </Button>
        </Grid>

        <!-- Result modal (bottom sheet) -->
        <Grid IsVisible="{Binding ShowPreviewModal}"
              BackgroundColor="#BB000000"
              Grid.Row="0"
              Grid.RowSpan="3"
              InputTransparent="False">
            <Grid RowDefinitions="*,Auto">

                <!-- Scrim tap area -->
                <Grid Grid.Row="0" BackgroundColor="Transparent">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RetakeCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Sheet card -->
                <Border Grid.Row="1"
                        StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="28,28,0,0" /></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,-6" Radius="24" Opacity="0.18" />
                    </Border.Shadow>

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">

                        <!-- Drag handle -->
                        <BoxView Grid.Row="0"
                                 WidthRequest="40" HeightRequest="4" CornerRadius="2"
                                 BackgroundColor="#D1D5DB"
                                 HorizontalOptions="Center"
                                 Margin="0,14,0,0" />

                        <!-- Header -->
                        <Grid Grid.Row="1"
                              Padding="20,14,20,4"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10">
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    StrokeThickness="0"
                                    BackgroundColor="#FFF4C9">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                <Label Text="✨" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="Kết quả AI dò vé"
                                       FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                                       TextColor="#031649" />
                                <Label Text="{Binding Results.Count, StringFormat='Tìm thấy {0} vé số'}"
                                       FontFamily="GeistMono" FontSize="11"
                                       TextColor="#66736A" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2"
                                    Text="✕"
                                    Command="{Binding RetakeCommand}"
                                    WidthRequest="34" HeightRequest="34"
                                    Padding="0" CornerRadius="17"
                                    FontSize="14"
                                    BackgroundColor="#E9EFE4"
                                    TextColor="#031649" />
                        </Grid>

                        <!-- Content (List of Tickets) -->
                        <CollectionView Grid.Row="2" 
                                        ItemsSource="{Binding Results}"
                                        Margin="0,10,0,0"
                                        MaximumHeightRequest="460">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:LotteryTicketResult">
                                    <VerticalStackLayout Padding="20,0,20,16" Spacing="12">
                                        <!-- Ticket number card -->
                                        <Border Padding="18" StrokeThickness="1"
                                                Stroke="#DAE5D6"
                                                BackgroundColor="White">
                                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                                            <VerticalStackLayout Spacing="10">
                                                <Label Text="DÃY SỐ AI ĐỌC ĐƯỢC"
                                                       FontFamily="Geist" FontSize="10.5" FontAttributes="Bold"
                                                       CharacterSpacing="0.06"
                                                       TextColor="#00bb77" />
                                                <Label Text="{Binding TicketNumber}"
                                                       FontFamily="GeistMono" FontSize="32" FontAttributes="Bold"
                                                       CharacterSpacing="4"
                                                       TextColor="#031649" />

                                                <BoxView HeightRequest="1" BackgroundColor="#E5EDE2" />

                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                        <Label Text="Đài quay"
                                                               FontFamily="Geist" FontSize="11"
                                                               TextColor="#66736A" />
                                                        <Label Text="{Binding Province}"
                                                               FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                                               TextColor="#031649" />
                                                    </VerticalStackLayout>
                                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                        <Label Text="Ngày quay"
                                                               FontFamily="Geist" FontSize="11"
                                                               TextColor="#66736A" />
                                                        <Label Text="{Binding DrawDateDisplay}"
                                                               FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                                               TextColor="#031649" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Border>

                                        <!-- Prize banner -->
                                        <Border Padding="18" StrokeThickness="0"
                                                BackgroundColor="{Binding IsWinner, Converter={StaticResource BoolToObject}, ConverterParameter='#F5C842|#E5E8E5'}">
                                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                                            <VerticalStackLayout Spacing="6">
                                                <Label Text="{Binding ResultHeadline}"
                                                       FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                                                       LineHeight="1.25"
                                                       TextColor="#031649" />
                                                <Label Text="{Binding PrizeAmountDisplay}"
                                                       IsVisible="{Binding IsWinner}"
                                                       FontFamily="Geist" FontSize="24" FontAttributes="Bold"
                                                       TextColor="#00bb77" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <!-- Notes -->
                                        <Border Padding="14" StrokeThickness="1"
                                                Stroke="#DAE5D6"
                                                BackgroundColor="White">
                                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                            <VerticalStackLayout Spacing="6">
                                                <Label Text="Ghi chú từ AI"
                                                       FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                                       TextColor="#031649" />
                                                <Label Text="{Binding Notes}"
                                                       FontFamily="Geist" FontSize="13" LineHeight="1.4"
                                                       TextColor="#66736A" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Bottom actions -->
                        <Grid Grid.Row="3"
                              Padding="20,12,20,32"
                              ColumnDefinitions="*,1.4*"
                              ColumnSpacing="12">
                            <Button Text="Chụp lại"
                                    Command="{Binding RetakeCommand}"
                                    HeightRequest="54"
                                    CornerRadius="18"
                                    FontFamily="Geist" FontAttributes="Bold" FontSize="15"
                                    BackgroundColor="#E9EFE4"
                                    TextColor="#031649" />
                            <Button Grid.Column="1"
                                    Text="💾 Lưu Lịch Sử"
                                    Command="{Binding ConfirmCommand}"
                                    HeightRequest="54"
                                    CornerRadius="18"
                                    FontFamily="Geist" FontAttributes="Bold" FontSize="15"
                                    BackgroundColor="#031649"
                                    TextColor="White">
                                <Button.Shadow>
                                    <Shadow Brush="#031649" Radius="8" Offset="0,4" Opacity="0.15" />
                                </Button.Shadow>
                            </Button>
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </Grid>

    </Grid>
</ContentPage>
