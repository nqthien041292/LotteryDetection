<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:LotteryDetection.Mobile.Views.Components"
             xmlns:viewModel="clr-namespace:LotteryDetection.Mobile.ViewModel"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="LotteryDetection.Mobile.Views.Family.TaskDetailPage"
             x:DataType="viewModel:TaskDetailViewModel"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCreamDark}}">
    <ContentPage.BindingContext>
        <viewModel:TaskDetailViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto,Auto">
        <!-- Top bar -->
        <Grid Grid.Row="0"
              Padding="20,40,20,10"
              ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0"
                    Text="←"
                    FontSize="20"
                    WidthRequest="36" HeightRequest="36"
                    Padding="0" CornerRadius="10"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1"
                   Text="Review task"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="17" FontAttributes="Bold"
                   CharacterSpacing="-0.01"
                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
            <BoxView Grid.Column="2" WidthRequest="36" HeightRequest="36" BackgroundColor="Transparent" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="0">
            <VerticalStackLayout Padding="20,8,20,4" Spacing="14">
                <!-- Main draft card -->
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}"
                        Padding="0">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#1E5BFF" Offset="0,2" Radius="6" Opacity="0.05" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">
                        <!-- AI strip -->
                        <Grid Padding="16,10"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="8"
                              BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}">
                            <Label Grid.Column="0" Text="✨" FontSize="14" VerticalOptions="Center" TextColor="White" />
                            <Label Grid.Column="1" Text="Drafted from your voice note"
                                   FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                                   CharacterSpacing="0.01"
                                   TextColor="White" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="0.4s"
                                   FontFamily="GeistMono" FontSize="10.5" Opacity="0.7"
                                   TextColor="White" VerticalOptions="Center" />
                        </Grid>

                        <!-- Body -->
                        <VerticalStackLayout Padding="20,18" Spacing="0">
                            <!-- Title view / edit -->
                            <Label x:Name="TitleLabel"
                                   Text="{Binding Task.Title, TargetNullValue='—'}"
                                   FontFamily="Geist" FontSize="20" FontAttributes="Bold"
                                   LineHeight="1.25" CharacterSpacing="-0.02"
                                   Margin="0,0,0,14"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                            <Entry x:Name="TitleEntry"
                                   Text="{Binding EditTitle}"
                                   Placeholder="Title"
                                   IsVisible="False" FontSize="20"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />

                            <!-- Field rows -->
                            <Grid ColumnDefinitions="Auto,*"
                                  Padding="0,10"
                                  ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Owner"
                                       FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                <HorizontalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End" VerticalOptions="Center">
                                    <components:FamilyAvatar Member="{Binding AssigneeMemberId}" Name="{Binding AssigneeInitial}" Size="22" />
                                    <Label x:Name="AssigneeLabel"
                                           Text="{Binding Task.Assignee, TargetNullValue='Unassigned'}"
                                           FontFamily="Geist" FontSize="13.5" FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                    <Entry x:Name="AssigneeEntry"
                                           Text="{Binding EditAssignee}"
                                           Placeholder="Assignee"
                                           IsVisible="False" />
                                </HorizontalStackLayout>
                            </Grid>
                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}" />

                            <Grid ColumnDefinitions="Auto,*"
                                  Padding="0,10"
                                  ColumnSpacing="10">
                                <Label Grid.Column="0" Text="When"
                                       FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                <Label x:Name="DueDateLabel" Grid.Column="1"
                                       Text="{Binding Task.DueDateFormatted, TargetNullValue='No due date'}"
                                       FontFamily="Geist" FontSize="13.5"
                                       HorizontalOptions="End" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Entry x:Name="DueDateEntry" Grid.Column="1"
                                       Text="{Binding EditDueDateTime}"
                                       Placeholder="Due"
                                       IsVisible="False" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}" />

                            <Grid ColumnDefinitions="Auto,*"
                                  Padding="0,10"
                                  ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Priority"
                                       FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                <components:FamilyChip x:Name="PriorityChip" Grid.Column="1"
                                                       Text="Medium"
                                                       ChipColor="med"
                                                       HorizontalOptions="End" VerticalOptions="Center" />
                                <Entry x:Name="PriorityEntry" Grid.Column="1"
                                       Text="{Binding EditPriority}"
                                       Placeholder="Priority"
                                       IsVisible="False" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}" />

                            <Grid ColumnDefinitions="Auto,*"
                                  Padding="0,10"
                                  ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Category"
                                       FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                <components:FamilyChip Grid.Column="1"
                                                       Text="{Binding Task.Category, TargetNullValue='—'}"
                                                       ChipColor="primary"
                                                       HorizontalOptions="End" VerticalOptions="Center" />
                                <Entry x:Name="CategoryEntry" Grid.Column="1"
                                       Text="{Binding EditCategory}"
                                       Placeholder="Category"
                                       IsVisible="False" />
                            </Grid>

                            <!-- Location (hidden unless present) -->
                            <Label x:Name="LocationLabel"
                                   Text="{Binding Task.Location, StringFormat='Location: {0}'}"
                                   FontFamily="Geist" FontSize="12"
                                   IsVisible="False"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            <Entry x:Name="LocationEntry"
                                   Text="{Binding EditLocation}"
                                   Placeholder="Location"
                                   IsVisible="False" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- AI suggestion panel (hidden until ViewModel surfaces real data) -->
                <Border IsVisible="{Binding HasAiSuggestion}"
                        Padding="14,12"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Grid.Column="0" Text="✨" FontSize="16" VerticalOptions="Start" Margin="0,1,0,0"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                        <Label Grid.Column="1"
                               FontFamily="Geist" FontSize="12.5" LineHeight="1.5"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding AiSuggestionTitle, StringFormat='{0} '}" FontAttributes="Bold" />
                                    <Span Text="{Binding AiSuggestionDescription}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Button Grid.Column="2" Text="Apply"
                                BackgroundColor="Transparent" BorderWidth="0" Padding="0"
                                FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                    </Grid>
                </Border>

                <!-- Notes card -->
                <Border x:Name="NotesCard"
                        Padding="14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}"
                        IsVisible="False">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Notes"
                               FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                        <Label x:Name="NotesLabel"
                               Text="{Binding Task.Notes}"
                               FontFamily="Geist" FontSize="13"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                        <Editor x:Name="NotesEditor"
                                Text="{Binding EditNotes}"
                                Placeholder="Notes"
                                IsVisible="False"
                                AutoSize="TextChanges" MinimumHeightRequest="80" />
                    </VerticalStackLayout>
                </Border>

                <!-- Transcript card -->
                <Border x:Name="TranscriptCard"
                        Padding="14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}"
                        IsVisible="False">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Voice transcript"
                               FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                        <Label Text="{Binding Task.Transcript}"
                               FontFamily="Geist" FontSize="13"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Edit / Save / Delete actions (shown only when in detail mode) -->
                <VerticalStackLayout Spacing="10">
                    <Button x:Name="EditButton"
                            Text="Edit task"
                            Command="{Binding EditCommand}"
                            HeightRequest="48"
                            CornerRadius="12"
                            FontFamily="Geist" FontAttributes="Bold" FontSize="14"
                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}"
                            TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                    <Grid x:Name="EditActions" IsVisible="False"
                          ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Cancel"
                                Command="{Binding CancelEditCommand}"
                                HeightRequest="48" CornerRadius="12"
                                FontFamily="Geist" FontAttributes="Bold"
                                BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}"
                                TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                        <Button x:Name="SaveButton" Grid.Column="1" Text="Save"
                                Command="{Binding SaveCommand}"
                                HeightRequest="48" CornerRadius="12"
                                FontFamily="Geist" FontAttributes="Bold"
                                BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                                TextColor="White">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsSaving}" Value="True">
                                    <Setter Property="Text" Value="Saving…" />
                                    <Setter Property="Opacity" Value="0.7" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>
                    <Border x:Name="CompletedBanner" Padding="12" StrokeThickness="0"
                            IsVisible="{Binding IsCompleted}"
                            BackgroundColor="#E6F7EE">
                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Label Text="Task completed"
                               HorizontalOptions="Center"
                               FontFamily="Geist" FontAttributes="Bold" TextColor="#0F8A4F" />
                    </Border>
                    <Button x:Name="CompleteButton" Text="Mark complete"
                            Command="{Binding CompleteTaskCommand}"
                            HeightRequest="48" CornerRadius="12"
                            FontFamily="Geist" FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilySuccessLight}, Dark={DynamicResource FamilySuccessDark}}"
                            TextColor="White">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsCompleting}" Value="True">
                                <Setter Property="Text" Value="Completing…" />
                                <Setter Property="Opacity" Value="0.7" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button x:Name="DeleteButton" Text="Delete task"
                            Command="{Binding DeleteCommand}"
                            HeightRequest="48" CornerRadius="12"
                            FontFamily="Geist" FontAttributes="Bold"
                            BackgroundColor="#FFE9E1" TextColor="#B91C1C">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsDeleting}" Value="True">
                                <Setter Property="Text" Value="Deleting…" />
                                <Setter Property="Opacity" Value="0.7" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Label x:Name="ErrorLabel" Text="{Binding ErrorMessage}"
                           IsVisible="False"
                           HorizontalOptions="Center"
                           FontFamily="Geist" FontSize="12"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyDangerLight}, Dark={DynamicResource FamilyDangerDark}}" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom: New recording / Add to board -->
        <Grid Grid.Row="2"
              Padding="20,12,20,16"
              ColumnDefinitions="*,1.3*"
              ColumnSpacing="10">
            <Button Grid.Column="0"
                    Text="New recording"
                    HeightRequest="56"
                    CornerRadius="14"
                    FontFamily="Geist" FontAttributes="Bold" FontSize="14"
                    Clicked="OnNewRecordingClicked"
                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
            <Button x:Name="AddToBoardButton"
                    Grid.Column="1"
                    Text="Add to board"
                    HeightRequest="56"
                    CornerRadius="14"
                    FontFamily="Geist" FontAttributes="Bold" FontSize="14"
                    Clicked="OnAddToBoardClicked"
                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                    TextColor="White">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsAddingToBoard}" Value="True">
                        <Setter Property="Text" Value="Adding…" />
                        <Setter Property="Opacity" Value="0.7" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <components:BottomBarView Grid.Row="3"
                                  x:Name="BottomBar"
                                  TabSelected="OnTabSelected" />

        <!-- Loading skeleton overlay (sits on top of ScrollView while initial data loads) -->
        <Grid Grid.Row="1"
              IsVisible="{Binding ShowSkeleton}"
              BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCreamDark}}"
              Padding="20,8,20,4">
            <components:TaskDetailSkeleton />
        </Grid>
    </Grid>
</ContentPage>
