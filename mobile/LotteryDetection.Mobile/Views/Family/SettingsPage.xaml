<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:LotteryDetection.Mobile.Views.Components"
             xmlns:viewModel="clr-namespace:LotteryDetection.Mobile.ViewModel"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="LotteryDetection.Mobile.Views.Family.SettingsPage"
             x:DataType="viewModel:SettingsViewModel"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCreamDark}}">
    <ContentPage.BindingContext>
        <viewModel:SettingsViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Top bar -->
        <Grid Grid.Row="0" Padding="20,40,20,4" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Text="←"
                    FontSize="20"
                    WidthRequest="36" HeightRequest="36"
                    Padding="0" CornerRadius="10"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1" Text="Settings"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="17" FontAttributes="Bold"
                   CharacterSpacing="-0.01"
                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
            <BoxView Grid.Column="2" WidthRequest="36" HeightRequest="36" BackgroundColor="Transparent" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="0">
            <VerticalStackLayout Padding="16,8,16,8" Spacing="0">
                <!-- Hero user card -->
                <Border Padding="14"
                        StrokeThickness="0"
                        Margin="0,8,0,0">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E5BFF" Offset="0" />
                            <GradientStop Color="#2D6CFF" Offset="0.6" />
                            <GradientStop Color="#6D5BD0" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#1E5BFF" Offset="0,6" Radius="18" Opacity="0.22" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                        <Border Grid.Column="0" WidthRequest="48" HeightRequest="48"
                                BackgroundColor="#38FFFFFF"
                                Stroke="#59FFFFFF" StrokeThickness="1">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                            <Label Text="A" TextColor="White"
                                   FontFamily="Geist" FontSize="20" FontAttributes="Bold" CharacterSpacing="-0.02"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding UserName}"
                                   FontFamily="Geist" FontSize="15" FontAttributes="Bold" CharacterSpacing="-0.01"
                                   TextColor="White" />
                            <Label Text="{Binding UserEmail}"
                                   FontFamily="Geist" FontSize="11.5" Opacity="0.85"
                                   TextColor="White" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2"
                                Text="Edit"
                                Command="{Binding EditUserNameCommand}"
                                HeightRequest="32" Padding="12,0" CornerRadius="8"
                                FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                                BackgroundColor="#33FFFFFF"
                                BorderColor="#4DFFFFFF" BorderWidth="1"
                                TextColor="White" />
                    </Grid>
                </Border>

                <!-- Family · members -->
                <Label Text="FAMILY · 4 MEMBERS" Style="{StaticResource FamilyEyebrowStyle}"
                       Margin="4,20,0,8"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout>
                        <!-- Bound member list — isolated so BindableLayout doesn't wipe sibling rows -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Members}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModel:SettingsMember">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="12"
                                          Padding="14,12">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="BackgroundColor" Value="Transparent" />
                                            </Style>
                                        </Grid.Style>
                                        <components:FamilyAvatar Grid.Column="0"
                                                                 Member="{Binding Id}"
                                                                 Name="{Binding Name}"
                                                                 Size="40" VerticalOptions="Center" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding Name}"
                                                       FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                                <Border IsVisible="{Binding HasBadge}" Padding="5,1" StrokeThickness="0"
                                                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}">
                                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                                                    <Label Text="{Binding Badge}"
                                                           FontFamily="Geist" FontSize="9.5" FontAttributes="Bold" CharacterSpacing="0.04"
                                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                                                </Border>
                                            </HorizontalStackLayout>
                                            <Label Text="{Binding Subtitle}"
                                                   FontFamily="Geist" FontSize="11.5"
                                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="›"
                                               FontFamily="Geist" FontSize="20"
                                               VerticalOptions="Center"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />

                        <!-- Invite someone -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12"
                              Padding="14,12">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnInviteClicked" />
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0" WidthRequest="30" HeightRequest="30"
                                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}"
                                    StrokeThickness="0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                <Label Text="+"
                                       FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                                       HorizontalOptions="Center" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Invite someone"
                                       FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="Send an invite link to add a member"
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontFamily="Geist" FontSize="20"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />

                        <!-- Family & Roles → AdminRoleManagementPage -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12"
                              Padding="14,12">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAdminClicked" />
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0" WidthRequest="30" HeightRequest="30"
                                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}"
                                    StrokeThickness="0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                <components:VectorIcon Glyph="home"
                                       Size="16"
                                       HorizontalOptions="Center" VerticalOptions="Center"
                                       Color="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Family &amp; roles"
                                       FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="Promote, demote, or remove members"
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontFamily="Geist" FontSize="20"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- AI assistant -->
                <Label Text="AI ASSISTANT" Style="{StaticResource FamilyEyebrowStyle}"
                       Margin="4,20,0,8"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout>
                        <VerticalStackLayout Padding="14,14,14,12" Spacing="10">
                            <Label Text="How should DoVeSo AI sound when it talks to you?"
                                   FontFamily="Geist" FontSize="12.5" LineHeight="1.4"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                <Button Grid.Column="0"
                                        Padding="10,12" CornerRadius="10" BorderWidth="2"
                                        FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                        Command="{Binding SetPersonaCommand}" CommandParameter="warm">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsPersonaWarm}" Value="True">
                                            <Setter Property="Text" Value="Warm" />
                                            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource FamilyPrimaryLight}, Dark={StaticResource FamilyPrimaryDark}}" />
                                            <Setter Property="BackgroundColor" Value="White" />
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource FamilyPrimaryLight}, Dark={StaticResource FamilyPrimaryDark}}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsPersonaWarm}" Value="False">
                                            <Setter Property="Text" Value="Warm" />
                                            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource FamilyCream3Light}, Dark={StaticResource FamilyCream3Dark}}" />
                                            <Setter Property="BackgroundColor" Value="Transparent" />
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource FamilyInk2Light}, Dark={StaticResource FamilyInk2Dark}}" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Button Grid.Column="1"
                                        Padding="10,12" CornerRadius="10" BorderWidth="2"
                                        FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                        Command="{Binding SetPersonaCommand}" CommandParameter="direct">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsPersonaDirect}" Value="True">
                                            <Setter Property="Text" Value="Direct" />
                                            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource FamilyPrimaryLight}, Dark={StaticResource FamilyPrimaryDark}}" />
                                            <Setter Property="BackgroundColor" Value="White" />
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource FamilyPrimaryLight}, Dark={StaticResource FamilyPrimaryDark}}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsPersonaDirect}" Value="False">
                                            <Setter Property="Text" Value="Direct" />
                                            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource FamilyCream3Light}, Dark={StaticResource FamilyCream3Dark}}" />
                                            <Setter Property="BackgroundColor" Value="Transparent" />
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource FamilyInk2Light}, Dark={StaticResource FamilyInk2Dark}}" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Button Grid.Column="2"
                                        Padding="10,12" CornerRadius="10" BorderWidth="2"
                                        FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                        Command="{Binding SetPersonaCommand}" CommandParameter="playful">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsPersonaPlayful}" Value="True">
                                            <Setter Property="Text" Value="Playful" />
                                            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource FamilyPrimaryLight}, Dark={StaticResource FamilyPrimaryDark}}" />
                                            <Setter Property="BackgroundColor" Value="White" />
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource FamilyPrimaryLight}, Dark={StaticResource FamilyPrimaryDark}}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsPersonaPlayful}" Value="False">
                                            <Setter Property="Text" Value="Playful" />
                                            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource FamilyCream3Light}, Dark={StaticResource FamilyCream3Dark}}" />
                                            <Setter Property="BackgroundColor" Value="Transparent" />
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource FamilyInk2Light}, Dark={StaticResource FamilyInk2Dark}}" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </Grid>
                        </VerticalStackLayout>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Memory" FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="What the AI remembers about your family"
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="On"
                                   FontFamily="Geist" FontSize="13" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Suggestions" FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="Proactively surface tasks &amp; plans"
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="Daily"
                                   FontFamily="Geist" FontSize="13" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Voice -->
                <Label Text="VOICE" Style="{StaticResource FamilyEyebrowStyle}" Margin="4,20,0,8"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Wake word"
                                       FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text='Say "Hey Family" to start capture'
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding VoiceWake}"
                                    OnColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Auto-correct on send"
                                       FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="Confirm transcript before saving"
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding VoiceCorrect}"
                                    OnColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Notifications -->
                <Label Text="NOTIFICATIONS" Style="{StaticResource FamilyEyebrowStyle}" Margin="4,20,0,8"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Morning briefing"
                                       FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="7:00 AM · today's tasks &amp; schedule"
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding NotifMorning}"
                                    OnColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Task reminders"
                                       FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="15 min before due time"
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding NotifReminders}"
                                    OnColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Weekly family digest"
                                       FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="Sunday evening recap"
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding NotifDigest}"
                                    OnColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Connected accounts -->
                <Label Text="CONNECTED ACCOUNTS" Style="{StaticResource FamilyEyebrowStyle}" Margin="4,20,0,8"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0" WidthRequest="30" HeightRequest="30"
                                    BackgroundColor="#E8F0FE" StrokeThickness="0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                <Label Text="G" TextColor="#4285F4" FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Google Calendar" FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="alex@gmail.com · 2 calendars" FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="Connected" FontFamily="Geist" FontSize="13" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                        <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0" WidthRequest="30" HeightRequest="30"
                                    BackgroundColor="#E5F1FB" StrokeThickness="0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                <Label Text="O" TextColor="#0078D4" FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Outlook" FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="Connect work calendar" FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="Connect" FontFamily="Geist" FontSize="13" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Privacy & data -->
                <Label Text="PRIVACY &amp; DATA" Style="{StaticResource FamilyEyebrowStyle}" Margin="4,20,0,8"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="On-device processing"
                                       FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="Voice never leaves your phone"
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1" Padding="8,2" StrokeThickness="0" BackgroundColor="#D1FAE5" VerticalOptions="Center">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                <Label Text="ENABLED" FontFamily="Geist" FontSize="11" FontAttributes="Bold" CharacterSpacing="0.04"
                                       TextColor="#0F766E" />
                            </Border>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Share anonymous usage"
                                       FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="Help us improve the AI"
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding DataShare}"
                                    OnColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="Export family data" FontFamily="Geist" FontSize="14" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                            <Label Grid.Column="1" Text="›" FontFamily="Geist" FontSize="20" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="Delete account" FontFamily="Geist" FontSize="14" VerticalOptions="Center"
                                   TextColor="#B91C1C" />
                            <Label Grid.Column="1" Text="›" FontFamily="Geist" FontSize="20" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Appearance -->
                <Label Text="APPEARANCE &amp; REGION" Style="{StaticResource FamilyEyebrowStyle}" Margin="4,20,0,8"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Dark mode" FontFamily="Geist" FontSize="14"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="Match system" FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding DarkMode}"
                                    OnColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="Language" FontFamily="Geist" FontSize="14" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                            <Label Grid.Column="1" Text="English (US)" FontFamily="Geist" FontSize="13" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                        <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="Time zone" FontFamily="Geist" FontSize="14" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                            <Label Grid.Column="1" Text="Pacific" FontFamily="Geist" FontSize="13" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Plan -->
                <Label Text="PLAN" Style="{StaticResource FamilyEyebrowStyle}" Margin="4,20,0,8"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCream2Dark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <Grid Padding="14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" WidthRequest="36" HeightRequest="36"
                                StrokeThickness="0">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1E5BFF" Offset="0" />
                                    <GradientStop Color="#6D5BD0" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Text="★" FontSize="18" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding PlanName}"
                                   FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                            <Label Text="{Binding PlanRenewal}"
                                   FontFamily="Geist" FontSize="11.5"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2" Text="Manage"
                                HeightRequest="32" Padding="14,0" CornerRadius="8"
                                FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                                BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}"
                                TextColor="White" />
                    </Grid>
                </Border>

                <!-- Help & support -->
                <Label Text="HELP &amp; SUPPORT" Style="{StaticResource FamilyEyebrowStyle}" Margin="4,20,0,8"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHelpClicked" />
                        </Grid.GestureRecognizers>
                        <Border Grid.Column="0" WidthRequest="30" HeightRequest="30"
                                BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}"
                                StrokeThickness="0">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Label Text="?"
                                   FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Help &amp; FAQ"
                                   FontFamily="Geist" FontSize="14"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                            <Label Text="Tutorials, common questions, contact us"
                                   FontFamily="Geist" FontSize="11.5"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›"
                               FontFamily="Geist" FontSize="20"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                    </Grid>
                </Border>

                <!-- Sign out -->
                <Border StrokeThickness="1" Margin="0,20,0,0"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <Grid Padding="14,12" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Grid.Column="0" Text="Sign out" FontFamily="Geist" FontSize="14" VerticalOptions="Center"
                               TextColor="#B91C1C" />
                        <Label Grid.Column="1" Text="›" FontFamily="Geist" FontSize="20" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                    </Grid>
                </Border>

                <Label Text="FAMILY · AI · v2.4.1"
                       Margin="0,18,0,4"
                       FontFamily="GeistMono" FontSize="10.5" CharacterSpacing="0.05"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="#F8FAFC"
              Padding="16,8,16,8">
            <components:SettingsSkeleton />
        </Grid>

        <components:BottomBarView Grid.Row="2"
                                  x:Name="BottomBar"
                                  TabSelected="OnTabSelected" />
    </Grid>
</ContentPage>
