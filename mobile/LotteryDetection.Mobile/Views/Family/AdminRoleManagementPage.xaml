<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:LotteryDetection.Mobile.Views.Components"
             xmlns:viewModel="clr-namespace:LotteryDetection.Mobile.ViewModel"
             xmlns:family="clr-namespace:LotteryDetection.Mobile.Models.Family"
             x:Name="RolePage"
             x:Class="LotteryDetection.Mobile.Views.Family.AdminRoleManagementPage"
             x:DataType="viewModel:AdminRoleManagementViewModel"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCreamDark}}">
    <ContentPage.BindingContext>
        <viewModel:AdminRoleManagementViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0" RowDefinitions="Auto,*">

            <!-- Top bar with stacked title + admin sub-line -->
            <Grid Grid.Row="0"
                  Padding="20,48,20,8"
                  ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        FontSize="20"
                        WidthRequest="36" HeightRequest="36"
                        Padding="0" CornerRadius="10"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}"
                        Clicked="OnBackClicked" />
                <VerticalStackLayout Grid.Column="1"
                                     HorizontalOptions="Center" VerticalOptions="Center"
                                     Spacing="1">
                    <Label Text="Family &amp; roles"
                           HorizontalOptions="Center"
                           FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                           CharacterSpacing="-0.01"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                        <BoxView WidthRequest="5" HeightRequest="5"
                                 CornerRadius="3"
                                 BackgroundColor="#B45309"
                                 VerticalOptions="Center" />
                        <Label Text="{Binding AdminName}"
                               FontFamily="Geist" FontSize="10.5"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                <BoxView Grid.Column="2" WidthRequest="36" HeightRequest="36" BackgroundColor="Transparent" />
            </Grid>

            <!-- Scroll body -->
            <ScrollView Grid.Row="1" BackgroundColor="Transparent">
                <VerticalStackLayout Padding="16,8,16,20" Spacing="0">

                    <!-- Family hero card -->
                    <Border StrokeShape="RoundRectangle 16"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource FamilyPaperLight}, Dark={StaticResource FamilyPaperDark}}"
                            Padding="14"
                            Margin="0,0,0,14">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    WidthRequest="42" HeightRequest="42"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#FFD66B" />
                                        <GradientStop Offset="1" Color="#B45309" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <components:VectorIcon Glyph="home"
                                       Size="22"
                                       HorizontalOptions="Center" VerticalOptions="Center"
                                       Color="White" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding FamilyName}"
                                       FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                       CharacterSpacing="-0.005"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="{Binding MemberCountText}"
                                       FontFamily="Geist" FontSize="11.5"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="2"
                                    Padding="12,0"
                                    HeightRequest="30"
                                    VerticalOptions="Center"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding InviteMemberCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                                    <Label Text="+"
                                           FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           TextColor="White" />
                                    <Label Text="Invite"
                                           FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           TextColor="White" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- MEMBERS section label -->
                    <Label Text="MEMBERS"
                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="0.08"
                           Padding="4,0,0,0"
                           Margin="0,0,0,8"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />

                    <!-- Members list card -->
                    <Border StrokeShape="RoundRectangle 16"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource FamilyPaperLight}, Dark={StaticResource FamilyPaperDark}}"
                            Padding="0"
                            Margin="0,0,0,14">
                        <CollectionView ItemsSource="{Binding Members}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="family:FamilyMember">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid Padding="14,12"
                                              ColumnDefinitions="Auto,*,Auto,Auto"
                                              ColumnSpacing="10">

                                            <!-- Avatar with green online-dot overlay -->
                                            <Grid Grid.Column="0"
                                                  WidthRequest="40" HeightRequest="40"
                                                  VerticalOptions="Center">
                                                <components:FamilyAvatar Name="{Binding Name}"
                                                                          Member="{Binding Id}"
                                                                          Size="40" />
                                                <Border IsVisible="{Binding IsOnline}"
                                                        WidthRequest="11" HeightRequest="11"
                                                        HorizontalOptions="End" VerticalOptions="End"
                                                        Margin="0,0,-1,-1"
                                                        StrokeShape="RoundRectangle 6"
                                                        StrokeThickness="2"
                                                        Stroke="{AppThemeBinding Light={StaticResource FamilyPaperLight}, Dark={StaticResource FamilyPaperDark}}"
                                                        BackgroundColor="#22C55E" />
                                            </Grid>

                                            <!-- Info: name + YOU pill, then email · age N -->
                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center"
                                                                 Spacing="2">
                                                <HorizontalStackLayout Spacing="6">
                                                    <Label Text="{Binding Name}"
                                                           FontFamily="Geist" FontSize="13.5" FontAttributes="Bold"
                                                           CharacterSpacing="-0.005"
                                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                                    <Border IsVisible="{Binding IsYou}"
                                                            Padding="5,1"
                                                            StrokeShape="RoundRectangle 4"
                                                            StrokeThickness="0"
                                                            VerticalOptions="Center"
                                                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}">
                                                        <Label Text="YOU"
                                                               FontFamily="Geist" FontSize="9" FontAttributes="Bold"
                                                               CharacterSpacing="0.04"
                                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                                    </Border>
                                                </HorizontalStackLayout>
                                                <Label Text="{Binding Subtitle}"
                                                       FontFamily="Geist" FontSize="11"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                            </VerticalStackLayout>

                                            <!-- Role pill (tap → custom bottom-sheet picker) -->
                                            <components:RolePillPicker Grid.Column="2"
                                                                        Role="{Binding Role}"
                                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenRolePickerCommand}"
                                                                        CommandParameter="{Binding .}"
                                                                        VerticalOptions="Center" />

                                            <!-- Overflow -->
                                            <Button Grid.Column="3"
                                                    Text="⋯"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OverflowCommand}"
                                                    CommandParameter="{Binding .}"
                                                    WidthRequest="30" HeightRequest="30"
                                                    Padding="0" CornerRadius="8"
                                                    FontSize="16"
                                                    BackgroundColor="Transparent"
                                                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                        </Grid>
                                        <BoxView HeightRequest="1"
                                                 Margin="14,0"
                                                 BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                    <!-- PENDING section -->
                    <VerticalStackLayout IsVisible="{Binding HasPendingInvites}" Spacing="0">
                        <Label Text="PENDING"
                               FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                               CharacterSpacing="0.08"
                               Padding="4,0,0,0"
                               Margin="0,0,0,8"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />

                        <CollectionView ItemsSource="{Binding PendingInvites}" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="family:PendingInvite">
                                    <Border Padding="14"
                                            StrokeShape="RoundRectangle 14"
                                            StrokeThickness="1"
                                            StrokeDashArray="3,3"
                                            Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource FamilyPaperLight}, Dark={StaticResource FamilyPaperDark}}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Border Grid.Column="0"
                                                    WidthRequest="36" HeightRequest="36"
                                                    StrokeShape="RoundRectangle 18"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}">
                                                <Label Text="?"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center"
                                                                 Spacing="2">
                                                <Label Text="{Binding Email}"
                                                       FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                                       CharacterSpacing="-0.005"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}" />
                                                <Label Text="{Binding Subtitle}"
                                                       FontFamily="Geist" FontSize="11"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="2"
                                                    Padding="10,0"
                                                    HeightRequest="28"
                                                    VerticalOptions="Center"
                                                    StrokeShape="RoundRectangle 7"
                                                    StrokeThickness="1"
                                                    Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                                                    BackgroundColor="Transparent">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ResendInviteCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="Resend"
                                                       FontFamily="Geist" FontSize="11.5" FontAttributes="Bold"
                                                       VerticalOptions="Center"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!-- RECENT ACTIVITY section -->
                    <Label Text="RECENT ACTIVITY"
                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="0.08"
                           Padding="4,0,0,0"
                           Margin="0,14,0,8"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />

                    <Border StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource FamilyPaperLight}, Dark={StaticResource FamilyPaperDark}}"
                            Padding="0,4">
                        <CollectionView ItemsSource="{Binding AuditEntries}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="family:AuditEntry">
                                    <Grid Padding="14,10"
                                          ColumnDefinitions="Auto,*"
                                          ColumnSpacing="12">
                                        <Border Grid.Column="0"
                                                WidthRequest="26" HeightRequest="26"
                                                VerticalOptions="Center"
                                                StrokeShape="RoundRectangle 8"
                                                StrokeThickness="0"
                                                BackgroundColor="{Binding TintColor}">
                                            <Label Text="{Binding IconGlyph}"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="{Binding ForegroundColor}" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1"
                                                             VerticalOptions="Center"
                                                             Spacing="1">
                                            <Label Text="{Binding What}"
                                                   FontFamily="Geist" FontSize="12.5" FontAttributes="Bold"
                                                   LineHeight="1.3"
                                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                            <Label Text="{Binding Who}"
                                                   FontFamily="Courier" FontSize="10.5"
                                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <Grid Grid.Row="1"
                  IsVisible="{Binding IsLoading}"
                  BackgroundColor="#F8FAFC"
                  Padding="16,8,16,20">
                <components:AdminRolesSkeleton />
            </Grid>
        </Grid>

        <!-- Bottom nav -->
        <components:BottomBarView x:Name="BottomBar"
                                  Grid.Row="1"
                                  TabSelected="OnTabSelected" />

        <!-- Role picker bottom-sheet overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              IsVisible="{Binding IsRolePickerOpen}"
              BackgroundColor="#66061325"
              RowDefinitions="*,Auto">
            <BoxView Grid.Row="0"
                     BackgroundColor="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseRolePickerCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>
            <Border VerticalOptions="End"
                    Grid.Row="1"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource FamilyPaperLight}, Dark={StaticResource FamilyPaperDark}}"
                    Padding="16,16,16,32">
                <VerticalStackLayout Spacing="14">
                    <BoxView WidthRequest="36" HeightRequest="4"
                             CornerRadius="2"
                             HorizontalOptions="Center"
                             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                    <VerticalStackLayout Padding="4,0" Spacing="4">
                        <Label Text="Choose a role"
                               FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                               CharacterSpacing="-0.015"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                        <Label Text="{Binding PickerMemberName, StringFormat='For {0}'}"
                               FontFamily="Geist" FontSize="12"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8"
                                         BindableLayout.ItemsSource="{Binding RolePickerOptions}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="family:RoleOption">
                                <Grid Padding="0">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference RolePage}, Path=BindingContext.PickRoleCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Border Padding="14,12"
                                            StrokeShape="RoundRectangle 12"
                                            StrokeThickness="1"
                                            Stroke="Transparent"
                                            InputTransparent="True"
                                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsCurrent}" Value="True">
                                                <Setter Property="BackgroundColor"
                                                        Value="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}" />
                                                <Setter Property="Stroke"
                                                        Value="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                                                <Setter Property="StrokeThickness" Value="1.5" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Border Grid.Column="0"
                                                    WidthRequest="36" HeightRequest="36"
                                                    VerticalOptions="Center"
                                                    StrokeShape="RoundRectangle 10"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{Binding TintColor}">
                                                <Label Text="{Binding Initial}"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                                                       TextColor="{Binding ForegroundColor}" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center"
                                                                 Spacing="2">
                                                <Label Text="{Binding Label}"
                                                       FontFamily="Geist" FontSize="13.5" FontAttributes="Bold"
                                                       CharacterSpacing="-0.005"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                                <Label Text="{Binding Description}"
                                                       FontFamily="Geist" FontSize="11.5"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2"
                                                   Text="✓"
                                                   IsVisible="{Binding IsCurrent}"
                                                   FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Invite member bottom-sheet overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              IsVisible="{Binding IsInviteSheetOpen}"
              BackgroundColor="#66061325"
              RowDefinitions="*,Auto">
            <BoxView Grid.Row="0"
                     BackgroundColor="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseInviteSheetCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>
            <Border VerticalOptions="End"
                    Grid.Row="1"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource FamilyPaperLight}, Dark={StaticResource FamilyPaperDark}}"
                    Padding="16,16,16,32">
                <VerticalStackLayout Spacing="14">
                    <BoxView WidthRequest="36" HeightRequest="4"
                             CornerRadius="2"
                             HorizontalOptions="Center"
                             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}" />
                    <VerticalStackLayout Padding="4,0" Spacing="4">
                        <Label Text="Invite member"
                               FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                               CharacterSpacing="-0.015"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                        <Label Text="They'll get a link to sign in with their Microsoft account."
                               FontFamily="Geist" FontSize="12"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                    </VerticalStackLayout>

                    <!-- Email field -->
                    <Border StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}"
                            Padding="12,2">
                        <Entry Text="{Binding InviteEmail}"
                               Placeholder="name@email.com"
                               Keyboard="Email"
                               FontFamily="Geist" FontSize="13"
                               BackgroundColor="Transparent"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}"
                               PlaceholderColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                    </Border>

                    <Label Text="{Binding InviteError}"
                           IsVisible="{Binding HasInviteError}"
                           FontFamily="Geist" FontSize="11.5"
                           Margin="2,-8,0,0"
                           TextColor="#DC2626" />

                    <Label Text="ROLE"
                           FontFamily="Geist" FontSize="10.5" FontAttributes="Bold"
                           CharacterSpacing="0.08"
                           Padding="4,0,0,0"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />

                    <VerticalStackLayout Spacing="8"
                                         BindableLayout.ItemsSource="{Binding InviteRoleOptions}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="family:RoleOption">
                                <Grid Padding="0">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference RolePage}, Path=BindingContext.PickInviteRoleCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Border Padding="14,12"
                                            StrokeShape="RoundRectangle 12"
                                            StrokeThickness="1"
                                            Stroke="Transparent"
                                            InputTransparent="True"
                                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsCurrent}" Value="True">
                                                <Setter Property="BackgroundColor"
                                                        Value="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}" />
                                                <Setter Property="Stroke"
                                                        Value="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                                                <Setter Property="StrokeThickness" Value="1.5" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Border Grid.Column="0"
                                                    WidthRequest="36" HeightRequest="36"
                                                    VerticalOptions="Center"
                                                    StrokeShape="RoundRectangle 10"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{Binding TintColor}">
                                                <Label Text="{Binding Initial}"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                                                       TextColor="{Binding ForegroundColor}" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center"
                                                                 Spacing="2">
                                                <Label Text="{Binding Label}"
                                                       FontFamily="Geist" FontSize="13.5" FontAttributes="Bold"
                                                       CharacterSpacing="-0.005"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                                <Label Text="{Binding Description}"
                                                       FontFamily="Geist" FontSize="11.5"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2"
                                                   Text="✓"
                                                   IsVisible="{Binding IsCurrent}"
                                                   FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- Send invite button -->
                    <Border HeightRequest="46"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SendInviteCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="Send invite"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               FontFamily="Geist" FontSize="13.5" FontAttributes="Bold"
                               TextColor="White" />
                    </Border>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
