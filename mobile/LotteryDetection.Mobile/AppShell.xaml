<?xml version="1.0" encoding="UTF-8"?>

<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:onboarding="clr-namespace:LotteryDetection.Mobile.Views.OnBoarding"
       xmlns:forms="clr-namespace:LotteryDetection.Mobile.Views.Forms"
       xmlns:capture="clr-namespace:LotteryDetection.Mobile.Views.LotteryCapture"
       x:Class="LotteryDetection.Mobile.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.NavBarIsVisible="False"
       Shell.BackgroundColor="#F4F8FE"
       Shell.ForegroundColor="#1E5BFF"
       Shell.TitleColor="#172033"
       Shell.UnselectedColor="#9CA3AF"
       Shell.TabBarBackgroundColor="#FFFFFF"
       Shell.TabBarTitleColor="#1E5BFF"
       Shell.TabBarUnselectedColor="#9CA3AF">
    <ShellContent
        Route="SplashPage"
        ContentTemplate="{DataTemplate forms:SplashPage}" />
    <ShellContent
        Route="onboarding"
        ContentTemplate="{DataTemplate onboarding:OnboardingPage}" />
    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate forms:LoginPage}" />
    <ShellContent
        Route="LotteryCapturePage"
        ContentTemplate="{DataTemplate capture:LotteryCapturePage}" />
</Shell>
