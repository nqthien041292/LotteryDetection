<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>NSCameraUsageDescription</key>
	<string>DòXổSố AI needs camera access to capture lottery tickets.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>DòXổSố AI needs photo library access so you can select ticket images.</string>
	<!-- MSAL on iOS uses ASWebAuthenticationSession by default, but the
	     msauth.<bundleId> scheme must still be declared so the broker /
	     Microsoft Authenticator fallback path can call back into the app. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>msauth.com.lotterydetection.mobile</string>
			</array>
		</dict>
		<!-- Google sign-in callback. Replace with the reversed iOS client ID
		     from Google Cloud Console (Credentials → iOS OAuth client).
		     Format: com.googleusercontent.apps.<client-id-prefix> -->
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.134361125995-gn1dfrdtl7v9jgldbeq7dvh26kg105be</string>
			</array>
		</dict>
		<!-- Facebook sign-in callback. Replace REPLACE_WITH_FACEBOOK_APP_ID
		     with the numeric Facebook App ID, prefixed by "fb". -->
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>fb838658272624139</string>
			</array>
		</dict>
	</array>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>msauthv2</string>
		<string>msauthv3</string>
		<string>fbapi</string>
		<string>fb-messenger-share-api</string>
		<string>fbauth2</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
