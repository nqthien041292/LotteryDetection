<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LotteryDetectionMobile.Views.Components.AppDialogPage"
             x:Name="DialogRoot"
             BackgroundColor="Transparent"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">
    <!-- Tap outside the card cancels (only when CloseOnBackdrop=True). -->
    <Grid>
        <!-- Separate backdrop layer so we can fade it independently from the card. -->
        <BoxView x:Name="Backdrop"
                 Color="#000000"
                 Opacity="0" />
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnBackdropTapped" />
        </Grid.GestureRecognizers>

        <Border x:Name="Card"
                Opacity="0"
                Scale="0.85"
                StrokeThickness="0"
                Padding="28,24"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="300"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2D44}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,12" Radius="32" Opacity="0.22" />
            </Border.Shadow>
            <!-- Swallow taps so backdrop handler doesn't fire when interacting with the card. -->
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCardTapped" />
            </Border.GestureRecognizers>

            <VerticalStackLayout Spacing="16">
                <!-- Optional emoji/icon header -->
                <Border x:Name="IconHost"
                        WidthRequest="52" HeightRequest="52"
                        StrokeThickness="0"
                        BackgroundColor="#FEE2E2"
                        HorizontalOptions="Center"
                        IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Label x:Name="IconLabel" FontSize="24"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <!-- Title + message -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label x:Name="TitleLabel"
                           FontFamily="Geist" FontSize="17" FontAttributes="Bold"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark=White}" />
                    <Label x:Name="MessageLabel"
                           FontFamily="Geist" FontSize="13"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                           MaxLines="4" LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark=#9CA3AF}" />
                </VerticalStackLayout>

                <!-- Optional input field (prompt mode) -->
                <Border x:Name="InputHost"
                        StrokeThickness="0"
                        BackgroundColor="Transparent"
                        IsVisible="False">
                    <Entry x:Name="InputEntry"
                           FontFamily="Geist" FontSize="16"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark=White}"
                           PlaceholderColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark=#6B7280}" />
                </Border>

                <!-- Action buttons -->
                <Grid x:Name="ButtonRow"
                      ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                    <Button x:Name="CancelButton"
                            Grid.Column="0"
                            Clicked="OnCancelClicked"
                            HeightRequest="46"
                            CornerRadius="12"
                            FontFamily="Geist" FontAttributes="Bold" FontSize="14"
                            BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D3E58}"
                            TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark=White}" />
                    <Button x:Name="AcceptButton"
                            Grid.Column="1"
                            Clicked="OnAcceptClicked"
                            HeightRequest="46"
                            CornerRadius="12"
                            FontFamily="Geist" FontAttributes="Bold" FontSize="14"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
