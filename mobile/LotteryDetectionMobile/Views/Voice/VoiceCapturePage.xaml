<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:viewModel="clr-namespace:LotteryDetectionMobile.ViewModel"
             xmlns:voice="clr-namespace:LotteryDetectionMobile.Models.Voice"
             x:Class="LotteryDetectionMobile.Views.Voice.VoiceCapturePage"
             x:DataType="viewModel:VoiceCaptureViewModel"
             Title="Voice Capture"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCreamDark}}">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Top bar -->
        <Grid Grid.Row="0"
              Padding="20,40,20,10"
              ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0"
                    Text="←"
                    FontSize="20"
                    WidthRequest="36" HeightRequest="36"
                    Padding="0" CornerRadius="10"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1"
                   Text="Voice capture"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="17" FontAttributes="Bold"
                   CharacterSpacing="-0.01"
                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
            <BoxView Grid.Column="2" WidthRequest="36" HeightRequest="36" BackgroundColor="Transparent" />
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1" Padding="0">
            <VerticalStackLayout Padding="24,12,24,0" Spacing="14">
                <!-- Hero copy -->
                <Label
                    FontFamily="Geist" FontSize="24" FontAttributes="Bold"
                    LineHeight="1.15" CharacterSpacing="-0.025"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Speak the task." />
                            <Span Text="&#10;We'll handle the rest." />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label Text="Family AI transcribes live, then suggests the owner, time, and priority."
                       FontFamily="Geist" FontSize="13.5" LineHeight="1.5"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />

                <!-- Mic + waveform -->
                <Grid HeightRequest="200" Margin="0,8,0,0">
                    <!-- Waveform bars: flanking columns with a fixed-width gap matching the mic button -->
                    <Grid ColumnDefinitions="*,88,*"
                          ColumnSpacing="8"
                          HorizontalOptions="Fill"
                          VerticalOptions="Center">
                        <HorizontalStackLayout Grid.Column="0"
                                               BindableLayout.ItemsSource="{Binding LeftWaveform}"
                                               Spacing="3"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="voice:WaveformBar">
                                    <Border WidthRequest="2.5" HeightRequest="{Binding Height}"
                                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                                            StrokeThickness="0" Opacity="0.7"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="2" /></Border.StrokeShape>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Column="2"
                                               BindableLayout.ItemsSource="{Binding RightWaveform}"
                                               Spacing="3"
                                               HorizontalOptions="Start"
                                               VerticalOptions="Center">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="voice:WaveformBar">
                                    <Border WidthRequest="2.5" HeightRequest="{Binding Height}"
                                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                                            StrokeThickness="0" Opacity="0.7"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="2" /></Border.StrokeShape>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Mic button: direct child of outer Grid so HorizontalOptions="Center" is guaranteed -->
                    <Border x:Name="MicContainer"
                            WidthRequest="88" HeightRequest="88"
                            StrokeThickness="0"
                            HorizontalOptions="Center" VerticalOptions="Center">
                        <Border.StrokeShape>
                            <shapes:RoundRectangle CornerRadius="44" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleRecordCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0.2,0" EndPoint="1,1">
                                            <GradientStop Color="#5B8FFF" Offset="0" />
                                            <GradientStop Color="#1E5BFF" Offset="0.6" />
                                            <GradientStop Color="#0A2E8A" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Shadow">
                                    <Setter.Value>
                                        <Shadow Brush="#1E5BFF" Offset="0,0" Radius="28" Opacity="0.55" />
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="{AppThemeBinding Light={StaticResource FamilyInkLight}, Dark={StaticResource FamilyInkDark}}" />
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Shadow">
                                            <Setter.Value>
                                                <Shadow Brush="#0A1628" Offset="0,0" Radius="28" Opacity="0.38" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <!-- Idle: mic glyph -->
                            <Label Text="🎙" FontSize="34"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   IsVisible="{Binding ShowIdleMic}" />
                            <!-- Recording: white square stop -->
                            <BoxView WidthRequest="22" HeightRequest="22"
                                     CornerRadius="5"
                                     Color="White"
                                     HorizontalOptions="Center" VerticalOptions="Center"
                                     IsVisible="{Binding IsRecording}" />
                            <!-- Processing: AI thinking animation -->
                            <ActivityIndicator IsRunning="{Binding IsProcessing}"
                                               IsVisible="{Binding IsProcessing}"
                                               Color="White"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               HeightRequest="36" WidthRequest="36" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Timer + status -->
                <Label Text="{Binding RecordingDuration}"
                       FontFamily="GeistMono" FontSize="14"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center">
                    <Label.Style>
                        <Style TargetType="Label">
                            <Setter Property="TextColor"
                                    Value="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            <Style.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsRecording}" Value="True">
                                    <Setter Property="TextColor"
                                            Value="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Label.Style>
                </Label>
                <Label HorizontalOptions="Center"
                       FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                       CharacterSpacing="0.04"
                       TextTransform="Uppercase"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsRecording}" Value="True">
                            <Setter Property="Text" Value="Recording…" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsRecording}" Value="False">
                            <Setter Property="Text" Value="Tap to start" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

                <!-- Permission notice (shown when mic not granted) -->
                <Border IsVisible="{Binding ShowPermissionNotice}"
                        Padding="12"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Microphone access needed"
                                   FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                            <Label Text="Enable the mic to capture and stream your task in real time."
                                   FontFamily="Geist" FontSize="12"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Enable mic"
                                Command="{Binding RequestPermissionCommand}"
                                CornerRadius="10"
                                HeightRequest="36"
                                Padding="12,0"
                                FontFamily="Geist" FontAttributes="Bold" FontSize="12"
                                BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                                TextColor="White" />
                    </Grid>
                </Border>

                <!-- Live transcription card -->
                <Border Padding="16"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}"
                        MinimumHeightRequest="110">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#1E5BFF" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Ellipse WidthRequest="6" HeightRequest="6" VerticalOptions="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill">
                                            <Setter.Value>
                                                <SolidColorBrush Color="{AppThemeBinding Light={StaticResource FamilyInk4Light}, Dark={StaticResource FamilyInk4Dark}}" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Ellipse" Binding="{Binding IsRecording}" Value="True">
                                                <Setter Property="Fill">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{AppThemeBinding Light={StaticResource FamilyPrimaryLight}, Dark={StaticResource FamilyPrimaryDark}}" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <Label Text="LIVE TRANSCRIPTION"
                                   FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                   CharacterSpacing="0.06"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label x:Name="LiveTranscriptLabel"
                               Text="{Binding Transcript}"
                               LineBreakMode="WordWrap"
                               FontFamily="Geist" FontSize="14.5" LineHeight="1.5"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom: Discard + Save buttons -->
        <Grid Grid.Row="2"
              Padding="24,12,24,28"
              ColumnDefinitions="*,1.4*"
              ColumnSpacing="10">
            <Button Grid.Column="0"
                    Text="Discard"
                    Clicked="OnDiscardClicked"
                    HeightRequest="56"
                    CornerRadius="14"
                    FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
            <Grid Grid.Column="1">
                <!-- Save / Toggle (Save only enabled when transcript exists; otherwise the toggle records) -->
                <Button Text="{Binding RecordButtonText}"
                        Command="{Binding ToggleRecordCommand}"
                        IsVisible="{Binding ShowRecordButton}"
                        HeightRequest="56"
                        CornerRadius="14"
                        FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                        TextColor="White" />
                <Border IsVisible="{Binding ShowLoadingIndicator}"
                        HeightRequest="56"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                        <ActivityIndicator IsRunning="{Binding ShowLoadingIndicator}"
                                           Color="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                                           HeightRequest="20" WidthRequest="20" />
                        <Label Text="{Binding LoadingIndicatorText}"
                               FontFamily="Geist" FontAttributes="Bold" FontSize="14"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Grid>

        <!-- AI preview bottom-sheet popup -->
        <Grid IsVisible="{Binding ShowPreviewModal}"
              BackgroundColor="#BB000000"
              Grid.Row="0"
              Grid.RowSpan="3"
              InputTransparent="False">
            <Grid RowDefinitions="*,Auto">

                <!-- Scrim tap area -->
                <Grid Grid.Row="0" BackgroundColor="Transparent">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NewRecordCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Sheet card -->
                <Border Grid.Row="1"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1B2A45}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="28,28,0,0" /></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,-6" Radius="24" Opacity="0.18" />
                    </Border.Shadow>

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">

                        <!-- Drag handle -->
                        <BoxView Grid.Row="0"
                                 WidthRequest="40" HeightRequest="4" CornerRadius="2"
                                 BackgroundColor="{AppThemeBinding Light=#D1D5DB, Dark=#374151}"
                                 HorizontalOptions="Center"
                                 Margin="0,14,0,0" />

                        <!-- Sheet header -->
                        <Grid Grid.Row="1"
                              Padding="20,14,20,4"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10">
                            <Border Grid.Column="0"
                                    WidthRequest="38" HeightRequest="38"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryDeepDark}}">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="11" /></Border.StrokeShape>
                                <Label Text="✨" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="Drafted from your voice note"
                                       FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyPaperLight}}" />
                                <Label Text="{Binding RecordingDuration}"
                                       FontFamily="GeistMono" FontSize="11"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2"
                                    Text="✕"
                                    Command="{Binding NewRecordCommand}"
                                    Clicked="OnModalNewRecordClicked"
                                    WidthRequest="34" HeightRequest="34"
                                    Padding="0" CornerRadius="17"
                                    FontSize="14"
                                    BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#2D3E58}"
                                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                        </Grid>

                        <!-- Scrollable content -->
                        <ScrollView Grid.Row="2" Padding="20,10,20,4" MaximumHeightRequest="430">
                            <VerticalStackLayout Spacing="12">

                                <!-- Main Task Details Card -->
                                <Border Padding="18" StrokeThickness="1"
                                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyInk2Dark}}"
                                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyInk2Dark}}">
                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="{Binding PreviewData.Title}"
                                               FontFamily="Geist" FontSize="20" FontAttributes="Bold" LineHeight="1.2"
                                               Margin="0,0,0,14"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyPaperLight}}" />

                                        <!-- Owner -->
                                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyInk3Dark}}" Opacity="0.5" />
                                        <Grid ColumnDefinitions="Auto,*" Padding="0,11" ColumnSpacing="8">
                                            <Label Grid.Column="0" Text="Owner"
                                                   FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk4Dark}}"
                                                   VerticalOptions="Center" />
                                            <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="6" VerticalOptions="Center">
                                                <Border WidthRequest="24" HeightRequest="24" StrokeThickness="0"
                                                        BackgroundColor="{Binding PreviewData.Assignee, Converter={StaticResource MemberToColor}, ConverterParameter=bg}">
                                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                                    <Label Text="{Binding PreviewData.Assignee, Converter={StaticResource FirstChar}}"
                                                           TextColor="White" FontSize="11" FontAttributes="Bold"
                                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                                </Border>
                                                <Label Text="{Binding PreviewData.Assignee}"
                                                       FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyPaperLight}}"
                                                       VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Grid>

                                        <!-- When -->
                                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyInk3Dark}}" Opacity="0.5" />
                                        <Grid ColumnDefinitions="Auto,*" Padding="0,11" ColumnSpacing="8">
                                            <Label Grid.Column="0" Text="When"
                                                   FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk4Dark}}"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Column="1" Text="{Binding PreviewData.DueDateTime}"
                                                   FontFamily="Geist" FontSize="14" HorizontalOptions="End"
                                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyPaperLight}}"
                                                   VerticalOptions="Center" />
                                        </Grid>

                                        <!-- Priority + Category -->
                                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyInk3Dark}}" Opacity="0.5" />
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,12,0,0">
                                            <Border Grid.Column="0" Padding="12,8" StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPriMedBgLight}, Dark={DynamicResource FamilyPrimaryDeepDark}}">
                                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="PRIORITY" FontFamily="Geist" FontSize="10" FontAttributes="Bold"
                                                           CharacterSpacing="0.04"
                                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                                                    <Label Text="{Binding PreviewData.Priority}"
                                                           FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyPriMedTextLight}, Dark={DynamicResource FamilyPrimaryTintDark}}" />
                                                </VerticalStackLayout>
                                            </Border>
                                            <Border Grid.Column="1" Padding="12,8" StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyAccent2Light}, Dark={DynamicResource FamilyPrimaryDeepDark}}">
                                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="CATEGORY" FontFamily="Geist" FontSize="10" FontAttributes="Bold"
                                                           CharacterSpacing="0.04"
                                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                                                    <Label Text="{Binding PreviewData.Category}"
                                                           FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryTintDark}}" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Notes Card -->
                                <Border IsVisible="{Binding PreviewData.Notes, Converter={StaticResource HasText}}"
                                        Padding="14" StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyInk2Dark}}">
                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="Notes"
                                               FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyPaperLight}}" />
                                        <Label Text="{Binding PreviewData.Notes}"
                                               FontFamily="Geist" FontSize="13" LineHeight="1.4"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Voice Transcript Card -->
                                <Border Padding="14" StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyInk2Dark}}">
                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="Voice transcript"
                                               FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyPaperLight}}" />
                                        <Label Text="{Binding Transcript}"
                                               FontFamily="Geist" FontSize="13" LineHeight="1.4"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>
                        </ScrollView>

                        <!-- Bottom Actions -->
                        <Grid Grid.Row="3"
                              Padding="20,10,20,34"
                              ColumnDefinitions="*,1.4*"
                              ColumnSpacing="12">
                            <Button Text="Discard"
                                    Command="{Binding NewRecordCommand}"
                                    Clicked="OnModalNewRecordClicked"
                                    HeightRequest="54"
                                    CornerRadius="16"
                                    FontFamily="Geist" FontAttributes="Bold" FontSize="15"
                                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}"
                                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                            <Button Grid.Column="1"
                                    Text="Add to board"
                                    Command="{Binding SaveTaskCommand}"
                                    IsEnabled="{Binding CanSave}"
                                    HeightRequest="54"
                                    CornerRadius="16"
                                    FontFamily="Geist" FontAttributes="Bold" FontSize="15"
                                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                                    TextColor="White" />
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>

    <ContentPage.Resources>
        <ResourceDictionary xmlns:cv="clr-namespace:LotteryDetectionMobile.Converters">
            <cv:InvertBoolConverter x:Key="InvertBool" />
            <cv:IsNullConverter x:Key="IsNull" />
            <cv:IsNotNullConverter x:Key="IsNotNull" />
            <cv:HasTextConverter x:Key="HasText" />
            <cv:MemberToColorConverter x:Key="MemberToColor" />
            <cv:FirstCharConverter x:Key="FirstChar" />
        </ResourceDictionary>
    </ContentPage.Resources>
</ContentPage>
