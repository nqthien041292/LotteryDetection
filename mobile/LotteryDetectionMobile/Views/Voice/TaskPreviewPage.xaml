<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:LotteryDetectionMobile.ViewModel"
             x:Class="LotteryDetectionMobile.Views.Voice.TaskPreviewPage"
             x:DataType="viewModel:TaskPreviewViewModel"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCreamDark}}">
    <ContentPage.BindingContext>
        <viewModel:TaskPreviewViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top bar -->
        <Grid Grid.Row="0"
              Padding="20,48,20,8"
              ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0"
                    Text="←"
                    FontSize="20"
                    WidthRequest="36" HeightRequest="36"
                    Padding="0" CornerRadius="10"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1"
                   Text="Review task"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="17" FontAttributes="Bold"
                   CharacterSpacing="-0.01"
                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
            <BoxView Grid.Column="2" WidthRequest="36" HeightRequest="36" BackgroundColor="Transparent" />
        </Grid>

        <ScrollView Grid.Row="1" BackgroundColor="Transparent">
            <VerticalStackLayout Padding="20,8,20,20" Spacing="14">

                <!-- AI strip -->
                <Border Padding="12,10"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}">
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="✨" FontSize="14" VerticalOptions="Center" />
                        <Label Text="Drafted from your voice note"
                               FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Title -->
                <Border Padding="14"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyBorderLight}, Dark={DynamicResource FamilyBorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource FamilySurfaceLight}, Dark={StaticResource FamilySurfaceDark}}">
                    <Editor Text="{Binding Title}"
                            Placeholder="Task title"
                            AutoSize="TextChanges"
                            BackgroundColor="Transparent"
                            FontFamily="Geist" FontSize="20" FontAttributes="Bold"
                            MinimumHeightRequest="64"
                            TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}"
                            PlaceholderColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                </Border>

                <!-- Owner -->
                <Border Padding="14"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyBorderLight}, Dark={DynamicResource FamilyBorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource FamilySurfaceLight}, Dark={StaticResource FamilySurfaceDark}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPickOwnerTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Owner"
                               FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding Owner}"
                               FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- When -->
                <Border Padding="14"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyBorderLight}, Dark={DynamicResource FamilyBorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource FamilySurfaceLight}, Dark={StaticResource FamilySurfaceDark}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPickWhenTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="When"
                               FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding When, StringFormat='{0:ddd MMM d · h:mm tt}'}"
                               FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Priority + Category -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Padding="14"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={DynamicResource FamilyBorderLight}, Dark={DynamicResource FamilyBorderDark}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource FamilySurfaceLight}, Dark={StaticResource FamilySurfaceDark}}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CyclePriorityCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="PRIORITY" FontFamily="Geist" FontSize="10" FontAttributes="Bold"
                                   CharacterSpacing="0.04"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            <Label Text="{Binding Priority}"
                                   FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1"
                            Padding="14"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={DynamicResource FamilyBorderLight}, Dark={DynamicResource FamilyBorderDark}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource FamilySurfaceLight}, Dark={StaticResource FamilySurfaceDark}}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPickCategoryTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="CATEGORY" FontFamily="Geist" FontSize="10" FontAttributes="Bold"
                                   CharacterSpacing="0.04"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            <Label Text="{Binding Category}"
                                   FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- AI suggestion -->
                <Border IsVisible="{Binding HasSuggestion}"
                        Padding="14"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="✨" FontSize="14" VerticalOptions="Start" />
                        <Label Grid.Column="1"
                               Text="{Binding SuggestionText}"
                               FontFamily="Geist" FontSize="13"
                               LineHeight="1.4"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                        <Button Grid.Column="2"
                                Text="Apply"
                                Command="{Binding ApplySuggestionCommand}"
                                BackgroundColor="Transparent"
                                Padding="0"
                                FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom actions -->
        <Grid Grid.Row="2"
              Padding="20,12,20,28"
              ColumnDefinitions="*,1.4*"
              ColumnSpacing="10">
            <Button Grid.Column="0"
                    Text="New recording"
                    Command="{Binding NewRecordingCommand}"
                    HeightRequest="54"
                    CornerRadius="14"
                    FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}" />
            <Button Grid.Column="1"
                    Text="Add to board"
                    Command="{Binding SaveCommand}"
                    HeightRequest="54"
                    CornerRadius="14"
                    FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                    TextColor="White" />
        </Grid>
    </Grid>
</ContentPage>
