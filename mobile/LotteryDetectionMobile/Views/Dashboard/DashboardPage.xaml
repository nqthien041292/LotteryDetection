<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:LotteryDetectionMobile.Views.Components"
             xmlns:viewModel="clr-namespace:LotteryDetectionMobile.ViewModel"
             xmlns:dashModels="clr-namespace:LotteryDetectionMobile.Models.Dashboard"
             xmlns:familyModels="clr-namespace:LotteryDetectionMobile.Models.Family"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:behaviors="clr-namespace:LotteryDetectionMobile.Behaviors"
             x:Class="LotteryDetectionMobile.Views.Dashboard.DashboardPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Padding="0"
             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCreamDark}}">
    <ContentPage.BindingContext>
        <viewModel:DashboardViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header: avatar + greeting + bell -->
        <Grid Grid.Row="0"
              Padding="20,40,20,8"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="10">
            <components:FamilyAvatar Grid.Column="0"
                                     Member="{Binding MyMemberId}"
                                     Name="{Binding GreetingInitial}"
                                     Size="34"
                                     VerticalOptions="Center" />
            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                <Label Text="{Binding DateLabel}"
                       FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                       CharacterSpacing="0.04" TextTransform="Uppercase"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <Label Text="{Binding GreetingHeadline}"
                       FontFamily="Geist" FontSize="16" FontAttributes="Bold"
                       CharacterSpacing="-0.01"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
            </VerticalStackLayout>
            <!-- Bell with unread badge -->
            <Grid Grid.Column="2" WidthRequest="40" HeightRequest="40"
                  VerticalOptions="Center">
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}"
                        Padding="0">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Behaviors>
                        <behaviors:TapAnimationBehavior />
                    </Border.Behaviors>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenNotificationsCommand}" />
                    </Border.GestureRecognizers>
                    <components:VectorIcon Glyph="bell"
                                           Size="18"
                                           Color="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                </Border>
                <Border IsVisible="{Binding HasUnread}"
                        WidthRequest="18" HeightRequest="18"
                        StrokeThickness="2"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCreamDark}}"
                        BackgroundColor="#EF4444"
                        Padding="0"
                        HorizontalOptions="End" VerticalOptions="Start"
                        Margin="0,-3,-3,0">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="9" />
                    </Border.StrokeShape>
                    <Label Text="{Binding UnreadLabel}"
                           FontFamily="GeistMono" FontSize="9.5" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           TextColor="White" />
                </Border>
            </Grid>
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1" BackgroundColor="Transparent">
            <VerticalStackLayout Padding="0,14,0,16" Spacing="14">

                <!-- Headline + summary tiles -->
                <VerticalStackLayout Padding="20,0" Spacing="0">
                    <Label FontFamily="Geist" FontSize="26" FontAttributes="Bold"
                           LineHeight="1.1" CharacterSpacing="-0.025"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding HeadlineCount}" />
                                <Span Text=" things to handle today." />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label Text="{Binding HeadlineNote}"
                           FontFamily="Geist" FontSize="13"
                           Margin="0,4,0,14"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <components:SummaryTile Grid.Column="0"
                                                Label="Due today"
                                                Value="{Binding SummaryDueToday}"
                                                TintBg="#FFE4DD" TintFg="#B23A1A"
                                                Command="{Binding ViewAllTasksCommand}" />
                        <components:SummaryTile Grid.Column="1"
                                                Label="Overdue"
                                                Value="{Binding SummaryOverdue}"
                                                TintBg="#FFD7D7" TintFg="#B91C1C"
                                                Command="{Binding ViewAllTasksCommand}" />
                        <components:SummaryTile Grid.Column="2"
                                                Label="Done · wk"
                                                Value="{Binding SummaryDoneWeek}"
                                                TintBg="#DCFCE7" TintFg="#15803D"
                                                Command="{Binding OpenAchievementsCommand}" />
                    </Grid>
                </VerticalStackLayout>

                <!-- Week strip -->
                <VerticalStackLayout Padding="20,0" Spacing="0">
                    <components:SectionHeader Title="THIS WEEK"
                                              ActionLabel="Calendar →"
                                              ActionCommand="{Binding OpenCalendarCommand}" />
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}"
                            Padding="8,14,8,14">
                        <Border.StrokeShape>
                            <shapes:RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <!-- FlexLayout distributes 7 day cells evenly across the row.
                                 Grid+BindableLayout does NOT auto-set Grid.Column per item, so it would stack all cells in column 0. -->
                            <FlexLayout Direction="Row"
                                        JustifyContent="SpaceBetween"
                                        AlignItems="Start"
                                        BindableLayout.ItemsSource="{Binding WeekDays}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="dashModels:DayCell">
                                        <VerticalStackLayout Spacing="4"
                                                             Padding="0,2,0,0"
                                                             HorizontalOptions="Center"
                                                             FlexLayout.Grow="1"
                                                             FlexLayout.Basis="0">
                                            <Label Text="{Binding Label}"
                                                   FontFamily="Geist" FontSize="10" FontAttributes="Bold"
                                                   CharacterSpacing="0.04" TextTransform="Uppercase"
                                                   HorizontalTextAlignment="Center" HorizontalOptions="Center"
                                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsToday}" Value="True">
                                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource FamilyPrimaryLight}, Dark={StaticResource FamilyPrimaryDark}}" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Border WidthRequest="30" HeightRequest="30"
                                                    StrokeThickness="0"
                                                    BackgroundColor="Transparent"
                                                    HorizontalOptions="Center">
                                                <Border.StrokeShape>
                                                    <shapes:RoundRectangle CornerRadius="15" />
                                                </Border.StrokeShape>
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsToday}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource FamilyInkLight}, Dark={StaticResource FamilyInkDark}}" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="{Binding Day}"
                                                       FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       CharacterSpacing="-0.01"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsToday}" Value="True">
                                                            <Setter Property="TextColor" Value="White" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Border>
                                            <!-- Dot density: up to 4 dots based on DotCount -->
                                            <HorizontalStackLayout Spacing="2" HorizontalOptions="Center" HeightRequest="5">
                                                <BoxView WidthRequest="4" HeightRequest="4" CornerRadius="2"
                                                         BackgroundColor="#2563EB"
                                                         IsVisible="{Binding DotCount, Converter={StaticResource AtLeastConverter}, ConverterParameter=1}" />
                                                <BoxView WidthRequest="4" HeightRequest="4" CornerRadius="2"
                                                         BackgroundColor="#0EA5E9"
                                                         IsVisible="{Binding DotCount, Converter={StaticResource AtLeastConverter}, ConverterParameter=2}" />
                                                <BoxView WidthRequest="4" HeightRequest="4" CornerRadius="2"
                                                         BackgroundColor="#14B8A6"
                                                         IsVisible="{Binding DotCount, Converter={StaticResource AtLeastConverter}, ConverterParameter=3}" />
                                                <BoxView WidthRequest="4" HeightRequest="4" CornerRadius="2"
                                                         BackgroundColor="#6D5BD0"
                                                         IsVisible="{Binding DotCount, Converter={StaticResource AtLeastConverter}, ConverterParameter=4}" />
                                            </HorizontalStackLayout>
                                            <VerticalStackLayout.Behaviors>
                                                <behaviors:TapAnimationBehavior />
                                            </VerticalStackLayout.Behaviors>
                                            <VerticalStackLayout.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenCalendarCommand}" />
                                            </VerticalStackLayout.GestureRecognizers>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                            <!-- Subtle caption when nothing scheduled all week -->
                            <Label Text="Nothing scheduled · tap a day to plan ahead"
                                   FontFamily="Geist" FontSize="11"
                                   HorizontalOptions="Center"
                                   IsVisible="{Binding HasWeekTasks, Converter={StaticResource InverseBool}}"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Quick launch -->
                <VerticalStackLayout Padding="20,0" Spacing="0">
                    <components:SectionHeader Title="JUMP IN" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="*,*"
                          ColumnSpacing="8" RowSpacing="8">
                        <components:QuickLaunch Grid.Row="0" Grid.Column="0"
                                                Icon="board"
                                                Label="Family board"
                                                Meta="Live · in progress"
                                                Accent="#1E5BFF"
                                                Tint="#E0EAFF"
                                                Command="{Binding OpenBoardCommand}" />
                        <components:QuickLaunch Grid.Row="0" Grid.Column="1"
                                                Icon="sparkle"
                                                Label="AI assistant"
                                                Meta="New suggestions"
                                                Accent="#6D5BD0"
                                                Tint="#E1DDFE"
                                                Command="{Binding OpenAssistantCommand}" />
                        <components:QuickLaunch Grid.Row="1" Grid.Column="0"
                                                Icon="chat"
                                                Label="Chat → task"
                                                Meta="Drafts ready"
                                                Accent="#0EA5E9"
                                                Tint="#D6EEFB"
                                                Command="{Binding OpenChatToTaskCommand}" />
                        <components:QuickLaunch Grid.Row="1" Grid.Column="1"
                                                Icon="calendar"
                                                Label="Calendar"
                                                Meta="Synced"
                                                Accent="#14B8A6"
                                                Tint="#D1F0EC"
                                                Command="{Binding OpenCalendarCommand}" />
                    </Grid>
                </VerticalStackLayout>

                <!-- Today's lineup -->
                <VerticalStackLayout Padding="20,0" Spacing="0">
                    <components:SectionHeader Title="TODAY'S LINEUP"
                                              ActionLabel="All tasks →"
                                              ActionCommand="{Binding ViewAllTasksCommand}" />
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}"
                            Padding="0">
                        <Border.StrokeShape>
                            <shapes:RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <Grid>
                            <!-- Populated list -->
                            <VerticalStackLayout IsVisible="{Binding HasTodayLineup}"
                                                 Padding="0,6"
                                                 BindableLayout.ItemsSource="{Binding TodayLineup}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="familyModels:TodayTaskItem">
                                        <Grid ColumnDefinitions="Auto,Auto,*"
                                              ColumnSpacing="12"
                                              Padding="14,10">
                                            <Grid.Behaviors>
                                                <behaviors:TapAnimationBehavior />
                                            </Grid.Behaviors>
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectTaskCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>
                                            <Label Grid.Column="0"
                                                   Text="{Binding When}"
                                                   FontFamily="GeistMono" FontSize="12" FontAttributes="Bold"
                                                   CharacterSpacing="-0.01"
                                                   LineBreakMode="TailTruncation"
                                                   WidthRequest="58"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                            <BoxView Grid.Column="1"
                                                     WidthRequest="4" HeightRequest="32"
                                                     CornerRadius="2"
                                                     BackgroundColor="{Binding Member, Converter={StaticResource MemberToDot}}"
                                                     VerticalOptions="Center" />
                                            <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding Title}"
                                                       FontFamily="Geist" FontSize="13.5" FontAttributes="Bold"
                                                       LineHeight="1.3" CharacterSpacing="-0.005"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                                <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="6">
                                                    <components:FamilyAvatar Grid.Column="0"
                                                                              Member="{Binding Member}"
                                                                              Name="{Binding OwnerLabel}"
                                                                              Size="14" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding OwnerLabel}"
                                                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                                           VerticalOptions="Center"
                                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                                    <Label Grid.Column="2" Text="·"
                                                           FontFamily="Geist" FontSize="11"
                                                           VerticalOptions="Center"
                                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                                                    <Label Grid.Column="3"
                                                           Text="{Binding Subtitle}"
                                                           FontFamily="Geist" FontSize="11"
                                                           LineBreakMode="TailTruncation"
                                                           VerticalOptions="Center"
                                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <!-- Empty state: icon disc + headline + sub copy + CTA -->
                            <VerticalStackLayout IsVisible="{Binding HasTodayLineup, Converter={StaticResource InverseBool}}"
                                                 Padding="20,28,20,28"
                                                 Spacing="6"
                                                 HorizontalOptions="Center">
                                <Border WidthRequest="44" HeightRequest="44"
                                        StrokeThickness="0"
                                        HorizontalOptions="Center"
                                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}">
                                    <Border.StrokeShape>
                                        <shapes:RoundRectangle CornerRadius="22" />
                                    </Border.StrokeShape>
                                    <Label Text="✓"
                                           FontFamily="Geist" FontSize="20" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource FamilyPrimaryLight}, Dark={StaticResource FamilyPrimaryDark}}" />
                                </Border>
                                <Label Text="You're all caught up."
                                       FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                       CharacterSpacing="-0.01"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="No tasks scheduled for today — enjoy the breather."
                                       FontFamily="Geist" FontSize="12"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                <Label Text="Add a task →"
                                       FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                                       Padding="0,6,0,0"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource FamilyPrimaryLight}, Dark={StaticResource FamilyPrimaryDark}}">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenVoiceCaptureCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Family pulse -->
                <VerticalStackLayout Padding="20,0" Spacing="0" IsVisible="{Binding HasPulse}">
                    <components:SectionHeader Title="FAMILY PULSE" />
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}"
                            Padding="14">
                        <Border.StrokeShape>
                            <shapes:RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <HorizontalStackLayout Grid.Column="0" Spacing="-8"
                                BindableLayout.ItemsSource="{Binding PulseMembers}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <components:FamilyAvatar Member="{Binding Member}"
                                                                 Name="{Binding Initial}"
                                                                 Size="32" Ring="True" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding PulseHeadline}"
                                       FontFamily="Geist" FontSize="13" FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                <Label Text="{Binding PulseSubline}"
                                       FontFamily="Geist" FontSize="11"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <components:BottomBarView Grid.Row="2"
                                  x:Name="BottomBar"
                                  TabSelected="OnTabSelected" />

        <!-- Loading skeleton -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              IsVisible="{Binding ShowSkeleton}"
              BackgroundColor="#F8FAFC"
              Padding="20,96,20,20">
            <components:DashboardSkeleton VerticalOptions="Start" />
        </Grid>
    </Grid>

    <ContentPage.Resources>
        <ResourceDictionary xmlns:cv="clr-namespace:LotteryDetectionMobile.Converters">
            <cv:MemberToColorConverter x:Key="MemberToDot" Slot="Dot" />
            <cv:AtLeastConverter x:Key="AtLeastConverter" />
            <cv:IsZeroConverter x:Key="IsZero" />
            <cv:InverseBoolConverter x:Key="InverseBool" />
        </ResourceDictionary>
    </ContentPage.Resources>
</ContentPage>
