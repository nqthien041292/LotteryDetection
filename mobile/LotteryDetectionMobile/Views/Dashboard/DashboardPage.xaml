<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="LotteryDetectionMobile.Views.Dashboard.DashboardPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Padding="0"
             BackgroundColor="#F6F8F2">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,44,20,24" Spacing="18">
                <Label Text="Dò vé số tự động"
                       FontFamily="Geist"
                       FontSize="30"
                       FontAttributes="Bold"
                       LineHeight="1.05"
                       TextColor="#142116" />

                <Border StrokeThickness="0" Padding="18" BackgroundColor="#173D2A">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#173D2A" Radius="24" Offset="0,14" Opacity="0.2" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="18">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Kiểm tra vé trong vài giây"
                                       FontFamily="Geist"
                                       FontSize="23"
                                       FontAttributes="Bold"
                                       LineHeight="1.12"
                                       TextColor="White" />
                                <Label Text="Chụp ảnh vé số, AI tự động đọc đài, ngày quay, dãy số và phân tích kết quả."
                                       FontFamily="Geist"
                                       FontSize="13"
                                       LineHeight="1.45"
                                       TextColor="#CFE6D5" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    WidthRequest="78"
                                    HeightRequest="112"
                                    Stroke="#A9D7B6"
                                    StrokeThickness="1"
                                    BackgroundColor="#F9FFF2"
                                    Padding="8">
                                <Border.StrokeShape>
                                    <shapes:RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="7" VerticalOptions="Center">
                                    <Label Text="VÉ SỐ"
                                           FontFamily="Geist"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"
                                           TextColor="#173D2A" />
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="*,*,*" ColumnSpacing="4" RowSpacing="4">
                                        <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#DDF6DC" StrokeThickness="0" HeightRequest="18">
                                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="9" /></Border.StrokeShape>
                                            <Label Text="12" FontSize="9" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#173D2A" />
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#FFE7A8" StrokeThickness="0" HeightRequest="18">
                                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="9" /></Border.StrokeShape>
                                            <Label Text="34" FontSize="9" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#173D2A" />
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#E7F0FF" StrokeThickness="0" HeightRequest="18">
                                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="9" /></Border.StrokeShape>
                                            <Label Text="56" FontSize="9" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#173D2A" />
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#FCE0EA" StrokeThickness="0" HeightRequest="18">
                                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="9" /></Border.StrokeShape>
                                            <Label Text="78" FontSize="9" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#173D2A" />
                                        </Border>
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="#C4D8C7" />
                                    <Label Text="AUTO"
                                           FontFamily="Geist"
                                           FontSize="9"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"
                                           TextColor="#52705A" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Button Grid.Row="1"
                                Text="Chụp vé số"
                                Command="{Binding OpenLotteryCaptureCommand}"
                                HeightRequest="56"
                                CornerRadius="18"
                                FontFamily="Geist"
                                FontSize="16"
                                FontAttributes="Bold"
                                BackgroundColor="#F5C842"
                                TextColor="#173D2A" />

                        <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="3 bước"
                                       FontFamily="Geist"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="Chụp, đọc, đối"
                                       FontFamily="Geist"
                                       FontSize="11"
                                       TextColor="#CFE6D5" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="AI"
                                       FontFamily="Geist"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="Nhận diện số"
                                       FontFamily="Geist"
                                       FontSize="11"
                                       TextColor="#CFE6D5" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="2">
                                <Label Text="Nhanh"
                                       FontFamily="Geist"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="Kết quả tức thì"
                                       FontFamily="Geist"
                                       FontSize="11"
                                       TextColor="#CFE6D5" />
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Padding="14" StrokeThickness="1" Stroke="#DAE5D6" BackgroundColor="White">
                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLotteryResultsCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0" BackgroundColor="#E7F5DE" HorizontalOptions="Start">
                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                    <Label Text="🎯" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Grid.Column="1" Text="›" FontSize="22" FontAttributes="Bold" TextColor="#66736A" VerticalOptions="Center" />
                            </Grid>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Kết quả hôm nay" FontFamily="Geist" FontSize="13" FontAttributes="Bold" TextColor="#142116" />
                                <Label Text="Cập nhật xổ số miền Bắc, miền Trung, miền Nam."
                                       FontFamily="Geist" FontSize="12" LineHeight="1.35" TextColor="#66736A" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Padding="14" StrokeThickness="1" Stroke="#DAE5D6" BackgroundColor="White">
                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLotteryHistoryCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0" BackgroundColor="#FFF1C2" HorizontalOptions="Start">
                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                    <Label Text="🗂" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Grid.Column="1" Text="›" FontSize="22" FontAttributes="Bold" TextColor="#66736A" VerticalOptions="Center" />
                            </Grid>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Lịch sử dò vé" FontFamily="Geist" FontSize="13" FontAttributes="Bold" TextColor="#142116" />
                                <Label Text="Lưu lại ảnh vé, dãy số và trạng thái trúng thưởng."
                                       FontFamily="Geist" FontSize="12" LineHeight="1.35" TextColor="#66736A" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border Padding="16" StrokeThickness="1" Stroke="#DAE5D6" BackgroundColor="White">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Quy trình tự động"
                               FontFamily="Geist"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#142116" />
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                            <Border Grid.Row="0" WidthRequest="32" HeightRequest="32" StrokeThickness="0" BackgroundColor="#E7F5DE">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                <Label Text="1" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#173D2A" />
                            </Border>
                            <Label Grid.Row="0" Grid.Column="1" Text="Căn vé trong khung chụp để ảnh rõ số và mã vé." FontFamily="Geist" FontSize="13" TextColor="#38443B" VerticalOptions="Center" />
                            <Border Grid.Row="1" WidthRequest="32" HeightRequest="32" StrokeThickness="0" BackgroundColor="#FFF1C2">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                <Label Text="2" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#173D2A" />
                            </Border>
                            <Label Grid.Row="1" Grid.Column="1" Text="AI đọc và phân tích dãy số, ngày quay và đài phát hành." FontFamily="Geist" FontSize="13" TextColor="#38443B" VerticalOptions="Center" />
                            <Border Grid.Row="2" WidthRequest="32" HeightRequest="32" StrokeThickness="0" BackgroundColor="#E8EEFF">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                <Label Text="3" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#173D2A" />
                            </Border>
                            <Label Grid.Row="2" Grid.Column="1" Text="AI đối chiếu kết quả và báo vé có trúng giải hay không." FontFamily="Geist" FontSize="13" TextColor="#38443B" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
