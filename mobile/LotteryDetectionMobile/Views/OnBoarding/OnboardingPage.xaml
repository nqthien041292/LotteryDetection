<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:LotteryDetectionMobile.ViewModel"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="LotteryDetectionMobile.Views.OnBoarding.OnboardingPage"
             x:DataType="viewModel:OnboardingViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F8F2">

    <ContentPage.BindingContext>
        <viewModel:OnboardingViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" Padding="20,44,20,0" ColumnDefinitions="Auto,*,Auto">
            <Button Text="‹"
                    FontSize="28"
                    WidthRequest="40"
                    HeightRequest="40"
                    Padding="0"
                    CornerRadius="14"
                    BackgroundColor="#E9EFE4"
                    TextColor="#173D2A"
                    IsVisible="{Binding ShowBackButton}"
                    Command="{Binding BackCommand}" />
            <Button Grid.Column="2"
                    Text="Bỏ qua"
                    FontFamily="Geist"
                    FontSize="14"
                    BackgroundColor="Transparent"
                    TextColor="#52705A"
                    IsVisible="{Binding ShowSkipButton}"
                    Command="{Binding SkipCommand}" />
        </Grid>

        <Grid Grid.Row="1" Padding="24,12,24,0">
            <VerticalStackLayout IsVisible="{Binding IsSlide0}" Spacing="24" VerticalOptions="Center">
                <Border HeightRequest="280" StrokeThickness="0" BackgroundColor="#173D2A" Padding="20">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="30" /></Border.StrokeShape>
                    <Grid>
                        <Border WidthRequest="170" HeightRequest="230" Stroke="#F5C842" StrokeThickness="2" BackgroundColor="#F9FFF2" Padding="16" HorizontalOptions="Center" VerticalOptions="Center">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="14">
                                <Label Text="VÉ SỐ" FontFamily="Geist" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="#173D2A" />
                                <Grid ColumnDefinitions="*,*" RowDefinitions="*,*,*" ColumnSpacing="8" RowSpacing="8">
                                    <Border BackgroundColor="#DDF6DC" StrokeThickness="0" HeightRequest="34">
                                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="17" /></Border.StrokeShape>
                                        <Label Text="18" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#173D2A" />
                                    </Border>
                                    <Border Grid.Column="1" BackgroundColor="#FFE7A8" StrokeThickness="0">
                                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="17" /></Border.StrokeShape>
                                        <Label Text="42" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#173D2A" />
                                    </Border>
                                    <Border Grid.Row="1" BackgroundColor="#E7F0FF" StrokeThickness="0">
                                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="17" /></Border.StrokeShape>
                                        <Label Text="67" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#173D2A" />
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#FCE0EA" StrokeThickness="0">
                                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="17" /></Border.StrokeShape>
                                        <Label Text="90" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#173D2A" />
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </Border>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Dò vé số bằng camera"
                           FontFamily="Geist"
                           FontSize="31"
                           FontAttributes="Bold"
                           LineHeight="1.08"
                           TextColor="#142116" />
                    <Label Text="Chụp ảnh vé số, AI sẽ đọc thông tin trên vé và phân tích để chuẩn bị kết quả đối chiếu."
                           FontFamily="Geist"
                           FontSize="15"
                           LineHeight="1.45"
                           TextColor="#66736A" />
                </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsSlide1}" Spacing="24" VerticalOptions="Center">
                <Border HeightRequest="280" StrokeThickness="0" BackgroundColor="#FFF4C9" Padding="22">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="30" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="16" VerticalOptions="Center">
                        <Label Text="834972" FontFamily="GeistMono" FontSize="36" FontAttributes="Bold" CharacterSpacing="3" HorizontalTextAlignment="Center" TextColor="#173D2A" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Padding="14" StrokeThickness="0" BackgroundColor="White">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                <Label Text="Đài quay" FontFamily="Geist" FontSize="13" FontAttributes="Bold" TextColor="#52705A" />
                            </Border>
                            <Border Grid.Column="1" Padding="14" StrokeThickness="0" BackgroundColor="White">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                <Label Text="Ngày quay" FontFamily="Geist" FontSize="13" FontAttributes="Bold" TextColor="#52705A" />
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
                <VerticalStackLayout Spacing="10">
                    <Label Text="AI đọc và phân tích vé số"
                           FontFamily="Geist"
                           FontSize="31"
                           FontAttributes="Bold"
                           LineHeight="1.08"
                           TextColor="#142116" />
                    <Label Text="AI phân tích ảnh vé để suy ra dãy số, ngày quay, đài phát hành và các thông tin cần đối chiếu."
                           FontFamily="Geist"
                           FontSize="15"
                           LineHeight="1.45"
                           TextColor="#66736A" />
                </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsSlide2}" Spacing="24" VerticalOptions="Center">
                <Border HeightRequest="280" StrokeThickness="0" BackgroundColor="#173D2A" Padding="22">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="30" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14" VerticalOptions="Center">
                        <Border Padding="16" StrokeThickness="0" BackgroundColor="#E7F6DE">
                            <Border.StrokeShape><shapes:RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                            <Label Text="Không trúng giải"
                                   FontFamily="Geist"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#173D2A" />
                        </Border>
                        <Label Text="Ứng dụng sẵn sàng kết nối API kết quả xổ số thật để đối chiếu tự động."
                               FontFamily="Geist"
                               FontSize="14"
                               LineHeight="1.45"
                               HorizontalTextAlignment="Center"
                               TextColor="#CFE6D5" />
                    </VerticalStackLayout>
                </Border>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Báo kết quả rõ ràng"
                           FontFamily="Geist"
                           FontSize="31"
                           FontAttributes="Bold"
                           LineHeight="1.08"
                           TextColor="#142116" />
                    <Label Text="Sau khi AI phân tích, app hiện dãy số, đài quay, ngày quay và trạng thái trúng thưởng."
                           FontFamily="Geist"
                           FontSize="15"
                           LineHeight="1.45"
                           TextColor="#66736A" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <VerticalStackLayout Grid.Row="2" Padding="24,14,24,36" Spacing="18">
            <HorizontalStackLayout Spacing="7" HorizontalOptions="Center">
                <Border WidthRequest="24" HeightRequest="7" StrokeThickness="0" IsVisible="{Binding IsDot0Active}" BackgroundColor="#173D2A">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                </Border>
                <Border WidthRequest="7" HeightRequest="7" StrokeThickness="0" IsVisible="{Binding IsDot0Active, Converter={StaticResource InvertBool}}" BackgroundColor="#CBD8C8">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                </Border>
                <Border WidthRequest="24" HeightRequest="7" StrokeThickness="0" IsVisible="{Binding IsDot1Active}" BackgroundColor="#173D2A">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                </Border>
                <Border WidthRequest="7" HeightRequest="7" StrokeThickness="0" IsVisible="{Binding IsDot1Active, Converter={StaticResource InvertBool}}" BackgroundColor="#CBD8C8">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                </Border>
                <Border WidthRequest="24" HeightRequest="7" StrokeThickness="0" IsVisible="{Binding IsDot2Active}" BackgroundColor="#173D2A">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                </Border>
                <Border WidthRequest="7" HeightRequest="7" StrokeThickness="0" IsVisible="{Binding IsDot2Active, Converter={StaticResource InvertBool}}" BackgroundColor="#CBD8C8">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                </Border>
            </HorizontalStackLayout>
            <Button Text="{Binding NextButtonText}"
                    Command="{Binding NextCommand}"
                    HeightRequest="58"
                    CornerRadius="19"
                    FontFamily="Geist"
                    FontSize="16"
                    FontAttributes="Bold"
                    BackgroundColor="#F5C842"
                    TextColor="#173D2A" />
        </VerticalStackLayout>

        <Grid IsVisible="{Binding ShowPermissionPopup}"
              Grid.RowSpan="3"
              BackgroundColor="#99000000"
              Padding="24">
            <Border Padding="22"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    VerticalOptions="Center">
                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Cho phép camera?"
                           FontFamily="Geist"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#142116" />
                    <Label Text="Lottery Detection cần quyền camera để chụp ảnh vé số và tự động dò kết quả."
                           FontFamily="Geist"
                           FontSize="14"
                           LineHeight="1.45"
                           TextColor="#66736A" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                        <Button Text="Để sau"
                                Command="{Binding NotNowCommand}"
                                HeightRequest="50"
                                CornerRadius="16"
                                FontFamily="Geist"
                                FontAttributes="Bold"
                                BackgroundColor="#E9EFE4"
                                TextColor="#173D2A" />
                        <Button Grid.Column="1"
                                Text="Cho phép"
                                Command="{Binding AllowCommand}"
                                HeightRequest="50"
                                CornerRadius="16"
                                FontFamily="Geist"
                                FontAttributes="Bold"
                                BackgroundColor="#173D2A"
                                TextColor="White" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

    <ContentPage.Resources>
        <ResourceDictionary xmlns:cv="clr-namespace:LotteryDetectionMobile.Converters">
            <cv:InvertBoolConverter x:Key="InvertBool" />
        </ResourceDictionary>
    </ContentPage.Resources>
</ContentPage>
