<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:LotteryDetectionMobile.Views.Components"
             xmlns:viewModel="clr-namespace:LotteryDetectionMobile.ViewModel"
             xmlns:familyModels="clr-namespace:LotteryDetectionMobile.Models.Family"
             xmlns:calendarModels="clr-namespace:LotteryDetectionMobile.Models.Calendar"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="LotteryDetectionMobile.Views.Family.CalendarPage"
             x:DataType="viewModel:CalendarViewModel"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCreamDark}}">
    <ContentPage.BindingContext>
        <viewModel:CalendarViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <ResourceDictionary xmlns:cv="clr-namespace:LotteryDetectionMobile.Converters">
            <cv:MemberToColorConverter x:Key="MemberToDot" Slot="Dot" />
            <cv:IsZeroConverter x:Key="IsZero" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0"
              Padding="20,40,20,4"
              ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Text="←" FontSize="20"
                    WidthRequest="36" HeightRequest="36"
                    Padding="0" CornerRadius="10"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1"
                   Text="Calendar"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="17" FontAttributes="Bold"
                   CharacterSpacing="-0.01"
                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
            <Button Grid.Column="2" Text="+" FontSize="22"
                    WidthRequest="36" HeightRequest="36"
                    Padding="0" CornerRadius="10"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}"
                    Clicked="OnAddClicked" />
        </Grid>

        <!-- Month label + sync chip + mode toggle -->
        <Grid Grid.Row="1"
              Padding="20,6,20,10"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Text="{Binding MonthLabel}"
                       FontFamily="Geist" FontSize="26" FontAttributes="Bold"
                       LineHeight="1.1" CharacterSpacing="-0.025"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                    <BoxView WidthRequest="7" HeightRequest="7" CornerRadius="4"
                             BackgroundColor="{Binding SyncDotColor}"
                             VerticalOptions="Center" />
                    <Label Text="{Binding SyncLabel}"
                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Mode toggle -->
            <Border Grid.Column="1"
                    Padding="3"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <shapes:RoundRectangle CornerRadius="999" />
                </Border.StrokeShape>
                <!-- Each segment is a Border (not a Button): MAUI iOS does not
                     repaint Button.BackgroundColor from a style/trigger after
                     render, so the selected fill never showed. Border background
                     repaints reliably from a DataTrigger. -->
                <HorizontalStackLayout Spacing="0">
                    <Border StrokeShape="RoundRectangle 999"
                            StrokeThickness="0" Padding="16,5"
                            BackgroundColor="Transparent">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding Mode}" Value="month">
                                <Setter Property="BackgroundColor"
                                        Value="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleModeCommand}" CommandParameter="month" />
                        </Border.GestureRecognizers>
                        <Label Text="Month"
                               FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding Mode}" Value="month">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                    <Border StrokeShape="RoundRectangle 999"
                            StrokeThickness="0" Padding="16,5"
                            BackgroundColor="Transparent">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding Mode}" Value="week">
                                <Setter Property="BackgroundColor"
                                        Value="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleModeCommand}" CommandParameter="week" />
                        </Border.GestureRecognizers>
                        <Label Text="Week"
                               FontFamily="Geist" FontSize="12" FontAttributes="Bold"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding Mode}" Value="week">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- (placeholder row keeps grid layout simple) -->
        <BoxView Grid.Row="2" HeightRequest="0" BackgroundColor="Transparent" />

        <!-- Body -->
        <ScrollView Grid.Row="3" BackgroundColor="Transparent">
            <VerticalStackLayout Padding="16,0,16,16" Spacing="14">

                <components:CalendarSkeleton
                    IsVisible="{Binding ShowSkeleton}" />

                <components:CalendarMonthGrid
                    IsVisible="{Binding ShowMonth}"
                    Cells="{Binding MonthCells}"
                    SelectCommand="{Binding SelectDayCommand}" />

                <components:CalendarWeekTimeline
                    IsVisible="{Binding ShowWeek}"
                    Days="{Binding WeekDays}"
                    Blocks="{Binding WeekBlocks}" />

                <!-- Member legend (live from family cache) -->
                <HorizontalStackLayout Spacing="12" Padding="4,2,4,4" HorizontalOptions="Center"
                                       BindableLayout.ItemsSource="{Binding LegendMembers}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="calendarModels:CalendarLegendMember">
                            <HorizontalStackLayout Spacing="5">
                                <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4"
                                         BackgroundColor="{Binding MemberId, Converter={StaticResource MemberToDot}}" />
                                <Label Text="{Binding DisplayName}" FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                            </HorizontalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>

                <!-- Selected day events (month mode) -->
                <Border IsVisible="{Binding ShowDayCard}"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}"
                        Padding="0">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="16,14,16,6"
                              ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="{Binding SelectedDayLabel}"
                                   FontFamily="Geist" FontSize="18" FontAttributes="Bold"
                                   CharacterSpacing="-0.015"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                            <Label Grid.Column="1"
                                   Text="{Binding SelectedDayCount}"
                                   FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                        </Grid>
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedDayEvents}"
                                             Padding="0,4,0,8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="familyModels:CalendarEvent">
                                    <Grid ColumnDefinitions="48,4,*,Auto"
                                          ColumnSpacing="12"
                                          Padding="16,10">
                                        <Label Grid.Column="0"
                                               Text="{Binding Start, StringFormat='{0:h:mm tt}'}"
                                               FontFamily="GeistMono" FontSize="12" FontAttributes="Bold"
                                               CharacterSpacing="-0.01"
                                               VerticalOptions="Center"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                        <BoxView Grid.Column="1"
                                                 WidthRequest="4" HeightRequest="28"
                                                 CornerRadius="2"
                                                 BackgroundColor="{Binding Member, Converter={StaticResource MemberToDot}}"
                                                 VerticalOptions="Center" />
                                        <Label Grid.Column="2"
                                               Text="{Binding Title}"
                                               FontFamily="Geist" FontSize="13.5" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation"
                                               VerticalOptions="Center"
                                               CharacterSpacing="-0.005"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                        <components:FamilyAvatar Grid.Column="3"
                                                                  Member="{Binding Member}"
                                                                  Name="{Binding Owner}"
                                                                  Size="20"
                                                                  VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                        <Label Text="Nothing scheduled"
                               FontFamily="Geist" FontSize="13"
                               HorizontalOptions="Center" Padding="16,16,16,18"
                               IsVisible="{Binding SelectedDayEvents.Count, Converter={StaticResource IsZero}}"
                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <components:BottomBarView x:Name="BottomBar"
                                  Grid.Row="4"
                                  TabSelected="OnTabSelected" />
    </Grid>
</ContentPage>
