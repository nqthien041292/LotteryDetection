<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:LotteryDetectionMobile.ViewModel"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:cv="clr-namespace:LotteryDetectionMobile.Converters"
             x:Class="LotteryDetectionMobile.Views.Family.Invitation.AcceptInvitationPage"
             x:DataType="viewModel:AcceptInvitationViewModel"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCreamDark}}">

    <ContentPage.Resources>
        <cv:HasTextConverter x:Key="HasText" />
        <cv:InverseBoolConverter x:Key="InverseBool" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Top bar -->
        <Grid Grid.Row="0" Padding="20,48,20,8" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Text="←"
                    FontSize="20" WidthRequest="36" HeightRequest="36"
                    Padding="0" CornerRadius="10"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1" Text="Join a Family"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="17" FontAttributes="Bold"
                   CharacterSpacing="-0.01"
                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
            <BoxView Grid.Column="2" WidthRequest="36" HeightRequest="36" BackgroundColor="Transparent" />
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,32,24,24" Spacing="24">

                <!-- Icon -->
                <Border WidthRequest="72" HeightRequest="72"
                        HorizontalOptions="Center"
                        StrokeThickness="0">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E5BFF" Offset="0" />
                            <GradientStop Color="#6D5BD0" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label Text="🏠" FontSize="32"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <!-- Heading -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="Enter your invitation code"
                           FontFamily="Geist" FontSize="20" FontAttributes="Bold"
                           CharacterSpacing="-0.02"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                    <Label Text="Paste the code from your invitation email"
                           FontFamily="Geist" FontSize="14" Opacity="0.6"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                </VerticalStackLayout>

                <!-- Input -->
                <Border StrokeThickness="1.5"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyBorderLight}, Dark={DynamicResource FamilyBorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <Entry Text="{Binding Token}"
                           Placeholder="Paste invitation code here"
                           PlaceholderColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}"
                           FontFamily="Geist" FontSize="14"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}"
                           BackgroundColor="Transparent"
                           Margin="12,14"
                           ReturnCommand="{Binding AcceptCommand}" />
                </Border>

                <!-- Error message -->
                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource HasText}}"
                       FontFamily="Geist" FontSize="13"
                       TextColor="#E53935"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center" />

                <!-- Accept button -->
                <Button Text="Accept Invitation"
                        Command="{Binding AcceptCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        HeightRequest="52" CornerRadius="14"
                        FontFamily="Geist" FontSize="15" FontAttributes="Bold"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                        TextColor="White" />

                <!-- Loading indicator -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                                   HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
