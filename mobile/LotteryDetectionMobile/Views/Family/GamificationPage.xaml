<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:LotteryDetectionMobile.Views.Components"
             xmlns:viewModel="clr-namespace:LotteryDetectionMobile.ViewModel"
             xmlns:models="clr-namespace:LotteryDetectionMobile.Models.Family"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="LotteryDetectionMobile.Views.Family.GamificationPage"
             x:DataType="viewModel:GamificationViewModel"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCreamLight}, Dark={DynamicResource FamilyCreamDark}}">
    <ContentPage.BindingContext>
        <viewModel:GamificationViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Top bar -->
        <Grid Grid.Row="0" Padding="20,40,20,8" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Text="←"
                    FontSize="20"
                    WidthRequest="36" HeightRequest="36"
                    Padding="0" CornerRadius="10"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={DynamicResource FamilyInk2Light}, Dark={DynamicResource FamilyInk2Dark}}"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1" Text="Your progress"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontFamily="Geist" FontSize="17" FontAttributes="Bold"
                   CharacterSpacing="-0.01"
                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
            <BoxView Grid.Column="2" WidthRequest="36" HeightRequest="36" BackgroundColor="Transparent" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="0">
            <VerticalStackLayout Padding="20,8,20,8" Spacing="14">
                <!-- Hero level card -->
                <Border Padding="20"
                        StrokeThickness="0">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0A2E8A" Offset="0" />
                            <GradientStop Color="#1E5BFF" Offset="0.5" />
                            <GradientStop Color="#6D5BD0" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#1E5BFF" Offset="0,12" Radius="32" Opacity="0.32" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" VerticalOptions="Center">
                            <Grid Grid.Column="0" WidthRequest="64" HeightRequest="64">
                                <components:FamilyAvatar Member="{Binding MyMember}" Name="{Binding MyInitial}" Size="56" Ring="True"
                                                         HorizontalOptions="Center" VerticalOptions="Center" />
                                <Border WidthRequest="24" HeightRequest="24"
                                        BackgroundColor="White"
                                        Stroke="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}"
                                        StrokeThickness="2"
                                        HorizontalOptions="End" VerticalOptions="End">
                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                    <Label Text="{Binding Level}"
                                           FontFamily="GeistMono" FontSize="11" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                                </Border>
                            </Grid>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="FAMILY HERO"
                                       FontFamily="Geist" FontSize="11" FontAttributes="Bold" Opacity="0.75"
                                       CharacterSpacing="0.06" TextTransform="Uppercase"
                                       TextColor="White" />
                                <Label FontFamily="Geist" FontSize="22" FontAttributes="Bold"
                                       CharacterSpacing="-0.02" TextColor="White">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding MyName}" />
                                            <Span Text=" · " />
                                            <Span Text="{Binding LevelLabel}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Text="{Binding XpDisplay}"
                                       FontFamily="Geist" FontSize="12" Opacity="0.85"
                                       TextColor="White" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- progress bar (white track + filled border) -->
                        <Grid HeightRequest="8">
                            <Border BackgroundColor="#33FFFFFF" StrokeThickness="0">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="99" /></Border.StrokeShape>
                            </Border>
                            <Grid HorizontalOptions="Start">
                                <Border BackgroundColor="White" StrokeThickness="0"
                                        WidthRequest="{Binding LevelProgressFraction, Converter={StaticResource ProgressWidth}, ConverterParameter=260}"
                                        HeightRequest="8">
                                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="99" /></Border.StrokeShape>
                                </Border>
                            </Grid>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   FontFamily="GeistMono" FontSize="11" Opacity="0.85" TextColor="White">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding XpInLevel}" />
                                        <Span Text=" XP earned this level" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Grid.Column="1"
                                   FontFamily="GeistMono" FontSize="11" Opacity="0.85" TextColor="White">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding XpToNextLevel}" />
                                        <Span Text=" XP to " />
                                        <Span Text="{Binding NextLevelLabel}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Grid>

                        <!-- Hero stats -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Border Grid.Column="0" Padding="10,12" StrokeThickness="1"
                                    Stroke="#2EFFFFFF" BackgroundColor="#26FFFFFF">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="🔥" FontSize="18" />
                                    <Label Text="{Binding Streak}" FontFamily="GeistMono" FontSize="18" FontAttributes="Bold" CharacterSpacing="-0.02" TextColor="White" />
                                    <Label Text="DAY STREAK" FontFamily="Geist" FontSize="9.5" FontAttributes="Bold" Opacity="0.85"
                                           CharacterSpacing="0.04" TextTransform="Uppercase" TextColor="White" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" Padding="10,12" StrokeThickness="1"
                                    Stroke="#2EFFFFFF" BackgroundColor="#26FFFFFF">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="⚡" FontSize="18" />
                                    <Label Text="{Binding Weekly}" FontFamily="GeistMono" FontSize="18" FontAttributes="Bold" CharacterSpacing="-0.02" TextColor="White" />
                                    <Label Text="THIS WEEK" FontFamily="Geist" FontSize="9.5" FontAttributes="Bold" Opacity="0.85"
                                           CharacterSpacing="0.04" TextTransform="Uppercase" TextColor="White" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2" Padding="10,12" StrokeThickness="1"
                                    Stroke="#2EFFFFFF" BackgroundColor="#26FFFFFF">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="🏆" FontSize="18" />
                                    <Label Text="{Binding Badges.Count}"
                                           FontFamily="GeistMono" FontSize="18" FontAttributes="Bold" CharacterSpacing="-0.02"
                                           TextColor="White" />
                                    <Label Text="BADGES" FontFamily="Geist" FontSize="9.5" FontAttributes="Bold" Opacity="0.85"
                                           CharacterSpacing="0.04" TextTransform="Uppercase" TextColor="White" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Leaderboard -->
                <Label Text="FAMILY LEADERBOARD · THIS WEEK" Style="{StaticResource FamilyEyebrowStyle}"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <Border StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}"
                        Padding="0">
                    <Border.StrokeShape><shapes:RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <CollectionView ItemsSource="{Binding Leaderboard}" SelectionMode="None"
                                    BackgroundColor="Transparent">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:AchievementRow">
                                <Grid ColumnDefinitions="32,Auto,*,Auto"
                                      ColumnSpacing="12"
                                      Padding="14,12">
                                    <Label Grid.Column="0" Text="{Binding Medal}"
                                           FontFamily="GeistMono" FontSize="16" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                    <components:FamilyAvatar Grid.Column="1"
                                                             Member="{Binding MemberId}"
                                                             Name="{Binding Name}"
                                                             Size="32"
                                                             VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="2" Spacing="1" VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding Name}"
                                                   FontFamily="Geist" FontSize="14" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                            <Border IsVisible="{Binding IsMe}" Padding="6,1" StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryTintLight}, Dark={DynamicResource FamilyPrimaryTintDark}}">
                                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                                                <Label Text="YOU"
                                                       FontFamily="Geist" FontSize="10" FontAttributes="Bold"
                                                       CharacterSpacing="0.04"
                                                       TextColor="{AppThemeBinding Light={DynamicResource FamilyPrimaryLight}, Dark={DynamicResource FamilyPrimaryDark}}" />
                                            </Border>
                                        </HorizontalStackLayout>
                                        <Label FontFamily="Geist" FontSize="11"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="🔥 " />
                                                    <Span Text="{Binding Streak}" />
                                                    <Span Text="-day streak" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="3" Spacing="0" HorizontalOptions="End" VerticalOptions="Center">
                                        <Label Text="{Binding Weekly}"
                                               FontFamily="GeistMono" FontSize="15" FontAttributes="Bold"
                                               CharacterSpacing="-0.01"
                                               HorizontalOptions="End"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                        <Label Text="XP"
                                               FontFamily="Geist" FontSize="10" FontAttributes="Bold"
                                               CharacterSpacing="0.04"
                                               HorizontalOptions="End"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <!-- Badges -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="BADGES"
                           Style="{StaticResource FamilyEyebrowStyle}"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                    <Label Grid.Column="1"
                           FontFamily="Geist" FontSize="11" CharacterSpacing="0.04"
                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk4Light}, Dark={DynamicResource FamilyInk4Dark}}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="· " />
                                <Span Text="{Binding BadgesEarnedSummary}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Grid>
                <CollectionView ItemsSource="{Binding Badges}" SelectionMode="None" BackgroundColor="Transparent"
                                HeightRequest="240">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:BadgeRow">
                            <Border Padding="12,12"
                                    StrokeThickness="1"
                                    Stroke="{Binding Earned, Converter={StaticResource EarnedStroke}}"
                                    BackgroundColor="{Binding Earned, Converter={StaticResource EarnedBg}}"
                                    Opacity="{Binding Earned, Converter={StaticResource EarnedOpacity}}">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Border WidthRequest="44" HeightRequest="44"
                                            StrokeThickness="0"
                                            HorizontalOptions="Center"
                                            BackgroundColor="{Binding Earned, Converter={StaticResource EarnedBadgeBg}}">
                                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                                        <Label Text="{Binding Emoji}"
                                               FontSize="22"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Text="{Binding Label}"
                                           FontFamily="Geist" FontSize="11" FontAttributes="Bold"
                                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                                           CharacterSpacing="-0.005"
                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                    <Label Text="{Binding Description}"
                                           FontFamily="Geist" FontSize="9.5"
                                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                                           LineHeight="1.3"
                                           TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Rewards -->
                <Label Text="SPEND XP ON REWARDS"
                       Style="{StaticResource FamilyEyebrowStyle}" Margin="0,4,0,0"
                       TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}" />
                <CollectionView ItemsSource="{Binding Rewards}" SelectionMode="None" BackgroundColor="Transparent">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Reward">
                            <Border Padding="14,10"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light={DynamicResource FamilyCream3Light}, Dark={DynamicResource FamilyCream3Dark}}"
                                    BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyPaperLight}, Dark={DynamicResource FamilyPaperDark}}">
                                <Border.StrokeShape><shapes:RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <Border Grid.Column="0" WidthRequest="36" HeightRequest="36"
                                            BackgroundColor="{AppThemeBinding Light={DynamicResource FamilyCream2Light}, Dark={DynamicResource FamilyCream2Dark}}"
                                            StrokeThickness="0"
                                            HorizontalOptions="Center" VerticalOptions="Center">
                                        <Border.StrokeShape><shapes:RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                        <Label Text="{Binding Emoji}" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontFamily="Geist" FontSize="13.5" FontAttributes="Bold"
                                               CharacterSpacing="-0.005"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInkLight}, Dark={DynamicResource FamilyInkDark}}" />
                                        <Label FontFamily="GeistMono" FontSize="11"
                                               TextColor="{AppThemeBinding Light={DynamicResource FamilyInk3Light}, Dark={DynamicResource FamilyInk3Dark}}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="⚡ " />
                                                    <Span Text="{Binding Cost}" />
                                                    <Span Text=" XP" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </VerticalStackLayout>
                                    <Button Grid.Column="2"
                                            HeightRequest="32" Padding="14,0" CornerRadius="8"
                                            FontFamily="Geist" FontSize="12" FontAttributes="Bold">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding Affordable}" Value="True">
                                                <Setter Property="Text" Value="Redeem" />
                                                <Setter Property="BackgroundColor"
                                                        Value="{AppThemeBinding Light={StaticResource FamilyPrimaryLight}, Dark={StaticResource FamilyPrimaryDark}}" />
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Button" Binding="{Binding Affordable}" Value="False">
                                                <Setter Property="Text" Value="Locked" />
                                                <Setter Property="BackgroundColor"
                                                        Value="{AppThemeBinding Light={StaticResource FamilyCream2Light}, Dark={StaticResource FamilyCream2Dark}}" />
                                                <Setter Property="TextColor"
                                                        Value="{AppThemeBinding Light={StaticResource FamilyInk4Light}, Dark={StaticResource FamilyInk4Dark}}" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              IsVisible="{Binding ShowSkeleton}"
              BackgroundColor="#F8FAFC"
              Padding="20,8,20,8">
            <components:GamificationSkeleton />
        </Grid>

        <components:BottomBarView Grid.Row="2"
                                  x:Name="BottomBar"
                                  TabSelected="OnTabSelected" />
    </Grid>

    <ContentPage.Resources>
        <ResourceDictionary xmlns:cv="clr-namespace:LotteryDetectionMobile.Converters">
            <cv:ProgressWidthConverter x:Key="ProgressWidth" />
            <cv:EarnedOpacityConverter x:Key="EarnedOpacity" />
            <cv:EarnedStrokeConverter x:Key="EarnedStroke" />
            <cv:EarnedBackgroundConverter x:Key="EarnedBg" />
            <cv:EarnedBadgeBackgroundConverter x:Key="EarnedBadgeBg" />
        </ResourceDictionary>
    </ContentPage.Resources>
</ContentPage>
